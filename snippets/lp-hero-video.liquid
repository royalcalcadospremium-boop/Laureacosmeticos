{%- comment -%}
  lp-hero-video.liquid — Hero reusável com vídeo em background.
  Usado pelas 3 LPs (atacado, dropshipping, varejo).

  Parâmetros:
    video_url    — URL do vídeo (mp4/webm, Shopify Files ou externo)
    poster_url   — img_url do poster (fallback enquanto carrega)
    overlay      — alpha 0-100 do overlay escuro (default 55)
    badge        — texto da badge de prova social (opcional)
    eyebrow      — pequeno label acima do título (opcional)
    title        — headline H1 (obrigatório)
    subtitle     — subheadline em 1 linha
    cta1_label   — texto do CTA primário
    cta1_url     — URL do CTA primário
    cta2_label   — texto do CTA secundário (opcional)
    cta2_url     — URL do CTA secundário (opcional)
    cta2_variant — 'whatsapp' aplica verde; default = ghost
{%- endcomment -%}

{%- assign _overlay_alpha = overlay | default: 55 | divided_by: 100.0 -%}

<section class="lp-hero">
  {%- if video_url != blank -%}
    <video
      class="lp-hero__video"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      {% if poster_url != blank %}poster="{{ poster_url }}"{% endif %}
      aria-hidden="true"
    >
      <source src="{{ video_url }}" type="video/mp4">
    </video>
  {%- elsif poster_url != blank -%}
    <img class="lp-hero__poster" src="{{ poster_url }}" alt="" loading="eager">
  {%- endif -%}

  <div class="lp-hero__overlay" style="opacity: {{ _overlay_alpha }}"></div>

  <div class="lp-hero__inner">
    {%- if badge != blank -%}
      <span class="lp-hero__badge lp-reveal">{{ badge }}</span>
    {%- endif -%}

    {%- if eyebrow != blank -%}
      <p class="lp-section__eyebrow lp-reveal" style="color: var(--ad-color-primary-on-dark)">{{ eyebrow }}</p>
    {%- endif -%}

    <h1 class="lp-hero__title lp-reveal">{{ title }}</h1>

    {%- if subtitle != blank -%}
      <p class="lp-hero__subtitle lp-reveal">{{ subtitle }}</p>
    {%- endif -%}

    {%- if cta1_label != blank or cta2_label != blank -%}
      <div class="lp-hero__ctas lp-reveal">
        {%- if cta1_label != blank -%}
          <a class="lp-cta lp-cta--primary lp-cta--large" href="{{ cta1_url | default: '#' }}">
            {{ cta1_label }}
          </a>
        {%- endif -%}
        {%- if cta2_label != blank -%}
          <a class="lp-cta lp-cta--large {% if cta2_variant == 'whatsapp' %}lp-cta--whatsapp{% else %}lp-cta--secondary{% endif %}" href="{{ cta2_url | default: '#' }}"{% if cta2_variant == 'whatsapp' %} target="_blank" rel="noopener"{% endif %}>
            {%- if cta2_variant == 'whatsapp' -%}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
              </svg>
            {%- endif -%}
            {{ cta2_label }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>
