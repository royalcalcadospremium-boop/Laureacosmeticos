{%- comment -%}
  Snippet: rc-product-card.liquid
  Requer: product (objeto Shopify)

  Lógica de preços (a partir de 14-mai-2026):
  - v.price (Shopify)            = PREÇO DE VAREJO (sincronizado pelo sync/sync-precos.js)
  - metafield custom.preco_atacado = PREÇO DE ATACADO base (10+ pares)
  - Tiers de atacado: -R$1 (50+) | -R$2 (100+) | -R$3 (200+)
  - Shopify Function aplica os descontos progressivos no carrinho.

  Fallback se metafield ausente: atacado ≈ varejo × (1 - desconto%) — só pra não quebrar o card.
{%- endcomment -%}
{%- assign v = product.selected_or_first_available_variant -%}

{%- assign retail_cents = v.price -%}
{%- assign wholesale_raw = product.metafields.custom.preco_atacado -%}
{%- if wholesale_raw == blank or wholesale_raw == 0 -%}
  {%- assign wd = settings.atacado_discount_percent | default: 40 -%}
  {%- assign factor = 100 | minus: wd -%}
  {%- assign wholesale_cents = retail_cents | times: factor | divided_by: 100 -%}
{%- else -%}
  {%- assign wholesale_cents = wholesale_raw | times: 100 | round -%}
{%- endif -%}

{%- comment -%} Calcula os 4 tiers de atacado em centavos {%- endcomment -%}
{%- assign t10 = wholesale_cents -%}
{%- assign t50 = wholesale_cents | minus: 100 -%}
{%- assign t100 = wholesale_cents | minus: 200 -%}
{%- assign t200 = wholesale_cents | minus: 300 -%}
{%- if t50 < 0 -%}{%- assign t50 = 0 -%}{%- endif -%}
{%- if t100 < 0 -%}{%- assign t100 = 0 -%}{%- endif -%}
{%- if t200 < 0 -%}{%- assign t200 = 0 -%}{%- endif -%}

<article class="rc-card" data-product-id="{{ product.id }}">
  {%- if retail_cents > wholesale_cents -%}
    {%- assign discount_pct = retail_cents | minus: wholesale_cents | times: 100 | divided_by: retail_cents | round -%}
    <div class="rc-badge">-{{ discount_pct }}%</div>
  {%- endif -%}

  {%- assign __idx = product_index | default: 99 -%}
  {%- if __idx <= 4 -%}{%- assign __loading = 'eager' -%}{%- else -%}{%- assign __loading = 'lazy' -%}{%- endif -%}
  <a class="rc-media" href="{{ product.url }}">
    {%- render 'rc-product-image', product: product, size: '600x600', loading: __loading, alt: product.title -%}
    <button class="nb-bag" type="button" onclick="event.preventDefault(); openQuickBuy('{{ product.id }}')">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
    </button>
  </a>

  <div style="padding: 12px;">
    <a href="{{ product.url }}" class="rc-name">{{ product.title }}</a>

    {%- render 'rc-tier-boxes', product: product -%}
  </div>

  <script type="application/json" id="data-{{ product.id }}">
    {
      "id": {{ product.id }},
      "title": {{ product.title | json }},
      "image": "{{ product.featured_image | img_url: 'master' }}",
      "price": "{{ retail_cents | money }}",
      "price_raw": {{ retail_cents }},
      "wholesale_price": "{{ wholesale_cents | money }}",
      "wholesale_price_raw": {{ wholesale_cents }},
      "wholesale_min_qty": 10,
      "vendor": {{ product.vendor | json }},
      "tags": {{ product.tags | json }},
      "collections": [{% for c in product.collections %}"{{ c.handle }}"{% unless forloop.last %},{% endunless %}{% endfor %}],
      "variants": [
        {%- for var in product.variants -%}
          { "id": "{{ var.id }}", "title": {{ var.title | json }}, "available": {{ var.available }}, "inventory": {{ var.inventory_quantity | default: 0 }}, "tracked": {% if var.inventory_management == 'shopify' %}true{% else %}false{% endif %} }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    }
  </script>
</article>
