{%- comment -%}
  Snippet: rc-tier-card-assets.liquid
  CSS + JS globais. Renderizado UMA vez por pagina (flag rc_tier_card_assets_loaded).
  Layout compacto SEM labels "VAREJO"/"ATACADO"/"por par" — apenas qty + preço.
{%- endcomment -%}

{%- unless rc_tier_card_assets_loaded -%}
{%- assign rc_tier_card_assets_loaded = true -%}

<style>
/* ===========================================================================
   Image swap (foto 1 -> foto 2 ao hover/touch). Usa wrapper .rc-media-swap
   com 2 <img> empilhadas (.rc-img-primary / .rc-img-secondary).
   O wrapper ocupa 100% do container (.rc-media, .imgwrap, .nb-rec-card__img-wrap).
   =========================================================================== */
.rc-media-swap{
  position: absolute; inset: 0;
  width: 100%; height: 100%;
}
.rc-media-swap .rc-img-primary,
.rc-media-swap .rc-img-secondary{
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  object-fit: contain;
  transition: opacity 0.3s ease;
}
.rc-media-swap .rc-img-secondary{
  opacity: 0;
  pointer-events: none;
}
/* Desktop hover (acionado pelo card pai, nao so pela imagem) */
@media (hover: hover){
  .rc-card:hover .rc-media-swap .rc-img-secondary,
  .card:hover .rc-media-swap .rc-img-secondary,
  .nb-rec-card:hover .rc-media-swap .rc-img-secondary{ opacity: 1; }
  .rc-card:hover .rc-media-swap .rc-img-primary,
  .card:hover .rc-media-swap .rc-img-primary,
  .nb-rec-card:hover .rc-media-swap .rc-img-primary{ opacity: 0; }
}
/* Mobile: rotacao automatica a cada 3s via JS (.is-auto-flipped) */
.rc-media-swap.is-auto-flipped .rc-img-secondary{ opacity: 1; }
.rc-media-swap.is-auto-flipped .rc-img-primary{ opacity: 0; }

/* ===========================================================================
   Tier-card: tabela compacta de 2 linhas (varejo + atacado dropdown)
   Layout grid (1fr auto) garante alinhamento perfeito desktop + mobile.
   =========================================================================== */
.rc-card .rc-tier-table{
  margin-top: 6px;
  font-size: 0; /* anula whitespace entre spans */
}

.rc-card .rc-tier-section{
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: center;
  gap: 8px;
  padding: 4px 0;
  font-size: 12px;
}

.rc-card .rc-tier-divider{
  height: 1px;
  background: #ececec;
  margin: 0;
}

/* Linha VAREJO (1 PAR ............ R$ XX,XX) */
.rc-card .rc-tier-qty{
  font-size: 12px;
  font-weight: 700;
  color: #111;
  letter-spacing: 0.02em;
  line-height: 1.2;
}
.rc-card .rc-tier-price-retail{
  font-size: 13px;
  font-weight: 700;
  color: #111;
  white-space: nowrap;
  line-height: 1.2;
  text-align: right;
}

/* Linha ATACADO ([10 PARES ▾] ...... R$ XX,XX em verde) */
.rc-card .rc-tier-section--wholesale{
  position: relative; /* ancora pro dropdown inline (fallback) */
}
.rc-card .rc-tier-select{
  display: inline-flex;
  align-items: center;
  gap: 4px;
  background: #fff;
  border: 1.3px solid #d8d8d8;
  border-radius: 5px;
  padding: 3px 7px;
  font-size: 11px;
  font-weight: 700;
  color: #111;
  cursor: pointer;
  font-family: inherit;
  letter-spacing: 0.02em;
  white-space: nowrap;
  line-height: 1.2;
  transition: border-color 0.15s ease;
  justify-self: start;
}
.rc-card .rc-tier-select:hover,
.rc-card .rc-tier-select[aria-expanded="true"]{
  border-color: #00d864;
}
.rc-card .rc-tier-chevron{
  font-size: 9px;
  color: #666;
  transition: transform 0.15s ease;
}
.rc-card .rc-tier-select[aria-expanded="true"] .rc-tier-chevron{
  transform: rotate(180deg);
}
.rc-card .rc-tier-price-wholesale{
  font-size: 16px;
  font-weight: 800;
  color: #00a04a;
  letter-spacing: -0.01em;
  white-space: nowrap;
  line-height: 1.1;
  text-align: right;
}

/* Mobile: reduz um pouquinho */
@media (max-width: 480px){
  .rc-card .rc-tier-qty{ font-size: 11px; }
  .rc-card .rc-tier-price-retail{ font-size: 12px; }
  .rc-card .rc-tier-select{ font-size: 10px; padding: 2px 6px; }
  .rc-card .rc-tier-price-wholesale{ font-size: 14px; }
}

/* ===========================================================================
   Overlay dropdown (posicionado com position:fixed via JS, fora do card)
   =========================================================================== */
.rc-tier-options{
  position: fixed;
  background: #fff;
  border: none;
  border-radius: 10px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.14), 0 2px 6px rgba(0,0,0,0.06);
  z-index: 99999;
  overflow: hidden;
  min-width: 200px;
  max-width: 320px;
  padding: 4px 0;
}
.rc-tier-options[hidden]{ display: none !important; }

.rc-tier-option{
  display: flex;
  align-items: center;
  gap: 10px;
  width: 100%;
  padding: 9px 14px;
  background: #fff;
  border: none;
  cursor: pointer;
  font-family: inherit;
  text-align: left;
}
.rc-tier-option:hover{ background: #f8f8f8; }

/* Checkmark à esquerda (reserva espaço sempre, só mostra ✓ no ativo) */
.rc-tier-opt-check{
  width: 14px; height: 14px;
  flex: 0 0 14px;
  position: relative;
}
.rc-tier-option--active .rc-tier-opt-check::before{
  content: "";
  position: absolute;
  left: 1px; top: 1px;
  width: 7px; height: 11px;
  border: solid #00a04a;
  border-width: 0 2.5px 2.5px 0;
  transform: rotate(45deg);
}

.rc-tier-opt-qty{
  font-size: 13px;
  font-weight: 700;
  color: #111;
  letter-spacing: 0.02em;
  white-space: nowrap;
}
.rc-tier-option--active .rc-tier-opt-qty{ font-weight: 800; }
.rc-tier-opt-price{
  font-size: 13px;
  font-weight: 700;
  color: #111;
  margin-left: auto;
  white-space: nowrap;
}
.rc-tier-option--active .rc-tier-opt-price{
  color: #00a04a;
  font-weight: 800;
}
</style>

<script>
(function(){
  if (window.__rcTiersInit) return;
  window.__rcTiersInit = true;

  // Estado: overlay aberto vive em document.body. Guardamos referencias para devolver depois.
  var openState = null;

  function getWholesaleBox(btn) {
    // Aceita qualquer container que tenha .rc-tier-options dentro (a linha de atacado).
    var section = btn.closest('.rc-tier-section--wholesale');
    if (section) return section;
    // Fallback para layouts antigos
    return btn.closest('.rc-tier-wholesale') || btn.parentElement;
  }

  function positionOverlay(){
    if (!openState) return;
    var rect = openState.anchorBtn.getBoundingClientRect();
    var opts = openState.opts;
    opts.style.minWidth = Math.max(rect.width, 200) + 'px';
    opts.style.left = '0px';
    opts.style.top  = '0px';
    var optsRect = opts.getBoundingClientRect();
    var vw = window.innerWidth, vh = window.innerHeight;
    var left = rect.left;
    if (left + optsRect.width > vw - 8) left = vw - 8 - optsRect.width;
    if (left < 8) left = 8;
    var top = rect.bottom + 4;
    if (top + optsRect.height > vh - 8) {
      var above = rect.top - 4 - optsRect.height;
      if (above >= 8) top = above;
      else top = Math.max(8, vh - 8 - optsRect.height);
    }
    opts.style.left = left + 'px';
    opts.style.top  = top  + 'px';
  }

  function closeCurrent(){
    if (!openState) return;
    var st = openState;
    openState = null;
    st.opts.setAttribute('hidden','');
    st.opts.style.left = '';
    st.opts.style.top  = '';
    st.opts.style.minWidth = '';
    if (st.origNext && st.origNext.parentNode === st.origParent) {
      st.origParent.insertBefore(st.opts, st.origNext);
    } else if (st.origParent) {
      st.origParent.appendChild(st.opts);
    }
    if (st.anchorBtn) st.anchorBtn.setAttribute('aria-expanded','false');
  }

  window.rcToggleTiers = function(btn, ev){
    if (ev) { ev.preventDefault(); ev.stopPropagation(); }
    // Se este botao ja esta aberto, fecha.
    if (openState && openState.anchorBtn === btn) { closeCurrent(); return; }
    var box = getWholesaleBox(btn);
    if (!box) return;
    var opts = box.querySelector('.rc-tier-options');
    if (!opts) return;
    closeCurrent();
    openState = {
      opts: opts,
      origParent: opts.parentNode,
      origNext:  opts.nextSibling,
      anchorBtn: btn,
      box: box
    };
    document.body.appendChild(opts);
    opts.removeAttribute('hidden');
    btn.setAttribute('aria-expanded','true');
    positionOverlay();
  };

  window.rcPickTier = function(optBtn, ev){
    if (ev) { ev.preventDefault(); ev.stopPropagation(); }
    var box = (openState && openState.box) || getWholesaleBox(optBtn);
    if (!box) return;
    var qty = optBtn.getAttribute('data-qty');
    var priceText = optBtn.querySelector('.rc-tier-opt-price').innerText.trim();
    var display = box.querySelector('[data-price-display]');
    var current = box.querySelector('.rc-tier-current');
    if (display) display.innerText = priceText;
    if (current) { current.innerText = qty + ' PARES'; current.setAttribute('data-qty', qty); }
    var opts = openState ? openState.opts : box.querySelector('.rc-tier-options');
    if (opts) {
      opts.querySelectorAll('.rc-tier-option').forEach(function(b){
        b.classList.remove('rc-tier-option--active');
      });
    }
    optBtn.classList.add('rc-tier-option--active');
    closeCurrent();
  };

  // Fecha overlay ao clicar fora
  document.addEventListener('click', function(e){
    if (!openState) return;
    if (openState.opts.contains(e.target)) return;
    if (openState.anchorBtn.contains(e.target)) return;
    closeCurrent();
  });

  /* ============ Image swap automatico (mobile) ============
     Desktop usa :hover via CSS. No mobile, alterna primary <-> secondary
     a cada 3s, em CADA card visivel no viewport (IntersectionObserver).
     Sem interacao do usuario (nao usa touch). */
  function isMobileNow(){
    return window.matchMedia('(hover: none) and (pointer: coarse), (max-width: 767px)').matches;
  }

  var visibleMedias = new Set();
  var mediaIO = null;
  function ensureObserver(){
    if (mediaIO) return mediaIO;
    mediaIO = new IntersectionObserver(function(entries){
      entries.forEach(function(en){
        var m = en.target;
        if (en.isIntersecting) {
          visibleMedias.add(m);
        } else {
          visibleMedias.delete(m);
          m.classList.remove('is-auto-flipped');
        }
      });
    }, { rootMargin: '50px' });
    return mediaIO;
  }

  function attachAll(){
    var io = ensureObserver();
    document.querySelectorAll('.rc-media-swap').forEach(function(m){
      if (m.__rcObserved) return;
      // So observa cards que tem realmente foto secundaria
      if (!m.querySelector('.rc-img-secondary')) return;
      m.__rcObserved = true;
      io.observe(m);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', attachAll);
  } else {
    attachAll();
  }
  // Reaplica quando DOM muda (carrosseis com lazy load, etc)
  var mo = new MutationObserver(function(){ attachAll(); });
  mo.observe(document.body, { childList: true, subtree: true });

  // Loop principal: a cada 5s alterna .is-auto-flipped nos visiveis (so mobile)
  setInterval(function(){
    if (!isMobileNow()) return;
    if (!visibleMedias.size) return;
    visibleMedias.forEach(function(m){
      m.classList.toggle('is-auto-flipped');
    });
  }, 5000);

  // Reposiciona em scroll/resize, fecha em Esc
  window.addEventListener('scroll', function(){ if (openState) positionOverlay(); }, true);
  window.addEventListener('resize', function(){ if (openState) positionOverlay(); });
  document.addEventListener('keydown', function(e){
    if (e.key === 'Escape' && openState) closeCurrent();
  });
})();
</script>
{%- endunless -%}
