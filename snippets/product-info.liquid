<script>
/* ---- Dados do produto para JS ---- */
var rcProductVariants = {{ product.variants | json }};
var rcSelectedOpts = [
  {{ selected_variant.option1 | json }},
  {{ selected_variant.option2 | json }},
  {{ selected_variant.option3 | json }}
];
var rcDownloadData = {
  title: {{ product.title | json }},
  sku: {{ selected_variant.sku | default: product.id | json }},
  priceFormatted: {{ selected_variant.price | money | json }},
  images: [{% for img in product.images %}"{{ img | img_url: 'master' }}"{% unless forloop.last %},{% endunless %}{% endfor %}],
  variants: [{% for var in product.variants %}{title:{{ var.title | json }},available:{{ var.available }},inventory:{{ var.inventory_quantity | default: 0 }}}{% unless forloop.last %},{% endunless %}{% endfor %}]
};

/* ---- Formatar dinheiro ---- */
function rcMoney(cents) {
  return 'R$ ' + (cents / 100).toFixed(2).replace('.', ',');
}

/* ---- Encontrar variante pelos opts selecionados ---- */
function rcFindVariant() {
  return rcProductVariants.find(function(v) {
    return (rcSelectedOpts[0] == null || v.option1 === rcSelectedOpts[0]) &&
           (rcSelectedOpts[1] == null || v.option2 === rcSelectedOpts[1]) &&
           (rcSelectedOpts[2] == null || v.option3 === rcSelectedOpts[2]);
  });
}

/* ---- Razão varejo↔atacado (recalcular ao trocar variante) ----
   v.price = VAREJO.  Atacado = v.price × rcWholesaleRatio  */
var rcRetailBaseCents = {{ retail_cents_pi | json }};
var rcWholesaleBaseCents = {{ wholesale_cents_pi | json }};
var rcWholesaleRatio = (rcRetailBaseCents > 0)
  ? (rcWholesaleBaseCents / rcRetailBaseCents)
  : (100 - ({{ settings.atacado_discount_percent | default: 40 | json }})) / 100;

/* ---- Atualizar UI quando variante muda ---- */
function rcApplyVariant(v) {
  if (!v) return;
  // Hidden ID input
  var idInput = document.getElementById('rc-variant-id');
  if (idInput) idInput.value = v.id;
  // Preço varejo (1 par) = v.price direto
  var priceEl = document.querySelector('[data-product-price]');
  if (priceEl) priceEl.textContent = rcMoney(v.price);
  // Preço atacado (callout verde N+ pares) = v.price × ratio
  var wholesaleEl = document.querySelector('[data-wholesale-price]');
  if (wholesaleEl) {
    var wholesaleCents = Math.round(v.price * rcWholesaleRatio);
    var unit = wholesaleEl.querySelector('.wholesale-callout__unit');
    wholesaleEl.textContent = rcMoney(wholesaleCents);
    if (unit) wholesaleEl.appendChild(unit); else {
      var u = document.createElement('span');
      u.className = 'wholesale-callout__unit';
      u.textContent = '/par';
      wholesaleEl.appendChild(u);
    }
  }
  // Badge de urgência
  var urgency = document.querySelector('.product-urgency');
  if (urgency) {
    if (v.inventory_management === 'shopify' && v.inventory_quantity > 0 && v.inventory_quantity <= 10) {
      urgency.querySelector('strong').textContent = v.inventory_quantity + ' pares';
      urgency.style.display = 'flex';
    } else {
      urgency.style.display = 'none';
    }
  }
}

/* ---- Download: cartão de revenda (Canvas) ---- */
function rcCriarCartao(data) {
  return new Promise(function(resolve) {
    var W = 800, H = 1080;
    var canvas = document.createElement('canvas');
    canvas.width = W; canvas.height = H;
    var ctx = canvas.getContext('2d');

    function draw(productImg) {
      ctx.fillStyle = '#f8f8f8';
      ctx.fillRect(0, 0, W, H);

      var y = 20;
      if (productImg) {
        var iAr = productImg.naturalWidth / productImg.naturalHeight;
        var iH = Math.round(W / iAr);
        iH = Math.min(iH, 460);
        var iW = Math.round(iH * iAr);
        ctx.drawImage(productImg, Math.round((W - iW) / 2), y, iW, iH);
        y += iH;
        // gradient fade
        var g = ctx.createLinearGradient(0, y - 50, 0, y);
        g.addColorStop(0, 'rgba(248,248,248,0)');
        g.addColorStop(1, 'rgba(248,248,248,1)');
        ctx.fillStyle = g; ctx.fillRect(0, y - 50, W, 50);
      }
      y += 18;

      // Título
      ctx.fillStyle = '#111';
      ctx.font = 'bold 24px system-ui, Arial, sans-serif';
      var title = data.title.length > 42 ? data.title.slice(0, 42) + '…' : data.title;
      ctx.fillText(title, 32, y); y += 34;

      // Ref
      ctx.fillStyle = '#999';
      ctx.font = '13px system-ui, Arial, sans-serif';
      var sku = data.sku ? String(data.sku) : String(data.title).replace(/[^a-z0-9]/gi,'').slice(0,8).toUpperCase();
      ctx.fillText('Ref.: ' + sku, 32, y); y += 28;

      // Separador
      ctx.strokeStyle = '#e0e0e0'; ctx.lineWidth = 1;
      ctx.beginPath(); ctx.moveTo(32, y); ctx.lineTo(W - 32, y); ctx.stroke(); y += 18;

      // Header tabela
      ctx.fillStyle = '#555';
      ctx.font = '600 11px system-ui, Arial, sans-serif';
      ctx.fillText('DISPONIBILIDADE POR NUMERAÇÃO', 32, y); y += 22;

      data.variants.forEach(function(v) {
        var inv = v.inventory || 0;
        var available = v.available;

        ctx.fillStyle = available ? '#111' : '#bbb';
        ctx.font = (available ? '600 ' : '400 ') + '15px system-ui, Arial, sans-serif';
        ctx.fillText(v.title, 32, y + 1);

        if (available) {
          var dots = Math.max(1, Math.min(5, Math.ceil(inv / 3)));
          for (var d = 0; d < 5; d++) {
            ctx.beginPath();
            ctx.arc(215 + d * 20, y - 4, 6, 0, Math.PI * 2);
            ctx.fillStyle = d < dots ? '#22c55e' : '#e5e5e5';
            ctx.fill();
          }
          if (inv > 0) {
            ctx.fillStyle = '#aaa';
            ctx.font = '11px system-ui, Arial, sans-serif';
            ctx.fillText(inv + ' prs', 330, y + 1);
          }
        } else {
          ctx.fillStyle = '#ddd'; ctx.font = '11px system-ui, Arial, sans-serif';
          ctx.fillText('Esgotado', 215, y + 1);
        }
        y += 28;
      });

      y += 8;
      // Preço sutil
      ctx.fillStyle = '#ccc'; ctx.font = '11px system-ui, Arial, sans-serif';
      ctx.fillText('· ' + data.priceFormatted + ' / par', 32, y); y += 36;

      // Footer
      ctx.fillStyle = '#111'; ctx.fillRect(0, H - 44, W, 44);
      ctx.fillStyle = '#fff'; ctx.font = 'bold 13px system-ui, Arial, sans-serif';
      ctx.fillText('ROYAL ATACADO', 32, H - 15);
      ctx.fillStyle = '#666'; ctx.font = '11px system-ui, Arial, sans-serif';
      var domain = 'royalatacado.com.br';
      ctx.fillText(domain, W - 32 - ctx.measureText(domain).width, H - 15);

      canvas.toBlob(resolve, 'image/png');
    }

    if (data.images && data.images.length > 0) {
      var img = new Image(); img.crossOrigin = 'anonymous';
      img.onload = function() { draw(img); };
      img.onerror = function() { draw(null); };
      var url = data.images[0]; if (url.startsWith('//')) url = 'https:' + url;
      img.src = url;
    } else { draw(null); }
  });
}

/* ---- Download principal ---- */
async function rcBaixarFotos() {
  var btn = document.getElementById('btn-baixar-fotos');
  if (!btn || btn.disabled) return;
  var orig = btn.innerHTML;
  btn.innerHTML = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-.44-4.04"/></svg> Preparando…';
  btn.disabled = true;

  try {
    if (typeof JSZip === 'undefined') {
      await new Promise(function(ok, fail) {
        var s = document.createElement('script');
        s.src = 'https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js';
        s.onload = ok; s.onerror = fail;
        document.head.appendChild(s);
      });
    }

    var zip = new JSZip();
    var name = rcDownloadData.title.replace(/[^a-zA-Z0-9\s]/g,'').trim().slice(0,22).replace(/\s+/g,'-');

    for (var i = 0; i < rcDownloadData.images.length; i++) {
      try {
        var u = rcDownloadData.images[i];
        if (u.startsWith('//')) u = 'https:' + u;
        var r = await fetch(u, { mode: 'cors' });
        if (r.ok) {
          var blob = await r.blob();
          zip.file('foto-' + String(i + 1).padStart(2,'0') + '.jpg', blob);
        }
      } catch(e) { /* pula imagem com erro */ }
    }

    var card = await rcCriarCartao(rcDownloadData);
    if (card) zip.file('tabela-revenda.png', card);

    var zipBlob = await zip.generateAsync({ type: 'blob', compression: 'DEFLATE', compressionOptions: { level: 6 } });
    var a = document.createElement('a');
    a.href = URL.createObjectURL(zipBlob);
    a.download = name + '-royal.zip';
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
    setTimeout(function() { URL.revokeObjectURL(a.href); }, 2000);

    btn.innerHTML = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Baixado!';
    setTimeout(function() { btn.innerHTML = orig; btn.disabled = false; }, 3500);
  } catch(e) {
    console.error('rcBaixarFotos:', e);
    btn.innerHTML = orig; btn.disabled = false;
    alert('Não foi possível baixar. Tente novamente.');
  }
}

(function() {
  // ---- Accordion ----
  document.querySelectorAll('[data-accordion-btn]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var content = this.nextElementSibling;
      var toggle = this.querySelector('.accordion-toggle');
      var isOpen = content.classList.contains('open');
      content.classList.toggle('open');
      toggle.textContent = isOpen ? '+' : '−';
    });
  });

  // ---- Color swatch selection ----
  document.querySelectorAll('.color-radio').forEach(function(radio) {
    radio.addEventListener('change', function() {
      var labelId = this.dataset.colorLabelId;
      var labelEl = document.getElementById(labelId);
      if (labelEl) labelEl.textContent = this.dataset.colorValue;

      // Atualiza estado visual
      this.closest('.color-grid').querySelectorAll('.color-item').forEach(function(item) {
        item.classList.remove('is-selected');
      });
      this.closest('.color-item').classList.add('is-selected');

      // Atualiza opts e variante
      var optPos = parseInt((this.name || '').replace(/[^0-9]/g, ''), 10);
      if (optPos >= 1) {
        rcSelectedOpts[optPos - 1] = this.value;
        var sel = document.getElementById('rc-select-' + optPos);
        if (sel) { sel.value = this.value; sel.dispatchEvent(new Event('change', { bubbles: true })); }
        rcApplyVariant(rcFindVariant());
      }
    });
  });

  // ---- Size button selection ----
  document.querySelectorAll('.size-button').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var sectionEl = this.closest('.size-section');
      var optionPos = parseInt(this.dataset.optionPosition, 10);
      var sizeValue = this.dataset.size;

      // Atualiza botão ativo
      sectionEl.querySelectorAll('.size-button').forEach(function(b) { b.classList.remove('active'); });
      this.classList.add('active');

      // Atualiza opts rastreados
      rcSelectedOpts[optionPos - 1] = sizeValue;

      // Atualiza select oculto (compatibilidade Dropmeta)
      var sel = document.getElementById('rc-select-' + optionPos);
      if (sel) { sel.value = sizeValue; sel.dispatchEvent(new Event('change', { bubbles: true })); }

      // Atualiza variante e UI
      rcApplyVariant(rcFindVariant());
    });
  });

  // ---- CEP mask ----
  var cepInput = document.getElementById('shipping-cep-input');
  if (cepInput) {
    cepInput.addEventListener('input', function() {
      var v = this.value.replace(/\D/g, '');
      if (v.length > 5) v = v.slice(0, 5) + '-' + v.slice(5, 8);
      this.value = v;
    });
  }

  // ---- Shipping calculator ----
  var shippingBtn = document.getElementById('shipping-calc-btn');
  var shippingResult = document.getElementById('shipping-result');
  if (shippingBtn) {
    shippingBtn.addEventListener('click', function() {
      var cep = (cepInput ? cepInput.value : '').replace(/\D/g, '');
      if (cep.length === 8) {
        shippingResult.textContent = 'Calculando...';
        fetch('/apps/shipping?zip=' + cep + '&variant=' + document.querySelector('.product-variant-id').value)
          .then(function(r) { return r.json(); })
          .then(function(data) {
            shippingResult.textContent = data.message || 'Frete calculado com sucesso.';
          })
          .catch(function() {
            shippingResult.textContent = 'Não foi possível calcular o frete agora.';
          });
      } else {
        shippingResult.textContent = 'Por favor, insira um CEP válido (ex: 01310-100).';
      }
    });
  }

  // ---- Wishlist button ----
  var wishlistBtn = document.getElementById('wishlist-btn');
  if (wishlistBtn) {
    wishlistBtn.addEventListener('click', function() {
      var icon = this.querySelector('.wishlist-icon');
      var text = this.querySelector('.wishlist-text');
      if (icon.getAttribute('fill') === 'none') {
        icon.setAttribute('fill', '#D42B2B');
        icon.setAttribute('stroke', '#D42B2B');
        text.textContent = 'Adicionado à lista de desejo';
      } else {
        icon.setAttribute('fill', 'none');
        icon.setAttribute('stroke', 'currentColor');
        text.textContent = 'Adicionar a lista de desejo';
      }
    });
  }

  // ---- Floating buy button ----
  var floatingBtn = document.getElementById('floating-buy-btn');
  if (floatingBtn) {
    floatingBtn.addEventListener('click', function() {
      var buyBtn = document.querySelector('.btn-buy');
      if (buyBtn) buyBtn.click();
    });
  }

  // ---- Size guide modal ----
  (function() {
    var trigger = document.querySelector('.size-guide-trigger');
    var modal = document.getElementById('size-guide-modal');
    if (!trigger || !modal) return;
    var backdrop = modal.querySelector('.size-guide-modal__backdrop');
    var closeBtn = modal.querySelector('.size-guide-modal__close');
    function openModal() { modal.setAttribute('aria-hidden', 'false'); document.body.style.overflow = 'hidden'; }
    function closeModal() { modal.setAttribute('aria-hidden', 'true'); document.body.style.overflow = ''; }
    trigger.addEventListener('click', openModal);
    if (backdrop) backdrop.addEventListener('click', closeModal);
    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeModal(); });
  })();

  // ---- Modality tabs ----
  (function() {
    var tabs = document.querySelectorAll('.pinfo-modality__tab');
    if (!tabs.length) return;
    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        var key = this.dataset.tab;
        tabs.forEach(function(t) {
          t.classList.remove('pinfo-modality__tab--active');
          t.setAttribute('aria-selected', 'false');
        });
        document.querySelectorAll('.pinfo-modality__panel').forEach(function(p) {
          p.classList.remove('pinfo-modality__panel--active');
          p.hidden = true;
        });
        this.classList.add('pinfo-modality__tab--active');
        this.setAttribute('aria-selected', 'true');
        var panel = document.getElementById('tab-' + key);
        if (panel) { panel.classList.add('pinfo-modality__panel--active'); panel.hidden = false; }
      });
    });
  })();
})();
</script>
