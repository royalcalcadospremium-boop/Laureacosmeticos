# Olist / Tiny ERP — API v3 (OAuth 2.0)
# Gere em: https://erp.olist.com/aplicativos_api (instale extensão "Gestão de Aplicativos" antes)
TINY_CLIENT_ID=
TINY_CLIENT_SECRET=
TINY_REDIRECT_URI=http://localhost:3000/oauth/callback
# Tokens são preenchidos automaticamente por `node oauth-flow.js`
TINY_ACCESS_TOKEN=
TINY_REFRESH_TOKEN=
TINY_TOKEN_EXPIRES_AT=

# Shopify Admin API
# Gere em: Shopify Admin → Configurações → Apps → Desenvolver apps → Custom app
# Escopos necessários: read_products, write_products
SHOPIFY_STORE_DOMAIN=812091-2.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_

# Destino dos metafields no Shopify
SHOPIFY_METAFIELD_NAMESPACE=custom
SHOPIFY_METAFIELD_KEY=preco_varejo
# 1 = usa preco.precoPromocional (R$ 37,90); 0 = usa preco.preco (R$ 45,00)
OLIST_USE_PROMO_PRICE=1
