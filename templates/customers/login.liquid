<section data-section-id="login" data-section-type="login" class="ad-login-section">
  <div class="ad-login-wrap">
    <header class="ad-login-header">
      <h1 class="ad-display-lg">Entrar</h1>
      <p class="ad-lead ad-login-sub">Acesse sua conta para acompanhar seus pedidos.</p>
    </header>

    {%- comment -%} LOGIN FORM {%- endcomment -%}
    {%- form 'customer_login', novalidate: 'novalidate' -%}
      {%- if form.errors -%}
        <ul class="ad-login-errors">
          {%- for field in form.errors -%}
            <li class="ad-caption">{{ form.errors.messages[field] }}</li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      <div class="ad-field">
        <label for="customer_email" class="ad-caption-strong">E-mail</label>
        <input type="email" id="customer_email" name="customer[email]" required autocomplete="email" class="ad-input">
      </div>

      <div class="ad-field">
        <label for="customer_password" class="ad-caption-strong">Senha</label>
        <input type="password" id="customer_password" name="customer[password]" required autocomplete="current-password" class="ad-input">
      </div>

      <button type="submit" class="ad-btn ad-btn--primary ad-btn--store-hero" style="width:100%">Entrar</button>
    {%- endform -%}

    {%- comment -%} RECOVER FORM {%- endcomment -%}
    <details class="ad-recover">
      <summary class="ad-body-strong ad-recover-summary">Esqueci minha senha</summary>
      <div class="ad-recover-body">
        {%- form 'recover_customer_password', novalidate: 'novalidate' -%}
          {%- if form.posted_successfully? -%}
            <p class="ad-body ad-recover-success">Verifique seu e-mail.</p>
          {%- else -%}
            {%- if form.errors -%}
              <ul class="ad-login-errors">
                {%- for field in form.errors -%}
                  <li class="ad-caption">{{ form.errors.messages[field] }}</li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
            <div class="ad-field">
              <label for="recover_email" class="ad-caption-strong">E-mail</label>
              <input type="email" id="recover_email" name="email" required autocomplete="email" class="ad-input">
            </div>
            {% render 'apple-button', variant: 'secondary-pill', label: 'Enviar instruções', type: 'submit' %}
          {%- endif -%}
        {%- endform -%}
      </div>
    </details>

    <div class="ad-login-foot">
      <p class="ad-caption-strong ad-login-foot-text">
        Não tem conta? <a href="{{ routes.account_register_url }}" class="ad-text-link">Criar uma</a>
      </p>
    </div>
  </div>
</section>

<style>
  .ad-login-section {
    padding: var(--ad-space-xxl) var(--ad-space-lg);
    background: var(--ad-canvas);
  }
  .ad-login-wrap {
    max-width: 480px;
    margin: 0 auto;
  }
  .ad-login-header {
    text-align: left;
    margin-bottom: var(--ad-space-xl);
  }
  .ad-login-sub {
    color: var(--ad-ink-muted-80);
    margin-top: 4px;
  }
  .ad-login-errors {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--ad-space-md) 0;
  }
  .ad-login-errors li {
    color: var(--ad-primary);
    margin-bottom: 4px;
  }
  .ad-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: var(--ad-space-md);
  }
  .ad-input {
    height: 44px;
    border: 1px solid var(--ad-hairline);
    border-radius: var(--ad-radius-sm);
    padding: 12px 14px;
    font: inherit;
    color: var(--ad-ink);
    background: var(--ad-canvas);
    transition: border-color 120ms ease, outline-color 120ms ease;
    width: 100%;
    box-sizing: border-box;
  }
  .ad-input:focus {
    outline: 2px solid var(--ad-primary-focus);
    outline-offset: 2px;
    border-color: var(--ad-primary-focus);
  }
  .ad-recover {
    margin-top: var(--ad-space-lg);
    border-top: 1px solid var(--ad-hairline);
    padding-top: var(--ad-space-lg);
  }
  .ad-recover-summary {
    cursor: pointer;
    list-style: none;
    color: var(--ad-ink);
    user-select: none;
  }
  .ad-recover-summary::-webkit-details-marker { display: none; }
  .ad-recover-summary::marker { content: ''; }
  .ad-recover-body {
    margin-top: var(--ad-space-md);
  }
  .ad-recover-success {
    color: var(--ad-primary);
  }
  .ad-login-foot {
    margin-top: var(--ad-space-lg);
    padding-top: var(--ad-space-lg);
    border-top: 1px solid var(--ad-hairline);
    text-align: center;
  }
  .ad-login-foot-text {
    color: var(--ad-ink-muted-80);
  }
  .ad-text-link {
    color: var(--ad-primary);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
  }
  .ad-text-link:hover { color: var(--ad-primary-focus); }
  @media (max-width: 600px) {
    .ad-login-wrap { max-width: 100%; }
  }
</style>

{% schema %}
{
  "name": "Login",
  "settings": []
}
{% endschema %}
