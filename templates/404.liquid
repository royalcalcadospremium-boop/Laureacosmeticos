{%- comment -%}
  Apple-pure 404 page (Subsistema 6).
  Full-bleed parchment tile with centered stack.
{%- endcomment -%}

<section class="ad-tile ad-tile--parchment ad-404">
  <div class="ad-404__inner">
    <p class="ad-caption-strong ad-404__eyebrow">ERRO 404</p>
    <h1 class="ad-hero-display ad-404__title">Página não encontrada.</h1>
    <p class="ad-lead ad-404__lead">A página que você procura não existe ou foi movida. Tente uma busca abaixo.</p>

    <form class="ad-404__search" action="{{ routes.search_url }}" method="get" role="search">
      <input type="hidden" name="type" value="product">
      <input type="search" name="q" class="ad-404__search-input" placeholder="Buscar produtos…" autocomplete="off" aria-label="Buscar">
      <button type="submit" class="ad-btn ad-btn--primary">Buscar</button>
    </form>

    <a class="ad-btn ad-btn--text-link ad-404__home" href="{{ routes.root_url }}">‹ Voltar para o início</a>
  </div>
</section>

<style>
  .ad-404 { min-height: 60vh; display: flex; align-items: center; }
  .ad-404__inner {
    max-width: 720px;
    margin: 0 auto;
    padding: var(--ad-space-xxl) var(--ad-space-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--ad-space-md);
    text-align: center;
  }
  .ad-404__eyebrow {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--ad-color-ink-muted-48);
  }
  .ad-404__title { margin: 0; }
  .ad-404__lead { margin: 0; color: var(--ad-color-ink-muted-80); }
  .ad-404__search {
    width: 100%;
    max-width: 480px;
    display: flex;
    gap: var(--ad-space-sm);
    margin-top: var(--ad-space-md);
  }
  .ad-404__search-input {
    flex: 1;
    padding: 12px 20px;
    height: 44px;
    background: var(--ad-color-canvas);
    border: 1px solid var(--ad-color-hairline);
    border-radius: var(--ad-radius-pill);
    font-size: var(--ad-type-body-size);
    font-family: var(--ad-font-text);
    color: var(--ad-color-ink);
  }
  .ad-404__search-input:focus-visible {
    outline: 2px solid var(--ad-color-primary-focus);
    outline-offset: 2px;
    border-color: var(--ad-color-primary-focus);
  }
  .ad-404__home { margin-top: var(--ad-space-md); }
  @media (max-width: 480px) {
    .ad-404__title { font-size: 34px; line-height: 1.1; }
    .ad-404__search { flex-direction: column; }
  }
</style>
