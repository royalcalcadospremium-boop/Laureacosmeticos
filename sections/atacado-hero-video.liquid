{%- comment -%}
  atacado-hero-video.liquid — Hero da Landing Page /pages/atacado.
  Renderiza o snippet reusável `lp-hero-video` com vídeo em background,
  badge de prova social, headline H1 e dois CTAs (catálogo + WhatsApp).

  Assets foundation (lp-shared.css / lp-shared.js) são carregados aqui
  pois esta section é sempre a primeira da página. Outras sections da
  LP também carregam (idempotente — o browser deduplica por URL).
{%- endcomment -%}

{{ 'lp-shared.css' | asset_url | stylesheet_tag }}
<script src="{{ 'lp-shared.js' | asset_url }}" defer></script>

{%- assign _video_url = section.settings.video_url -%}

{%- if section.settings.poster_image != blank -%}
  {%- assign _poster_url = section.settings.poster_image | img_url: '1920x' -%}
{%- else -%}
  {%- assign _poster_url = '' -%}
{%- endif -%}

{%- render 'lp-hero-video',
    video_url: _video_url,
    poster_url: _poster_url,
    overlay: section.settings.overlay,
    badge: section.settings.badge,
    eyebrow: section.settings.eyebrow,
    title: section.settings.title,
    subtitle: section.settings.subtitle,
    cta1_label: section.settings.cta1_label,
    cta1_url: section.settings.cta1_url,
    cta2_label: section.settings.cta2_label,
    cta2_url: section.settings.cta2_url,
    cta2_variant: 'whatsapp'
-%}

{% schema %}
{
  "name": "Atacado · Hero",
  "tag": "section",
  "class": "lp-section-wrap lp-section-wrap--hero",
  "enabled_on": { "templates": ["page"] },
  "settings": [
    { "type": "header", "content": "Vídeo de fundo" },
    { "type": "text", "id": "video_url", "label": "URL do vídeo (mp4)", "info": "Use este OU o arquivo abaixo. Suporta Shopify Files / CDN externo." },
    { "type": "image_picker", "id": "poster_image", "label": "Imagem poster (fallback)" },
    { "type": "range", "id": "overlay", "label": "Overlay escuro (%)", "min": 0, "max": 100, "step": 5, "default": 55 },

    { "type": "header", "content": "Conteúdo" },
    { "type": "text", "id": "badge", "label": "Badge de prova social", "default": "+500 lojistas atendidos no Brasil" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow (opcional)" },
    { "type": "text", "id": "title", "label": "Título (H1)", "default": "Compre no Atacado e Multiplique sua Margem" },
    { "type": "textarea", "id": "subtitle", "label": "Subtítulo", "default": "Sem mínimo por marca. CNPJ ou CPF. Entrega rápida com NF." },

    { "type": "header", "content": "CTA primário" },
    { "type": "text", "id": "cta1_label", "label": "Texto", "default": "Ver Catálogo Atacado" },
    { "type": "text", "id": "cta1_url", "label": "URL", "default": "/collections/all" },

    { "type": "header", "content": "CTA secundário (WhatsApp)" },
    { "type": "text", "id": "cta2_label", "label": "Texto", "default": "Falar no WhatsApp" },
    { "type": "text", "id": "cta2_url", "label": "URL", "default": "https://wa.me/5500000000000?text=Quero%20comprar%20no%20atacado" }
  ],
  "presets": [
    { "name": "Atacado · Hero" }
  ]
}
{% endschema %}
