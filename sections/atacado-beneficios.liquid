{%- comment -%}
  atacado-beneficios.liquid — 6 cards (3x2 desktop / 2col tablet / 1col mobile).
  Background parchment pra separar visualmente da section anterior.
{%- endcomment -%}

{{ 'lp-shared.css' | asset_url | stylesheet_tag }}
<script src="{{ 'lp-shared.js' | asset_url }}" defer></script>

<section class="lp-section lp-section--parchment" aria-labelledby="atacado-beneficios-title">
  <div class="lp-section__inner">
    <header class="lp-section__head lp-reveal">
      {%- if section.settings.eyebrow != blank -%}
        <p class="lp-section__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 id="atacado-beneficios-title" class="lp-section__title">{{ section.settings.section_title }}</h2>
      {%- if section.settings.section_lead != blank -%}
        <p class="lp-section__lead">{{ section.settings.section_lead }}</p>
      {%- endif -%}
    </header>

    {%- if section.blocks.size > 0 -%}
      <div class="lp-cards" role="list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'benefit' -%}
            <article class="lp-card lp-reveal" role="listitem" {{ block.shopify_attributes }}>
              {%- if block.settings.icon_svg != blank -%}
                <span class="lp-card__icon" aria-hidden="true">{{ block.settings.icon_svg }}</span>
              {%- endif -%}
              <h3 class="lp-card__title">{{ block.settings.title }}</h3>
              <p class="lp-card__text">{{ block.settings.text }}</p>
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Atacado · Benefícios",
  "tag": "section",
  "class": "lp-section-wrap lp-section-wrap--benefits",
  "enabled_on": { "templates": ["page"] },
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "POR QUE A ROYAL" },
    { "type": "text", "id": "section_title", "label": "Título da seção", "default": "Vantagens pra quem revende" },
    { "type": "textarea", "id": "section_lead", "label": "Subtítulo", "default": "Tudo que você precisa pra escalar sua loja com segurança." }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefício",
      "settings": [
        { "type": "textarea", "id": "icon_svg", "label": "SVG do ícone (inline)", "info": "Cole o markup SVG. Recomendado: stroke=\"currentColor\" 1.5px, 48x48 viewBox." },
        { "type": "text", "id": "title", "label": "Título" },
        { "type": "textarea", "id": "text", "label": "Descrição" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Atacado · Benefícios",
      "blocks": [
        {
