{%- capture section_settings -%}
{
  "navigationLayout": {{ section.settings.desktop_navigation_layout | json }},
  "desktopOpenTrigger": {{ section.settings.desktop_navigation_open_trigger | json }},
  "useStickyHeader": {{ section.settings.enable_sticky_header | json }}
}
{%- endcapture -%}

{%- assign navigation_menu_handle = section.settings.navigation_menu | default: 'main-menu' -%}
{%- assign navigation_menu = linklists[navigation_menu_handle] -%}

<section data-section-id="{{ section.id }}" data-section-type="header" data-section-settings='{{ section_settings }}'>

  {%- if section.settings.barraimg_top -%}
  <section style="background: {{ section.settings.bgimg }};">
    <div class="img-topbar topbar-flex container" style="padding: 0;">
      <a class="d-none imgdopc" href="{{ section.settings.linkimg }}">
        <img src="{{ section.settings.imgpc | img_url: '1000x' }}" class="img-responsive-pc" alt="">
      </a>

      <a class="d-none imgdomob" href="{{ section.settings.linkimg }}">
        <img src="{{ section.settings.imgmob | img_url: '1000x' }}" class="img-responsive-mob" alt="">
      </a>
    </div>
  </section>
  {%- endif -%}

  <header class="header header--gummy" role="banner">
    <div class="container">
      <div class="header__inner header__inner--gummy">

        {%- comment -%} MOBILE NAV {%- endcomment -%}
        {%- if navigation_menu.links.size > 0 -%}
          <nav class="header__mobile-nav hidden-lap-and-up" aria-label="Menu mobile">
            <button class="header__mobile-nav-toggle icon-state touch-area"
              data-action="toggle-menu"
              aria-expanded="false"
              aria-haspopup="true"
              aria-controls="mobile-menu"
              aria-label="{{ 'header.navigation.open_menu' | t }}">
              <span class="icon-state__primary">{%- render 'icon', icon: 'hamburger-mobile' -%}</span>
              <span class="icon-state__secondary">{%- render 'icon', icon: 'close' -%}</span>
            </button>

            {%- render 'mobile-menu', menu: navigation_menu -%}
          </nav>
        {%- endif -%}

        {%- comment -%} LOGO {%- endcomment -%}
        {%- capture header_logo -%}
          <a href="{{ routes.root_url }}" class="header__logo-link">
            {%- if section.settings.logo != blank -%}
              {%- capture image_size -%}{{ section.settings.logo_max_width }}x{%- endcapture -%}
              <img class="header__logo-image header__logo-image--gummy"
                   style="max-width: {{ section.settings.logo_max_width }}px"
                   width="{{ section.settings.logo.width }}"
                   height="{{ section.settings.logo.height }}"
                   src="{{ section.settings.logo | img_url: image_size, scale: 2 }}"
                   alt="{{ section.settings.logo.alt | default: shop.name | escape }}">
            {%- else -%}
              <span class="header__logo-text">{{ shop.name }}</span>
            {%- endif -%}
          </a>
        {%- endcapture -%}

        {%- if request.page_type == 'index' -%}
          <h1 class="header__logo header__logo--gummy">{{ header_logo }}</h1>
        {%- else -%}
          <div class="header__logo header__logo--gummy">{{ header_logo }}</div>
        {%- endif -%}

        {%- comment -%} DESKTOP MENU INLINE (visual gummy) {%- endcomment -%}
        {%- if navigation_menu.links.size > 0 -%}
          <nav class="gummy-nav hidden-pocket" aria-label="Menu principal">
            <ul class="gummy-nav__list" role="list">
              {%- for link in navigation_menu.links -%}
                <li class="gummy-nav__item">
                  {%- if link.links.size == 0 -%}
                    <a class="gummy-nav__link" href="{{ link.url }}">{{ link.title }}</a>
                  {%- else -%}
                    <a class="gummy-nav__link" href="{{ link.url }}" aria-haspopup="true" aria-expanded="false">
                      {{ link.title }}
                      {%- render 'icon', icon: 'arrow-bottom' -%}
                    </a>
                    {%- capture index -%}desktop-menu-gummy-{{ forloop.index }}{%- endcapture -%}
                    {%- render 'desktop-menu', menu: link, index: index -%}
                  {%- endif -%}
                </li>
              {%- endfor -%}
            </ul>
          </nav>
        {%- endif -%}

        <div class="header__spacer"></div>

        {%- comment -%} ACTIONS (ícones à direita) {%- endcomment -%}
        <div class="header__action-list header__action-list--gummy">

          {%- comment -%} Search {%- endcomment -%}
          <div class="header__action-item">
            <a class="header__action-item-link header__icon-btn" href="{{ routes.search_url }}" aria-label="Buscar">
              <svg class="gummy-ico" viewBox="0 0 24 24" aria-hidden="true">
                <circle cx="11" cy="11" r="7"></circle>
                <path d="M20 20l-3.5-3.5"></path>
              </svg>
            </a>
          </div>

          {%- comment -%} Bell / Notificações {%- endcomment -%}
          <div class="header__action-item">
            <a class="header__action-item-link header__icon-btn" href="/pages/notificacoes" aria-label="Notificações">
              <svg class="gummy-ico" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M18 8a6 6 0 10-12 0c0 7-3 7-3 7h18s-3 0-3-7"></path>
                <path d="M13.73 21a2 2 0 01-3.46 0"></path>
              </svg>
            </a>
          </div>

          {%- comment -%} Account (mantém popover do tema) {%- endcomment -%}
          {%- if shop.customer_accounts_enabled -%}
            <div class="header__action-item header__action-item--account">
              <div class="header__action-item-content">
                <a href="{% if customer %}/account{% else %}/account/login{% endif %}"
                  class="header__action-item-link header__account-icon icon-state header__icon-btn"
                  aria-label="{{ 'header.general.account' | t }}"
                  aria-controls="account-popover"
                  aria-expanded="false"
                  data-action="toggle-popover"
                  {% if customer %}data-follow-link="phone"{% endif %}>
                  <span class="icon-state__primary">
                    <svg class="gummy-ico" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M20 21a8 8 0 10-16 0"></path>
                      <circle cx="12" cy="8" r="4"></circle>
                    </svg>
                  </span>
                  <span class="icon-state__secondary">{%- render 'icon', icon: 'close' -%}</span>
                </a>

                <div id="account-popover" class="popover {% if customer %}popover--logged{% else %}popover--large popover--unlogged{% endif %}" aria-hidden="true">
                  {%- render 'icon', icon: 'nav-triangle-borderless' -%}

                  {%- if customer -%}
                    <div class="popover__inner popover__inner--no-padding">
                      <div class="popover__linklist">
                        <a class="popover__link-item" href="{{ routes.account_url }}">{{ 'customer.general.orders' | t }}</a>
                        <a class="popover__link-item" href="{{ routes.account_addresses_url }}">{{ 'customer.general.addresses' | t }}</a>
                        <a class="popover__link-item" href="{{ routes.account_logout_url }}" data-no-instant>{{ 'customer.general.logout' | t }}</a>
                      </div>
                    </div>
                  {%- else -%}
                    <div class="popover__panel-list">
                      <div id="header-login-panel" class="popover__panel popover__panel--default is-selected">
                        <div class="popover__inner">
                          {%- form 'customer_login', name: 'login', class: 'form', id: 'header_customer_login' -%}
                            <header class="popover__header">
                              <h2 class="popover__title heading">{{ 'customer.login.login' | t }}</h2>
                              <p class="popover__legend">{{ 'customer.login.description' | t }}</p>
                            </header>

                            <div class="form__input-wrapper form__input-wrapper--labelled">
                              <input type="email" id="login-customer[email]" class="form__field form__field--text" name="customer[email]" required="required">
                              <label for="login-customer[email]" class="form__floating-label">{{ 'customer.login.email' | t }}</label>
                            </div>

                            <div class="form__input-wrapper form__input-wrapper--labelled">
                              <input type="password" id="login-customer[password]" class="form__field form__field--text" name="customer[password]" required="required" autocomplete="current-password">
                              <label for="login-customer[password]" class="form__floating-label">{{ 'customer.login.password' | t }}</label>
                            </div>

                            <button type="submit" class="form__submit button button--primary button--full">{{ 'customer.login.submit' | t }}</button>
                          {%- endform -%}

                          <div class="popover__secondary-action">
                            <p>{{ 'customer.login.new_customer' | t }} <button data-action="show-popover-panel" aria-controls="header-register-panel" class="link link--accented">{{ 'customer.login.create_your_account' | t }}</button></p>
                            <p>{{ 'customer.login.lost_password' | t }} <button data-action="show-popover-panel" aria-controls="header-recover-panel" class="link link--accented">{{ 'customer.login.recover_password' | t }}</button></p>
                          </div>
                        </div>
                      </div>

                      <div id="header-recover-panel" class="popover__panel popover__panel--sliding">
                        <div class="popover__inner">
                          {%- form 'recover_customer_password', name: 'recover', class: 'form' -%}
                            <header class="popover__header">
                              <h2 class="popover__title heading">{{ 'customer.recover_password.recover_password' | t }}</h2>
                              <p class="popover__legend">{{ 'customer.recover_password.description' | t }}</p>
                            </header>

                            <div class="form__input-wrapper form__input-wrapper--labelled">
                              <input type="email" id="recover-customer[recover_email]" class="form__field form__field--text" name="email" required="required">
                              <label for="recover-customer[recover_email]" class="form__floating-label">{{ 'customer.recover_password.email' | t }}</label>
                            </div>

                            <button type="submit" class="form__submit button button--primary button--full">{{ 'customer.recover_password.submit' | t }}</button>
                          {%- endform -%}

                          <div class="popover__secondary-action">
                            <p>{{ 'customer.recover_password.remembered_your_password' | t }} <button data-action="show-popover-panel" aria-controls="header-login-panel" class="link link--accented">{{ 'customer.recover_password.back_to_login' | t }}</button></p>
                          </div>
                        </div>
                      </div>

                      <div id="header-register-panel" class="popover__panel popover__panel--sliding">
                        <div class="popover__inner">
                          {%- form 'create_customer', name: 'create', class: 'form' -%}
                            <header class="popover__header">
                              <h2 class="popover__title heading">{{ 'customer.register.create_account' | t }}</h2>
                              <p class="popover__legend">{{ 'customer.register.description' | t }}</p>
                            </header>

                            <div class="form__input-wrapper form__input-wrapper--labelled">
                              <input type="text" id="register-customer[first_name]" class="form__field form__field--text" name="customer[first_name]" required="required">
                              <label for="register-customer[first_name]" class="form__floating-label">{{ 'customer.register.first_name' | t }}</label>
                            </div>

                            <div class="form__input-wrapper form__input-wrapper--labelled">
                              <input type="text" id="register-customer[last_name]" class="form__field form__field--text" name="customer[last_name]" required="required">
                              <label for="register-customer[last_name]" class="form__floating-label">{{ 'customer.register.last_name' | t }}</label>
                            </div>

                            <div class="form__input-wrapper form__input-wrapper--labelled">
                              <input type="email" id="register-customer[email]" class="form__field form__field--text" name="customer[email]" required="required">
                              <label for="register-customer[email]" class="form__floating-label">{{ 'customer.register.email' | t }}</label>
                            </div>

                            <div class="form__input-wrapper form__input-wrapper--labelled">
                              <input type="password" id="register-customer[password]" class="form__field form__field--text" name="customer[password]" required="required" autocomplete="new-password">
                              <label for="register-customer[password]" class="form__floating-label">{{ 'customer.register.password' | t }}</label>
                            </div>

                            <button type="submit" class="form__submit button button--primary button--full">{{ 'customer.register.submit' | t }}</button>
                          {%- endform -%}

                          <div class="popover__secondary-action">
                            <p>{{ 'customer.register.already_have_account' | t }} <button data-action="show-popover-panel" aria-controls="header-login-panel" class="link link--accented">{{ 'customer.register.login' | t }}</button></p>
                          </div>
                        </div>
                      </div>
                    </div>
                  {% endif %}
                </div>
              </div>
            </div>
          {%- endif -%}

          {%- comment -%} Heart / Favoritos {%- endcomment -%}
          <div class="header__action-item">
            <a class="header__action-item-link header__icon-btn" href="/pages/favoritos" aria-label="Favoritos">
              <svg class="gummy-ico" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z"></path>
              </svg>
            </a>
          </div>

          {%- comment -%} Cart (badge) {%- endcomment -%}
          <div class="header__action-item header__action-item--cart">
            <a class="header__action-item-link header__cart-toggle header__icon-btn"
              href="{{ routes.cart_url }}"
              {% if settings.cart_type == 'drawer' and template != 'cart' %}aria-controls="mini-cart" aria-expanded="false" data-action="toggle-mini-cart"{% endif %}
              data-no-instant
              aria-label="Carrinho">
              <div class="header__cart-icon icon-state" aria-expanded="false">
                <span class="icon-state__primary">
                  <svg class="gummy-ico" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M6 6h15l-1.5 8.5a2 2 0 0 1-2 1.5H8.2a2 2 0 0 1-2-1.7L4.7 3.5A1.5 1.5 0 0 0 3.2 2H2"></path>
                    <circle cx="9" cy="20" r="1.6"></circle>
                    <circle cx="18" cy="20" r="1.6"></circle>
                  </svg>
                  <span class="header__cart-count">{{ cart.item_count }}</span>
                </span>
                <span class="icon-state__secondary">{%- render 'icon', icon: 'close' -%}</span>
              </div>
            </a>

            {%- if settings.cart_type == 'drawer' and template != 'cart' -%}
              {%- render 'mini-cart' -%}
            {%- endif -%}
          </div>

        </div>

      </div>
    </div>
  </header>

  {%- if section.settings.barraimg_bottom -%}
  <section style="background: {{ section.settings.bgimg }};">
    <div class="img-topbar topbar-flex container" style="padding: 0;">
      <a class="d-none imgdopc" href="{{ section.settings.linkimg }}">
        <img src="{{ section.settings.imgpc | img_url: '1000x' }}" class="img-responsive-pc" alt="">
      </a>

      <a class="d-none imgdomob" href="{{ section.settings.linkimg }}">
        <img src="{{ section.settings.imgmob | img_url: '1000x' }}" class="img-responsive-mob" alt="">
      </a>
    </div>
  </section>
  {%- endif -%}

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700&display=swap');

    :root{
      --gummy-pink: #ff0080;
      --gummy-black: #111111;
      --gummy-text: #1b1b1b;
      --gummy-shadow: rgba(0,0,0,.05);

      --header-is-sticky: {% if section.settings.enable_sticky_header %}1{% else %}0{% endif %};
      --header-inline-navigation: 1;
    }

    #shopify-section-{{ section.id }}{
      position: relative;
      z-index: 50;
      {%- if section.settings.enable_sticky_header -%}
        position: -webkit-sticky;
        position: sticky;
        top: 0;
        z-index: 1000;
      {%- endif -%}
    }

    /* HEADER VISUAL GUMMY (sem topbar rosa aqui) */
    .header--gummy{
      background: #fff;
      border: 0 !important;
      padding: 10px 0;
      box-shadow: 0 2px 10px var(--gummy-shadow);
      font-family: 'Montserrat', sans-serif;
    }

    .header__inner--gummy{
      display:flex;
      align-items:center;
      gap: 18px;
      min-height: 64px;
    }

    .header__logo--gummy{ margin:0; }
    .header__logo-image--gummy{ display:block; height:auto; }

    .header__spacer{ flex: 1 1 auto; min-width: 10px; }

    /* Menu inline */
    .gummy-nav{ flex: 0 1 auto; min-width: 0; }
    .gummy-nav__list{
      display:flex;
      align-items:center;
      gap: 26px;
      list-style:none;
      margin:0;
      padding:0;
      white-space: nowrap;
      min-width: 0;
    }

    .gummy-nav__link{
      display:inline-flex;
      align-items:center;
      font-weight: 600;
      font-size: 13px;
      letter-spacing: .2px;
      color: var(--gummy-text);
      text-decoration:none;
      padding: 10px 0;
      line-height:1;
      text-transform: uppercase;
      transition: color .2s ease;
    }
    .gummy-nav__link:hover{
      color: var(--gummy-pink);
    }

    /* Ajuste para 1366 */
    @media (max-width: 1366px){
      .gummy-nav__list{ gap: 20px; }
      .gummy-nav__link{ font-size: 12.5px; }
    }

    /* Ações (ícones) */
    .header__action-list--gummy{
      display:flex;
      align-items:center;
      gap: 14px;
      flex: 0 0 auto;
    }

    .header__icon-btn{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      width: 36px;
      height: 36px;
      border-radius: 999px;
      color: var(--gummy-black);
      text-decoration:none;
      transition: background .2s ease, color .2s ease;
    }
    .header__icon-btn:hover{
      background: rgba(255,0,128,.08);
      color: var(--gummy-pink);
    }

    /* Ícones outline */
    .gummy-ico{
      width: 22px;
      height: 22px;
      display:block;
      fill: none !important;
      stroke: currentColor !important;
      stroke-width: 1.7;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    /* Badge do carrinho */
    .header__cart-icon .icon-state__primary{
      position:relative;
      display:inline-flex;
      align-items:center;
      justify-content:center;
    }
    .header__cart-count{
      position:absolute;
      top:-6px;
      right:-6px;
      background: var(--gummy-pink);
      color:#fff;
      font-size: 10px;
      font-weight: 700;
      line-height: 16px;
      min-width: 16px;
      height: 16px;
      border-radius: 999px;
      text-align:center;
      padding: 0 4px;
      box-shadow: 0 0 0 2px #fff;
    }

    /* Esconder search bar grande (se existir) */
    .header__search-bar-wrapper{ display:none !important; }

    /* Remover textos extras */
    .header__action-item-title,
    .hidden-pocket.hidden-lap{ display:none !important; }

    /* Topbar imagens */
    .img-topbar{ justify-content:center!important; }
    .topbar-flex{ display:flex!important; }
    .img-responsive-mob{ width: {{ section.settings.imgmob_max_width }}%; height:auto; }
    .img-responsive-pc{ width: {{ section.settings.imgpc_max_width }}%; height:auto; }

    @media screen and (max-width: 640px){
      .imgdopc{ display:none; }
    }
    @media screen and (min-width: 641px){
      .imgdomob{ display:none; }
    }

    /* Responsivo: esconde menu inline e mantém hamburger do tema */
    @media (max-width: 1024px){
      .gummy-nav{ display:none !important; }
      .header__inner--gummy{ gap: 12px; }
      .header__icon-btn{ width: 34px; height: 34px; }
      .gummy-ico{ width: 22px; height: 22px; }
    }
  </style>

  <script>
    (function(){
      var root = document.getElementById('shopify-section-{{ section.id }}');
      if(!root) return;
      document.documentElement.style.setProperty('--header-height', root.clientHeight + 'px');
    })();
  </script>

  {%- if section.settings.mostrar_barra -%}
    <div class="container-fluid color-line" style="
      background: linear-gradient(to right, {{ section.settings.background1 }}, {{ section.settings.background2 }}, {{ section.settings.background3 }}, {{ section.settings.background4 }});
      height: 6px;
      width: 100%;">
    </div>
  {%- endif -%}

{% schema %}
{
  "name": "Cabeçalho",
  "class": "shopify-section__header",
  "settings": [
    { "type": "checkbox", "id": "enable_sticky_header", "label": "Ativar cabeçalho fixo", "default": true },
    { "type": "text", "id": "rastreiopage", "label": "URL do rastreio", "default": "rastrear-pedido" },

    { "type": "header", "content": "Logo" },
    { "type": "image_picker", "id": "logo", "label": "Image", "info": "200 x 60px .png recommended" },
    { "type": "range", "id": "logo_max_width", "min": 50, "max": 300, "step": 5, "unit": "px", "label": "Tamanho no Desktop", "default": 140 },
    { "type": "range", "id": "mobile_logo_max_width", "min": 50, "max": 170, "step": 5, "unit": "px", "label": "Tamanho no Mobile", "default": 100 },

    { "type": "header", "content": "Imagem" },
    { "type": "checkbox", "id": "barraimg_top", "label": "Acima do cabeçalho", "default": false },
    { "type": "checkbox", "id": "barraimg_bottom", "label": "Abaixo do cabeçalho", "default": false },
    { "type": "color", "id": "bgimg", "label": "Cor de fundo", "default": "#1e2d7d" },
    { "type": "image_picker", "id": "imgpc", "label": "Imagem Desktop" },
    { "type": "range", "id": "imgpc_max_width", "min": 5, "max": 100, "step": 5, "unit": "%", "label": "Tamanho no Desktop", "default": 100 },
    { "type": "image_picker", "id": "imgmob", "label": "Imagem Mobile" },
    { "type": "range", "id": "imgmob_max_width", "min": 5, "max": 100, "step": 5, "unit": "%", "label": "Tamanho no Mobile", "default": 100 },
    { "type": "text", "id": "linkimg", "label": "URL de redirecionamento", "default": "https://dropmeta.com.br/tema", "info": "Coloque aqui o link de alguma coleção de oferta ou até mesmo um produto" },

    { "type": "header", "content": "Barra colorida" },
    { "type": "checkbox", "id": "mostrar_barra", "label": "Mostrar barra", "default": true },
    { "type": "color", "id": "background1", "label": "Cor 1", "default": "#00FF48" },
    { "type": "color", "id": "background2", "label": "Cor 2", "default": "#01C6FF" },
    { "type": "color", "id": "background3", "label": "Cor 3", "default": "#FFA000" },
    { "type": "color", "id": "background4", "label": "Cor 4", "default": "#C100BE" },

    { "type": "header", "content": "Navigation" },
    { "type": "link_list", "id": "navigation_menu", "label": "Menu", "default": "main-menu" },

    { "type": "select", "id": "desktop_navigation_layout", "label": "Desktop layout",
      "options": [
        { "value": "condensed", "label": "Condensed" },
        { "value": "inline", "label": "Inline" }
      ],
      "default": "inline"
    },

    { "type": "select", "id": "desktop_navigation_open_trigger", "label": "Open dropdown on...",
      "options": [
        { "value": "hover", "label": "Hover" },
        { "value": "click", "label": "Click" }
      ],
      "default": "hover"
    },

    { "type": "header", "content": "Mobile navigation" },
    { "type": "checkbox", "id": "show_navigation_social_media", "label": "Show social media", "default": true },
    { "type": "text", "id": "navigation_phone_number", "label": "Phone number text", "default": "Call us 000-000-0000" },
    { "type": "text", "id": "navigation_email", "label": "Email", "default": "info@yourwebsite.com" },

    { "type": "header", "content": "Search" },
