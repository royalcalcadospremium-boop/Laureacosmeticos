{%- comment -%}
  Apple-pure header (Subsistema 1).
  Two-tier nav: 64px black global-nav + 52px frosted-parchment sub-nav.
  Mobile collapses to hamburger + centered logo + bag.
  Drawer mobile: layout rico (countdown, categorias, rastrear, promos, ações, menu, produto destaque).
{%- endcomment -%}

{%- assign navigation_menu_handle = section.settings.navigation_menu | default: 'main-menu' -%}
{%- assign navigation_menu = linklists[navigation_menu_handle] -%}

<header class="ad-header" data-section-id="{{ section.id }}" data-section-type="header" role="banner">

  {%- comment -%} ────────── GLOBAL NAV (64px black) ────────── {%- endcomment -%}
  <nav class="ad-global-nav" aria-label="Navegação principal">
    <div class="ad-global-nav__inner">

      <button class="ad-global-nav__hamburger" type="button" aria-expanded="false" aria-controls="ad-mobile-drawer" aria-label="Abrir menu">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" aria-hidden="true">
          <path d="M1 4h14M1 8h14M1 12h14"/>
        </svg>
      </button>

      <a class="ad-global-nav__logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | img_url: '400x' }}" alt="{{ shop.name | escape }}" width="180" height="36" loading="eager" decoding="async">
        {%- else -%}
          <span class="ad-nav-link">{{ shop.name }}</span>
        {%- endif -%}
      </a>

      <ul class="ad-global-nav__links">
        {%- for link in navigation_menu.links limit: 8 -%}
          <li><a class="ad-nav-link" href="{{ link.url }}">{{ link.title }}</a></li>
        {%- endfor -%}
      </ul>

      <div class="ad-global-nav__utils">
        <a class="ad-global-nav__icon" href="{{ routes.search_url }}" aria-label="Buscar">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <circle cx="8" cy="8" r="5.5"/><path d="m12 12 4 4"/>
          </svg>
        </a>
        <a class="ad-global-nav__icon" href="{{ routes.account_url }}" aria-label="Minha conta">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <circle cx="9" cy="6" r="3"/><path d="M3 16c0-3 2.7-5 6-5s6 2 6 5"/>
          </svg>
        </a>
        <a class="ad-global-nav__icon ad-global-nav__bag" href="{{ routes.cart_url }}" aria-label="Carrinho com {{ cart.item_count }} itens">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M3 6h12l-1 9H4z"/><path d="M6 6V4a3 3 0 0 1 6 0v2"/>
          </svg>
          {%- if cart.item_count > 0 -%}
            <span class="ad-global-nav__bag-count" aria-hidden="true">{{ cart.item_count }}</span>
          {%- endif -%}
        </a>
      </div>

    </div>
  </nav>

  {%- comment -%} ────────── MOBILE DRAWER ────────── {%- endcomment -%}
  <aside id="ad-mobile-drawer" class="ad-mobile-drawer" hidden aria-modal="true" role="dialog" aria-label="Menu de navegação">

    {%- comment -%} (1) HEAD {%- endcomment -%}
    <div class="ad-mobile-drawer__head">
      <a class="ad-mobile-drawer__logo" href="{{ routes.root_url }}">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | img_url: '400x' }}" alt="{{ shop.name | escape }}" width="160" height="32">
        {%- else -%}
          <span class="ad-tagline">{{ shop.name }}</span>
        {%- endif -%}
      </a>
      <button class="ad-mobile-drawer__close" type="button" aria-label="Fechar menu">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
          <path d="M3 3l12 12M15 3L3 15"/>
        </svg>
      </button>
    </div>

    <div class="ad-mobile-drawer__body">

      {%- comment -%} (2) COUNTDOWN BANNER {%- endcomment -%}
      {%- if section.settings.drawer_countdown_enabled and section.settings.drawer_countdown_text != blank -%}
        <div class="ad-drawer-countdown">
          <span class="ad-caption-strong">{{ section.settings.drawer_countdown_text }}</span>
          <span class="ad-drawer-countdown__timer" data-end="{{ section.settings.drawer_countdown_end }}">--:--:--</span>
        </div>
      {%- endif -%}

      {%- comment -%} (3) CATEGORY CARDS ROW {%- endcomment -%}
      {%- assign has_categories = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'category_card' -%}{%- assign has_categories = true -%}{%- break -%}{%- endif -%}
      {%- endfor -%}
      {%- if has_categories -%}
        <nav class="ad-drawer-categories" aria-label="Categorias">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'category_card' -%}
                <a class="ad-drawer-cat" href="{{ block.settings.url | default: '#' }}" {{ block.shopify_attributes }}>
                  <span class="ad-drawer-cat__image">
                    {%- if block.settings.image != blank -%}
                      <img src="{{ block.settings.image | img_url: '120x120', crop: 'center' }}" alt="" loading="lazy" width="64" height="64">
                    {%- endif -%}
                  </span>
                  <span class="ad-drawer-cat__label ad-caption">{{ block.settings.label }}</span>
                </a>
            {%- endcase -%}
          {%- endfor -%}
        </nav>
      {%- endif -%}

      {%- comment -%} (4) TRACK ORDER CTA {%- endcomment -%}
      {%- if section.settings.drawer_track_url != blank and section.settings.drawer_track_text != blank -%}
        <a class="ad-button ad-button--primary ad-drawer-track" href="{{ section.settings.drawer_track_url }}">
          <svg width="16" height="16" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M2 6h11l3 3v4h-2"/><circle cx="6" cy="14" r="2"/><circle cx="14" cy="14" r="2"/>
          </svg>
          {{ section.settings.drawer_track_text }}
        </a>
      {%- endif -%}

      {%- comment -%} (5) PROMO BANNER CARDS {%- endcomment -%}
      {%- assign has_promos = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'promo_card' -%}{%- assign has_promos = true -%}{%- break -%}{%- endif -%}
      {%- endfor -%}
      {%- if has_promos -%}
        <div class="ad-drawer-promos">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'promo_card' -%}
                <a class="ad-drawer-promo" href="{{ block.settings.url | default: '#' }}" {{ block.shopify_attributes }}>
                  {%- if block.settings.image != blank -%}
                    <img src="{{ block.settings.image | img_url: '600x' }}" alt="" loading="lazy">
                  {%- endif -%}
                  <div class="ad-drawer-promo__overlay">
                    {%- if block.settings.heading != blank -%}
                      <p class="ad-display-sm">{{ block.settings.heading }}</p>
                    {%- endif -%}
                    {%- if block.settings.cta_text != blank -%}
                      <span class="ad-caption-strong">{{ block.settings.cta_text }} ›</span>
                    {%- endif -%}
                  </div>
                </a>
            {%- endcase -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment -%} (6) ACTION CTAs {%- endcomment -%}
      {%- assign has_actions = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'action_cta' -%}{%- assign has_actions = true -%}{%- break -%}{%- endif -%}
      {%- endfor -%}
      {%- if has_actions -%}
        <div class="ad-drawer-actions">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'action_cta' -%}
                <a class="ad-drawer-action" href="{{ block.settings.url | default: '#' }}" {{ block.shopify_attributes }}>
                  <span class="ad-drawer-action__emoji" aria-hidden="true">{{ block.settings.emoji }}</span>
                  <span class="ad-drawer-action__label ad-body">{{ block.settings.label }}</span>
                  <span class="ad-drawer-action__chevron" aria-hidden="true">›</span>
                </a>
            {%- endcase -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment -%} (7) MENU ITEMS LIST {%- endcomment -%}
      {%- if navigation_menu.links.size > 0 -%}
        <nav class="ad-drawer-menu" aria-label="Menu principal">
          {%- for link in navigation_menu.links -%}
            <a class="ad-drawer-menu-item" href="{{ link.url }}">
              <span class="ad-drawer-action__label ad-body">{{ link.title }}</span>
              <span class="ad-drawer-action__chevron" aria-hidden="true">›</span>
            </a>
          {%- endfor -%}
        </nav>
      {%- endif -%}

      {%- comment -%} (8) FEATURED PRODUCT CARD {%- endcomment -%}
      {%- if section.settings.drawer_featured_product != blank -%}
        {%- assign featured = all_products[section.settings.drawer_featured_product] -%}
        {%- if featured != blank and featured != empty -%}
          <a class="ad-drawer-featured" href="{{ featured.url }}">
            {%- if featured.featured_image != blank -%}
              <img src="{{ featured.featured_image | img_url: '300x300', crop: 'center' }}" alt="{{ featured.title | escape }}" loading="lazy" width="80" height="80">
            {%- endif -%}
            <div class="ad-drawer-featured__body">
              <p class="ad-caption">{{ section.settings.drawer_featured_eyebrow | default: 'Destaque' }}</p>
              <p class="ad-display-sm">{{ featured.title }}</p>
              <p class="ad-body-strong">{{ featured.price | money }}</p>
            </div>
          </a>
        {%- endif -%}
      {%- endif -%}

      {%- comment -%} (9) FOOT {%- endcomment -%}
      <div class="ad-mobile-drawer__foot">
        <a class="ad-button-utility" href="{{ routes.account_url }}">Minha conta</a>
        <a class="ad-button-utility" href="{{ routes.search_url }}">Buscar</a>
        <a class="ad-button-utility" href="{{ routes.cart_url }}">Carrinho ({{ cart.item_count }})</a>
      </div>

    </div>
  </aside>

</header>

<style>
  /* ── Global nav (64px black bar) ─────────────────────────────── */
  .ad-header { isolation: isolate; }
  .ad-global-nav {
    background-color: var(--ad-color-surface-black);
    color: var(--ad-color-on-dark);
    height: 64px;
    position: sticky; top: 0; z-index: 100;
  }
  .ad-global-nav__inner {
    display: flex;
    align-items: center;
    gap: var(--ad-space-md);
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 var(--ad-space-lg);
    height: 100%;
  }
  .ad-global-nav__hamburger {
    display: none;
    background: none; border: 0; color: inherit;
    padding: 8px; cursor: pointer;
    width: 32px; height: 32px;
    align-items: center; justify-content: center;
  }
  .ad-global-nav__logo {
    color: inherit; text-decoration: none;
    display: inline-flex; align-items: center;
  }
  .ad-global-nav__logo img {
    display: block; height: 36px; width: auto;
  }
  .ad-global-nav__links {
    list-style: none; margin: 0; padding: 0;
    display: flex; gap: var(--ad-space-xl);
    flex: 1; justify-content: center;
  }
  .ad-global-nav__links .ad-nav-link {
    color: inherit; text-decoration: none; opacity: 0.85;
    transition: opacity 120ms ease-out;
  }
  .ad-global-nav__links .ad-nav-link:hover,
  .ad-global-nav__links .ad-nav-link:focus-visible { opacity: 1; }
  .ad-global-nav__utils {
    display: flex; gap: var(--ad-space-md); align-items: center;
  }
  .ad-global-nav__icon {
    color: inherit; opacity: 0.85;
    display: inline-flex; align-items: center; justify-content: center;
    padding: 8px; min-width: 32px; min-height: 32px;
    position: relative; text-decoration: none;
    transition: opacity 120ms ease-out;
  }
  .ad-global-nav__icon:hover { opacity: 1; }
  .ad-global-nav__bag-count {
    position: absolute; top: 2px; right: 0;
    background: var(--ad-color-primary);
    color: var(--ad-color-on-primary);
    font-size: 9px; font-weight: 600;
    min-width: 16px; height: 16px; border-radius: 9999px;
    display: inline-flex; align-items: center; justify-content: center;
    padding: 0 4px; line-height: 1;
  }

  /* ── Sub-nav (52px frosted parchment) ─────────────────────────── */
  .ad-sub-nav {
    height: 52px;
    position: sticky; top: 64px; z-index: 99;
    color: var(--ad-color-ink);
  }
  .ad-sub-nav__inner {
    display: flex;
    align-items: center;
    gap: var(--ad-space-xl);
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 var(--ad-space-lg);
    height: 100%;
  }
  .ad-sub-nav__category {
    color: inherit; text-decoration: none;
  }
  .ad-sub-nav__links {
    list-style: none; margin: 0; padding: 0;
    display: flex; gap: var(--ad-space-lg);
    flex: 1;
  }
  .ad-sub-nav__links a {
    color: var(--ad-color-ink-muted-80);
    text-decoration: none;
  }
  .ad-sub-nav__links a:hover,
  .ad-sub-nav__links a:focus-visible {
    color: var(--ad-color-ink);
  }

  /* ── Mobile drawer (parchment, rich layout) ───────────────────── */
  .ad-mobile-drawer {
    position: fixed; inset: 0; z-index: 200;
    background-color: var(--ad-color-canvas-parchment);
    color: var(--ad-color-ink);
    overflow-y: auto;
    animation: ad-fade-in 220ms ease-out;
    display: flex; flex-direction: column;
  }
  .ad-mobile-drawer[hidden] { display: none; }
  @keyframes ad-fade-in { from { opacity: 0; } to { opacity: 1; } }
  @media (prefers-reduced-motion: reduce) {
    .ad-mobile-drawer { animation: none; }
  }

  .ad-mobile-drawer__head {
    display: flex; justify-content: space-between; align-items: center;
    padding: var(--ad-space-lg);
    border-bottom: var(--ad-border-soft, 1px solid rgba(0,0,0,0.08));
    background-color: var(--ad-color-canvas-parchment);
    position: sticky; top: 0; z-index: 2;
  }
  .ad-mobile-drawer__logo { color: inherit; text-decoration: none; display: inline-flex; align-items: center; }
  .ad-mobile-drawer__logo img { display: block; height: 32px; width: auto; }
  .ad-mobile-drawer__close {
    background: none; border: 0; color: inherit;
    padding: 8px; cursor: pointer;
    width: 32px; height: 32px;
    display: inline-flex; align-items: center; justify-content: center;
  }

  .ad-mobile-drawer__body {
    padding: var(--ad-space-lg);
    display: flex; flex-direction: column;
    gap: var(--ad-space-xl);
    flex: 1;
  }

  /* (2) Countdown banner */
  .ad-drawer-countdown {
    display: flex; align-items: center; justify-content: space-between;
    gap: var(--ad-space-sm);
    background-color: var(--ad-color-primary);
    color: var(--ad-color-on-primary, #fff);
    padding: var(--ad-space-sm) var(--ad-space-md);
    border-radius: var(--ad-radius-sm);
  }
  .ad-drawer-countdown__timer {
    font-variant-numeric: tabular-nums;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  /* (3) Category cards row */
  .ad-drawer-categories {
    display: flex;
    gap: var(--ad-space-md);
    overflow-x: auto;
    overflow-y: hidden;
    margin: 0 calc(var(--ad-space-lg) * -1);
    padding: 0 var(--ad-space-lg) var(--ad-space-xs);
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .ad-drawer-categories::-webkit-scrollbar { display: none; }
  .ad-drawer-cat {
    display: flex; flex-direction: column; align-items: center;
    gap: var(--ad-space-xs);
    text-decoration: none; color: var(--ad-color-ink);
    flex: 0 0 auto;
    scroll-snap-align: start;
    width: 72px;
  }
  .ad-drawer-cat__image {
    width: 64px; height: 64px;
    border-radius: 50%;
    overflow: hidden;
    background-color: var(--ad-color-canvas-fog, #f0f0f3);
    display: inline-flex; align-items: center; justify-content: center;
  }
  .ad-drawer-cat__image img {
    width: 100%; height: 100%; object-fit: cover;
    display: block;
  }
  .ad-drawer-cat__label {
    font-size: 12px;
    text-align: center;
    line-height: 1.2;
    color: var(--ad-color-ink);
  }

  /* (4) Track order CTA */
  .ad-drawer-track {
    display: inline-flex; align-items: center; justify-content: center;
    gap: var(--ad-space-xs);
    width: 100%;
    padding: var(--ad-space-md);
    background-color: var(--ad-color-primary);
    color: var(--ad-color-on-primary, #fff);
    border-radius: var(--ad-radius-pill);
    text-decoration: none;
    font-weight: 600;
    transition: filter 120ms ease-out;
  }
  .ad-drawer-track:hover { filter: brightness(1.08); }

  /* (5) Promo cards */
  .ad-drawer-promos {
    display: flex; flex-direction: column;
    gap: var(--ad-space-md);
  }
  .ad-drawer-promo {
    position: relative;
    display: block;
    aspect-ratio: 16 / 9;
    background-color: var(--ad-color-surface-tile-1);
    border-radius: var(--ad-radius-md);
    overflow: hidden;
    text-decoration: none;
    color: #fff;
  }
  .ad-drawer-promo img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  .ad-drawer-promo__overlay {
    position: absolute; inset: 0;
    padding: var(--ad-space-md);
    display: flex; flex-direction: column; justify-content: flex-end;
    gap: 4px;
    background: linear-gradient(180deg, transparent 40%, rgba(0,0,0,0.7));
    color: #fff;
  }
  .ad-drawer-promo__overlay p { margin: 0; color: inherit; }
  .ad-drawer-promo__overlay .ad-caption-strong { color: inherit; opacity: 0.9; }

  /* (6) Action CTAs and (7) Menu items list */
  .ad-drawer-actions,
  .ad-drawer-menu {
    display: flex; flex-direction: column;
  }
  .ad-drawer-action,
  .ad-drawer-menu-item {
    display: flex; align-items: center;
    gap: var(--ad-space-md);
    padding: var(--ad-space-md) 0;
    text-decoration: none;
    color: var(--ad-color-ink);
    border-bottom: var(--ad-border-soft, 1px solid rgba(0,0,0,0.08));
  }
  .ad-drawer-action:last-child,
  .ad-drawer-menu-item:last-child { border-bottom: 0; }
  .ad-drawer-action__emoji {
    font-size: 24px;
    line-height: 1;
    width: 24px;
    text-align: center;
    flex: 0 0 auto;
  }
  .ad-drawer-action__label {
    flex: 1;
    color: var(--ad-color-ink);
  }
  .ad-drawer-action__chevron {
    font-size: 18px;
    color: var(--ad-color-ink-muted-80);
    line-height: 1;
    flex: 0 0 auto;
  }

  /* (8) Featured product */
  .ad-drawer-featured {
    display: flex; align-items: center;
    gap: var(--ad-space-md);
    padding: var(--ad-space-md);
    background-color: var(--ad-color-canvas-parchment);
    border: var(--ad-border-soft, 1px solid rgba(0,0,0,0.08));
    border-radius: var(--ad-radius-md);
    text-decoration: none;
    color: var(--ad-color-ink);
  }
  .ad-drawer-featured img {
    width: 80px; height: 80px;
    object-fit: cover;
    border-radius: var(--ad-radius-sm);
    display: block;
    flex: 0 0 auto;
  }
  .ad-drawer-featured__body {
    flex: 1;
    display: flex; flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .ad-drawer-featured__body p { margin: 0; }
  .ad-drawer-featured__body .ad-caption {
    color: var(--ad-color-ink-muted-80);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .ad-drawer-featured__body .ad-display-sm {
    color: var(--ad-color-ink);
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .ad-drawer-featured__body .ad-body-strong {
    color: var(--ad-color-primary);
    font-weight: 600;
  }

  /* (9) Foot */
  .ad-mobile-drawer__foot {
    display: flex; flex-wrap: wrap;
    gap: var(--ad-space-sm);
    margin-top: auto;
    padding-top: var(--ad-space-lg);
    border-top: var(--ad-border-soft, 1px solid rgba(0,0,0,0.08));
  }
  .ad-mobile-drawer__foot .ad-button-utility {
    background-color: transparent;
    color: var(--ad-color-ink);
    border: 1px solid rgba(0,0,0,0.12);
  }

  /* ── Responsive ──────────────────────────────────────────────── */
  @media (max-width: 833px) {
    .ad-global-nav__hamburger { display: inline-flex; }
    .ad-global-nav__links { display: none; }
    .ad-global-nav__logo { flex: 1; justify-content: center; }
    .ad-global-nav__logo img { height: 28px; }
    .ad-sub-nav__links { display: none; }
    .ad-sub-nav__inner { gap: var(--ad-space-md); }
  }
</style>

<script>
(function () {
  var hamburger = document.querySelector('.ad-global-nav__hamburger');
  var drawer = document.getElementById('ad-mobile-drawer');
  if (!hamburger || !drawer) return;
  // Portal drawer to <body> so it escapes the header's stacking context (isolation: isolate).
  if (drawer.parentElement !== document.body) {
    document.body.appendChild(drawer);
  }
  var closer = drawer.querySelector('.ad-mobile-drawer__close');

  function openDrawer() {
    drawer.hidden = false;
    hamburger.setAttribute('aria-expanded', 'true');
    document.documentElement.style.overflow = 'hidden';
  }
  function closeDrawer() {
    drawer.hidden = true;
    hamburger.setAttribute('aria-expanded', 'false');
    document.documentElement.style.overflow = '';
  }

  hamburger.addEventListener('click', openDrawer);
  if (closer) closer.addEventListener('click', closeDrawer);
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && !drawer.hidden) closeDrawer();
  });
  drawer.addEventListener('click', function (e) {
    if (e.target.closest('a')) closeDrawer();
  });

  // Countdown banner ticker
  var cd = drawer.querySelector('.ad-drawer-countdown__timer');
  if (cd && cd.dataset.end) {
    var endTs = new Date(cd.dataset.end).getTime();
    if (!isNaN(endTs)) {
      var tick = function () {
        var diff = endTs - Date.now();
        if (diff <= 0) {
          var banner = cd.closest('.ad-drawer-countdown');
          if (banner) banner.style.display = 'none';
          return;
        }
        var h = Math.floor(diff / 3.6e6);
        var m = Math.floor((diff % 3.6e6) / 6e4);
        var s = Math.floor((diff % 6e4) / 1000);
        cd.textContent =
          String(h).padStart(2, '0') + ':' +
          String(m).padStart(2, '0') + ':' +
          String(s).padStart(2, '0');
      };
      tick();
      setInterval(tick, 1000);
    }
  }
})();
</script>

