{%- assign variant = section.settings.variant | default: 'light' -%}
{%- assign cols = section.settings.columns_desktop | default: 3 -%}
{%- assign bg = '#ffffff' -%}
{%- if variant == 'parchment' -%}{%- assign bg = 'var(--ad-canvas-parchment)' -%}{%- endif -%}

<section
  id="ad-team-{{ section.id }}"
  class="ad-team ad-team--{{ variant }}"
  style="--ad-grid-cols: {{ cols }}; background: {{ bg }};"
>
  <div class="ad-team__wrap">
    <header class="ad-team__header">
      <h1 class="ad-display-lg ad-team__title">{{ page.title }}</h1>
      {%- if page.content != blank -%}
        <div class="ad-lead-airy ad-team__intro">{{ page.content }}</div>
      {%- endif -%}
    </header>

    {%- if section.blocks.size > 0 -%}
      <div class="ad-team__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'member' -%}
            <article class="ad-team__card" {{ block.shopify_attributes }}>
              {%- if block.settings.photo != blank -%}
                <div class="ad-team__avatar">
                  <img
                    src="{{ block.settings.photo | img_url: '400x400', crop: 'center' }}"
                    alt="{{ block.settings.photo.alt | default: block.settings.name | escape }}"
                    loading="lazy"
                    width="200"
                    height="200"
                  >
                </div>
              {%- else -%}
                <div class="ad-team__avatar ad-team__avatar--placeholder" aria-hidden="true"></div>
              {%- endif -%}

              {%- if block.settings.name != blank -%}
                <p class="ad-body-strong ad-team__name">{{ block.settings.name | escape }}</p>
              {%- endif -%}

              {%- if block.settings.role != blank -%}
                <p class="ad-caption ad-team__role">{{ block.settings.role | escape }}</p>
              {%- endif -%}

              {%- if block.settings.bio != blank -%}
                <p class="ad-body ad-team__bio">{{ block.settings.bio | escape }}</p>
              {%- endif -%}

              {%- if block.settings.linkedin != blank or block.settings.instagram != blank or block.settings.twitter != blank -%}
                <div class="ad-team__social" role="list">
                  {%- if block.settings.linkedin != blank -%}
                    <a href="{{ block.settings.linkedin }}" class="ad-team__social-link" aria-label="LinkedIn" rel="noopener" target="_blank" role="listitem">
                      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <rect x="3" y="3" width="18" height="18" rx="3"/>
                        <path d="M8 10v7"/>
                        <circle cx="8" cy="7" r="0.6" fill="currentColor"/>
                        <path d="M12 17v-4a2.5 2.5 0 0 1 5 0v4"/>
                        <path d="M12 10v7"/>
                      </svg>
                    </a>
                  {%- endif -%}
                  {%- if block.settings.instagram != blank -%}
                    <a href="{{ block.settings.instagram }}" class="ad-team__social-link" aria-label="Instagram" rel="noopener" target="_blank" role="listitem">
                      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <rect x="3" y="3" width="18" height="18" rx="5"/>
                        <circle cx="12" cy="12" r="4"/>
                        <circle cx="17.2" cy="6.8" r="0.6" fill="currentColor"/>
                      </svg>
                    </a>
                  {%- endif -%}
                  {%- if block.settings.twitter != blank -%}
                    <a href="{{ block.settings.twitter }}" class="ad-team__social-link" aria-label="Twitter" rel="noopener" target="_blank" role="listitem">
                      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M4 4l7.5 9.5L4.4 20H7l5.8-5.6L17 20h3l-7.8-9.9L19.4 4H17l-5.3 5.1L8 4z"/>
                      </svg>
                    </a>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="ad-team__empty">
        <p class="ad-display-md">Conheça nossa equipe em breve.</p>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  #ad-team-{{ section.id }} .ad-team__wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--ad-space-xxl) var(--ad-space-lg);
  }
  #ad-team-{{ section.id }} .ad-team__header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto var(--ad-space-xl);
  }
  #ad-team-{{ section.id }} .ad-team__title {
    color: var(--ad-ink);
    margin: 0;
  }
  #ad-team-{{ section.id }} .ad-team__intro {
    margin-top: var(--ad-space-md);
    color: var(--ad-ink-muted-80);
  }
  #ad-team-{{ section.id }} .ad-team__grid {
    display: grid;
    grid-template-columns: repeat(var(--ad-grid-cols, 3), minmax(0, 1fr));
    gap: var(--ad-space-xl) var(--ad-space-lg);
  }
  #ad-team-{{ section.id }} .ad-team__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  #ad-team-{{ section.id }} .ad-team__avatar {
    width: 100%;
    max-width: 200px;
    aspect-ratio: 1 / 1;
    border-radius: var(--ad-radius-full);
    overflow: hidden;
    background: var(--ad-canvas-parchment);
  }
  #ad-team-{{ section.id }} .ad-team__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  #ad-team-{{ section.id }} .ad-team__avatar--placeholder {
    border: 1px solid var(--ad-hairline);
  }
  #ad-team-{{ section.id }} .ad-team__name {
    margin: var(--ad-space-md) 0 0;
    color: var(--ad-ink);
  }
  #ad-team-{{ section.id }} .ad-team__role {
    margin: var(--ad-space-xxs) 0 0;
    color: var(--ad-ink-muted-48);
  }
  #ad-team-{{ section.id }} .ad-team__bio {
    margin: var(--ad-space-sm) 0 0;
    max-width: 280px;
    color: var(--ad-ink-muted-80);
  }
  #ad-team-{{ section.id }} .ad-team__social {
    display: flex;
    gap: var(--ad-space-sm);
    margin-top: var(--ad-space-sm);
    justify-content: center;
  }
  #ad-team-{{ section.id }} .ad-team__social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--ad-ink-muted-48);
    opacity: 0.6;
    transition: opacity 200ms ease, color 200ms ease;
    text-decoration: none;
  }
  #ad-team-{{ section.id }} .ad-team__social-link:hover,
  #ad-team-{{ section.id }} .ad-team__social-link:focus-visible {
    opacity: 1;
    color: var(--ad-ink);
  }
  #ad-team-{{ section.id }} .ad-team__empty {
    text-align: center;
    padding: var(--ad-space-xxl) var(--ad-space-lg);
    border: 1px solid var(--ad-hairline);
    border-radius: var(--ad-radius-lg);
    background: var(--ad-canvas);
  }
  #ad-team-{{ section.id }} .ad-team__empty p {
    margin: 0;
    color: var(--ad-ink);
  }
  @media (max-width: 1067px) {
    #ad-team-{{ section.id }} .ad-team__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 639px) {
    #ad-team-{{ section.id }} .ad-team__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Team",
  "settings": [
    {
      "type": "select",
      "id": "variant",
      "label": "Fundo",
      "options": [
        { "value": "light", "label": "Claro" },
        { "value": "parchment", "label": "Parchment" }
      ],
      "default": "light"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Colunas (desktop)",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    }
  ],
  "blocks": [
    {
      "type": "member",
      "name": "Membro",
      "settings": [
        {
          "type": "image_picker",
          "id": "photo",
          "label": "Foto",
          "info": "400 x 400px recomendado"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nome",
          "default": "Nome"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Cargo",
          "default": "Cargo"
        },
        {
          "type": "textarea",
          "id": "bio",
          "label": "Bio"
        },
        {
          "type": "url",
          "id": "linkedin",
          "label": "LinkedIn"
        },
        {
          "type": "url",
          "id": "instagram",
          "label": "Instagram"
        },
        {
          "type": "url",
          "id": "twitter",
          "label": "Twitter"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "member", "settings": { "name": "João", "role": "Fundador" } },
      { "type": "member", "settings": { "name": "Maria", "role": "Operações" } },
      { "type": "member", "settings": { "name": "Pedro", "role": "Atendimento" } }
    ]
  },
  "presets": [
    { "name": "Team", "category": "Team" }
  ]
}
{% endschema %}
