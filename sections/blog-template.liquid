{%- comment -%}
  Apple-pure blog template.
  Clean header + article card grid with native Shopify pagination.
{%- endcomment -%}

{%- assign _per_page = section.settings.articles_per_page | default: 12 -%}

<section class="ad-blog ad-tile ad-tile--{{ section.settings.variant | default: 'light' }}" data-section-id="{{ section.id }}" data-section-type="blog-template">

  <header class="ad-blog__head">
    <h1 class="ad-blog__title ad-display-lg">{{ blog.title }}</h1>
    {%- if section.settings.subtitle != blank -%}
      <p class="ad-blog__subtitle ad-lead">{{ section.settings.subtitle }}</p>
    {%- endif -%}
  </header>

  {%- if blog.articles_count == 0 -%}
    <div class="ad-blog__empty ad-tile ad-tile--parchment">
      <p class="ad-display-md">Em breve, novos artigos.</p>
    </div>
  {%- else -%}
    {%- paginate blog.articles by _per_page -%}
      <div class="ad-blog__grid" style="--ad-grid-cols: {{ section.settings.columns_desktop | default: 3 }}">
        {%- for article in blog.articles -%}
          <article class="ad-blog__card">
            {%- if article.image -%}
              <a class="ad-blog__media" href="{{ article.url }}" aria-label="{{ article.title | escape }}">
                <img src="{{ article.image | img_url: '800x' }}" alt="{{ article.title | escape }}" loading="lazy">
              </a>
            {%- endif -%}
            <div class="ad-blog__body">
              <p class="ad-blog__date ad-caption-strong">{{ article.published_at | date: '%d %B %Y' }}</p>
              <h2 class="ad-blog__card-title ad-display-md">
                <a href="{{ article.url }}">{{ article.title }}</a>
              </h2>
              <p class="ad-blog__excerpt ad-body">{{ article.excerpt_or_content | strip_html | truncate: 180 }}</p>
              {%- render 'apple-button', variant: 'text-link', href: article.url, label: 'Ler artigo →' -%}
            </div>
          </article>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <nav class="ad-blog__pagination" role="navigation" aria-label="Paginação">
          {%- if paginate.previous -%}
            {%- render 'apple-button', variant: 'text-link', href: paginate.previous.url, label: '‹ Anterior' -%}
          {%- endif -%}
          <span class="ad-caption" style="opacity:.7">
            Página {{ paginate.current_page }} de {{ paginate.pages }}
          </span>
          {%- if paginate.next -%}
            {%- render 'apple-button', variant: 'text-link', href: paginate.next.url, label: 'Próxima ›' -%}
          {%- endif -%}
        </nav>
      {%- endif -%}
    {%- endpaginate -%}
  {%- endif -%}

</section>

<style>
  .ad-blog {
    padding-top: var(--ad-space-xxl);
    padding-bottom: var(--ad-space-section);
  }
  .ad-blog > * {
    max-width: 1440px;
    margin-left: auto;
    margin-right: auto;
    padding-left: var(--ad-space-lg);
    padding-right: var(--ad-space-lg);
  }
  .ad-blog__head { text-align: center; margin-bottom: var(--ad-space-xxl); }
  .ad-blog__title { margin: 0 0 var(--ad-space-sm); }
  .ad-blog__subtitle { margin: 0 auto; max-width: 720px; color: var(--ad-color-ink-muted-80); }

  .ad-blog__grid {
    display: grid;
    grid-template-columns: repeat(var(--ad-grid-cols, 3), minmax(0, 1fr));
    gap: var(--ad-space-xl);
  }

  .ad-blog__card {
    display: flex;
    flex-direction: column;
    gap: var(--ad-space-md);
  }
  .ad-blog__media {
    display: block;
    overflow: hidden;
    border-radius: var(--ad-radius-lg);
    aspect-ratio: 16 / 10;
    background: var(--ad-color-canvas-parchment);
  }
  .ad-blog__media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 320ms cubic-bezier(.2,.7,.2,1);
  }
  .ad-blog__card:hover .ad-blog__media img { transform: scale(1.02); }

  .ad-blog__body {
    display: flex;
    flex-direction: column;
    gap: var(--ad-space-sm);
  }
  .ad-blog__date { margin: 0; color: var(--ad-color-ink-muted-48); }
  .ad-blog__card-title { margin: 0; }
  .ad-blog__card-title a { color: var(--ad-color-ink); text-decoration: none; }
  .ad-blog__card-title a:hover { color: var(--ad-color-primary); }
  .ad-blog__excerpt { margin: 0; color: var(--ad-color-ink-muted-80); }

  .ad-blog__pagination {
    margin-top: var(--ad-space-xxl);
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--ad-space-lg);
  }

  .ad-blog__empty {
    text-align: center;
    padding: var(--ad-space-section) var(--ad-space-lg);
    border-radius: var(--ad-radius-lg);
    max-width: 1440px;
    margin: 0 auto;
  }
  .ad-blog__empty p { margin: 0; }

  @media (max-width: 1068px) {
    .ad-blog__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: var(--ad-space-lg); }
  }
  @media (max-width: 640px) {
    .ad-blog__grid { grid-template-columns: 1fr; gap: var(--ad-space-lg); }
  }
</style>

{% schema %}
{
  "name": "Blog (Apple)",
  "class": "shopify-section__blog-posts",
  "settings": [
    { "type": "text", "id": "subtitle", "label": "Subtítulo (opcional)" },
    { "type": "select", "id": "variant", "label": "Cor da superfície", "default": "light",
      "options": [
        { "value": "light", "label": "Branco" },
        { "value": "parchment", "label": "Parchment" }
      ]
    },
    { "type": "range", "id": "articles_per_page", "label": "Artigos por página", "min": 6, "max": 24, "step": 1, "default": 12 },
    { "type": "range", "id": "columns_desktop", "label": "Colunas desktop", "min": 2, "max": 4, "step": 1, "default": 3 }
  ],
  "presets": [
    { "name": "Blog (Apple)" }
  ]
}
{% endschema %}
