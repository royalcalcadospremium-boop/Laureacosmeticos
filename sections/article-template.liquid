{%- liquid
  assign variant = section.settings.variant | default: 'light'
  assign canvas_color = '#ffffff'
  if variant == 'parchment'
    assign canvas_color = '#f5f5f7'
  endif
-%}

<article class="ad-article ad-article--{{ variant }}" data-section-id="{{ section.id }}" data-section-type="blog-post">
  <header class="ad-article__header">
    <h1 class="ad-article__title ad-hero-display">{{ article.title }}</h1>

    <div class="ad-article__meta">
      <time class="ad-article__meta-date ad-caption-strong" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
        {{- article.published_at | date: '%d %B %Y' -}}
      </time>

      {%- if section.settings.show_author and article.author != blank -%}
        <span class="ad-article__meta-dot" aria-hidden="true">·</span>
        <span class="ad-article__meta-author ad-caption">por {{ article.author }}</span>
      {%- endif -%}

      {%- if section.settings.show_tags and article.tags.size > 0 -%}
        <span class="ad-article__meta-dot" aria-hidden="true">·</span>
        <span class="ad-article__meta-tags ad-caption">
          {%- for tag in article.tags -%}
            <a href="/blogs/{{ blog.handle }}/tagged/{{ tag | handle }}" class="ad-article__meta-tag">{{ tag }}</a>{%- unless forloop.last -%}, {%- endunless -%}
          {%- endfor -%}
        </span>
      {%- endif -%}
    </div>
  </header>

  {%- if article.image -%}
    <figure class="ad-article__hero">
      <img
        class="ad-article__hero-image"
        src="{{ article.image | img_url: '1440x' }}"
        srcset="{{ article.image | img_url: '600x' }} 600w, {{ article.image | img_url: '900x' }} 900w, {{ article.image | img_url: '1200x' }} 1200w, {{ article.image | img_url: '1440x' }} 1440w"
        sizes="(min-width: 1440px) 1440px, 100vw"
        alt="{{ article.image.alt | escape }}"
        loading="eager">
    </figure>
  {%- endif -%}

  <div class="ad-article__body ad-body">
    {{ article.content }}
  </div>

  <div class="ad-article__back">
    {% render 'apple-button', variant: 'text-link', href: blog.url, label: '← Voltar ao blog' %}
  </div>

  {%- if article.comments_enabled? -%}
    <section id="comments" class="ad-article__comments">
      {%- if article.comments_count > 0 -%}
        <h2 class="ad-article__comments-title ad-display-md">
          {{ 'blog.article.comments_count' | t: count: article.comments_count }}
        </h2>

        {%- paginate article.comments by 50 -%}
          <div class="ad-article__comments-list">
            {%- for comment in article.comments -%}
              <article class="ad-article__comment">
                <header class="ad-article__comment-header">
                  <span class="ad-article__comment-author ad-body-strong">{{ comment.author }}</span>
                  <span class="ad-article__comment-dot" aria-hidden="true">·</span>
                  <time class="ad-article__comment-date ad-caption" datetime="{{ comment.created_at | date: '%Y-%m-%d' }}">
                    {{- comment.created_at | date: '%d %B %Y' -}}
                  </time>
                </header>
                <div class="ad-article__comment-content ad-body">
                  {{ comment.content }}
                </div>
              </article>
            {%- endfor -%}
          </div>

          {%- render 'pagination', paginate: paginate -%}
        {%- endpaginate -%}
      {%- endif -%}

      {%- form 'new_comment', article, class: 'ad-article__comment-form' -%}
        <h2 class="ad-article__comment-form-title ad-display-md">{{ 'blog.comments.leave_comment' | t }}</h2>

        {%- if blog.moderated? -%}
          <p class="ad-article__comment-note ad-caption">{{ 'blog.comments.approval_notice' | t }}</p>
        {%- endif -%}

        {%- if form.posted_successfully? -%}
          <p class="ad-article__comment-alert ad-article__comment-alert--success ad-body">
            {%- if blog.moderated? -%}
              {{- 'blog.comments.success_moderated' | t -}}
            {%- else -%}
              {{- 'blog.comments.success' | t -}}
            {%- endif -%}
          </p>
        {%- elsif form.errors -%}
          <div class="ad-article__comment-alert ad-article__comment-alert--error ad-body">
            <ul>
              {%- for field in form.errors -%}
                <li>{{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}</li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}

        <div class="ad-article__comment-row">
          <div class="ad-article__comment-field">
            <label for="comment-form-name" class="ad-caption-strong">{{ 'blog.comments.name' | t }}</label>
            <input id="comment-form-name" type="text" name="comment[author]" value="{{ form.author | default: customer.name | escape }}" required>
          </div>
          <div class="ad-article__comment-field">
            <label for="comment-form-email" class="ad-caption-strong">{{ 'blog.comments.email' | t }}</label>
            <input id="comment-form-email" type="email" name="comment[email]" value="{{ form.email | default: customer.email | escape }}" required>
          </div>
        </div>

        <div class="ad-article__comment-field">
          <label for="comment-form-body" class="ad-caption-strong">{{ 'blog.comments.content' | t }}</label>
          <textarea id="comment-form-body" name="comment[body]" rows="5" required>{{ form.body }}</textarea>
        </div>

        <button type="submit" class="ad-article__comment-submit">{{ 'blog.comments.submit' | t }}</button>
      {%- endform -%}
    </section>
  {%- endif -%}
</article>

<style>
  .ad-article {
    background: {{ canvas_color }};
    color: var(--ad-ink, #1d1d1f);
    padding: var(--ad-section, 80px) 0;
  }

  .ad-article__header {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 var(--ad-lg, 24px) var(--ad-xxl, 48px);
    text-align: center;
  }

  .ad-article__title {
    margin: 0 0 var(--ad-lg, 24px);
    letter-spacing: -0.28px;
    color: var(--ad-ink, #1d1d1f);
  }

  .ad-article__meta {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--ad-xs, 8px);
    color: var(--ad-ink-muted-80, #333333);
  }

  .ad-article__meta-dot {
    color: var(--ad-ink-muted-48, #7a7a7a);
  }

  .ad-article__meta-author { color: var(--ad-ink-muted-80, #333333); }

  .ad-article__meta-tag {
    color: var(--ad-primary, #0066cc);
    text-decoration: none;
  }
  .ad-article__meta-tag:hover { text-decoration: underline; }

  .ad-article__hero {
    max-width: 1440px;
    margin: 0 auto var(--ad-xxl, 48px);
    padding: 0 var(--ad-lg, 24px);
  }

  .ad-article__hero-image {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--ad-radius-lg, 18px);
    box-shadow: var(--ad-shadow-product, rgba(0, 0, 0, 0.22) 3px 5px 30px 0);
  }

  .ad-article__body {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 var(--ad-lg, 24px);
    line-height: 1.6;
    color: var(--ad-ink, #1d1d1f);
  }

  .ad-article__body > * + * { margin-top: var(--ad-lg, 24px); }

  .ad-article__body h2 {
    font-family: 'SF Pro Text', system-ui, -apple-system, sans-serif;
    font-size: 34px;
    font-weight: 600;
    line-height: 1.47;
    letter-spacing: -0.374px;
    margin-top: var(--ad-xxl, 48px);
    margin-bottom: var(--ad-md, 17px);
    color: var(--ad-ink, #1d1d1f);
  }

  .ad-article__body h3 {
    font-family: 'SF Pro Display', system-ui, -apple-system, sans-serif;
    font-size: 21px;
    font-weight: 600;
    line-height: 1.19;
    letter-spacing: 0.231px;
    margin-top: var(--ad-xl, 32px);
    margin-bottom: var(--ad-sm, 12px);
    color: var(--ad-ink, #1d1d1f);
  }

  .ad-article__body p { margin: 0 0 var(--ad-lg, 24px); }
  .ad-article__body p:last-child { margin-bottom: 0; }

  .ad-article__body ul,
  .ad-article__body ol {
    margin: 0 0 var(--ad-lg, 24px);
    padding-left: var(--ad-lg, 24px);
  }
  .ad-article__body li + li { margin-top: var(--ad-xs, 8px); }

  .ad-article__body blockquote {
    margin: var(--ad-xl, 32px) 0;
    padding: 0 0 0 var(--ad-lg, 24px);
    border-left: 4px solid var(--ad-primary, #0066cc);
    font-style: italic;
    color: var(--ad-ink-muted-80, #333333);
  }

  .ad-article__body img {
    display: block;
    max-width: 100%;
    height: auto;
    border-radius: var(--ad-radius-lg, 18px);
    box-shadow: var(--ad-shadow-product, rgba(0, 0, 0, 0.22) 3px 5px 30px 0);
    margin: var(--ad-xl, 32px) auto;
  }

  .ad-article__body a {
    color: var(--ad-primary, #0066cc);
    text-decoration: none;
  }
  .ad-article__body a:hover { text-decoration: underline; }

  .ad-article__body strong { font-weight: 600; }

  .ad-article__back {
    max-width: 720px;
    margin: var(--ad-xxl, 48px) auto 0;
    padding: 0 var(--ad-lg, 24px);
    text-align: center;
  }

  .ad-article__comments {
    max-width: 720px;
    margin: var(--ad-section, 80px) auto 0;
    padding: var(--ad-xxl, 48px) var(--ad-lg, 24px) 0;
    border-top: 1px solid var(--ad-hairline, #e0e0e0);
  }

  .ad-article__comments-title {
    margin: 0 0 var(--ad-xl, 32px);
    color: var(--ad-ink, #1d1d1f);
  }

  .ad-article__comments-list { display: flex; flex-direction: column; gap: var(--ad-xl, 32px); margin-bottom: var(--ad-xxl, 48px); }

  .ad-article__comment {
    padding: var(--ad-lg, 24px) 0;
    border-bottom: 1px solid var(--ad-divider-soft, #f0f0f0);
  }

  .ad-article__comment-header {
    display: flex;
    align-items: baseline;
    gap: var(--ad-xs, 8px);
    margin-bottom: var(--ad-sm, 12px);
  }

  .ad-article__comment-date,
  .ad-article__comment-dot { color: var(--ad-ink-muted-48, #7a7a7a); }

  .ad-article__comment-form {
    display: flex;
    flex-direction: column;
    gap: var(--ad-lg, 24px);
    margin-top: var(--ad-xxl, 48px);
  }

  .ad-article__comment-form-title { margin: 0; }

  .ad-article__comment-note { color: var(--ad-ink-muted-48, #7a7a7a); margin: 0; }

  .ad-article__comment-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--ad-lg, 24px);
  }
  @media (max-width: 640px) {
    .ad-article__comment-row { grid-template-columns: 1fr; }
  }

  .ad-article__comment-field { display: flex; flex-direction: column; gap: var(--ad-xs, 8px); }

  .ad-article__comment-field label { color: var(--ad-ink, #1d1d1f); }

  .ad-article__comment-field input,
  .ad-article__comment-field textarea {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid var(--ad-hairline, #e0e0e0);
    border-radius: var(--ad-radius-md, 11px);
    background: var(--ad-canvas, #ffffff);
    color: var(--ad-ink, #1d1d1f);
    font-family: 'SF Pro Text', system-ui, -apple-system, sans-serif;
    font-size: 17px;
    line-height: 1.47;
    letter-spacing: -0.374px;
  }

  .ad-article__comment-field input:focus,
  .ad-article__comment-field textarea:focus {
    outline: 2px solid var(--ad-primary-focus, #0071e3);
    outline-offset: 2px;
    border-color: var(--ad-primary, #0066cc);
  }

  .ad-article__comment-submit {
    align-self: flex-start;
    background: var(--ad-primary, #0066cc);
    color: var(--ad-on-primary, #ffffff);
    border: none;
    border-radius: var(--ad-radius-pill, 9999px);
    padding: 11px 22px;
    font-family: 'SF Pro Text', system-ui, -apple-system, sans-serif;
    font-size: 17px;
    font-weight: 400;
    letter-spacing: -0.374px;
    cursor: pointer;
    transition: transform 0.15s ease;
  }
  .ad-article__comment-submit:active { transform: scale(0.95); }
  .ad-article__comment-submit:focus-visible { outline: 2px solid var(--ad-primary-focus, #0071e3); outline-offset: 2px; }

  .ad-article__comment-alert {
    padding: var(--ad-md, 17px);
    border-radius: var(--ad-radius-md, 11px);
    margin: 0;
  }
  .ad-article__comment-alert--success { background: rgba(0, 102, 204, 0.06); color: var(--ad-primary, #0066cc); }
  .ad-article__comment-alert--error { background: rgba(220, 38, 38, 0.06); color: #b91c1c; }
  .ad-article__comment-alert ul { margin: 0; padding-left: var(--ad-lg, 24px); }

  @media (max-width: 768px) {
    .ad-article { padding: var(--ad-xxl, 48px) 0; }
    .ad-article__title { font-size: 40px; }
  }
  @media (max-width: 480px) {
    .ad-article__title { font-size: 34px; }
  }
</style>

{% schema %}
{
  "name": "Blog post page",
  "class": "shopify-section__article",
  "settings": [
    {
      "type": "select",
      "id": "variant",
      "label": "Canvas",
      "options": [
        { "value": "light", "label": "Branco" },
        { "value": "parchment", "label": "Parchment (#f5f5f7)" }
      ],
      "default": "light"
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "Mostrar autor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_tags",
      "label": "Mostrar tags",
      "default": true
    }
  ]
}
{% endschema %}
