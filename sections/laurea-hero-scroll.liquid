{% comment %}
  Laurea — Hero Scroll (Body Splash)
  Scroll-driven cinematic sequence using a 50-frame image set.
{% endcomment %}

{{ 'laurea-hero-scroll.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign frame_count = section.settings.frame_count | default: 50
  assign cta_text = section.settings.cta_text | default: 'Comprar Body Splash'
  assign cta_link = section.settings.cta_link | default: '/collections/all'
  assign eyebrow  = section.settings.eyebrow  | default: 'Lançamento'
  assign brand    = section.settings.brand    | default: 'Soul Cosméticos'
  assign heading  = section.settings.heading  | default: 'Body Splash Lumina — a nova linha shimmer da Soul Cosméticos'
-%}

{%- capture frame_urls -%}[
{%- for i in (1..frame_count) -%}
  {%- assign idx = forloop.index0 -%}
  {%- if idx < 10 -%}
    {%- assign idx_padded = idx | prepend: '0' -%}
  {%- else -%}
    {%- assign idx_padded = idx | append: '' -%}
  {%- endif -%}
  {%- assign frame_name = 'hero-frame-' | append: idx_padded | append: '.jpg' -%}
  "{{ frame_name | asset_url }}"{%- unless forloop.last -%},{%- endunless -%}
{%- endfor -%}
]{%- endcapture -%}

{%- assign first_frame_url = 'hero-frame-00.jpg' | asset_url -%}

<link rel="preload" as="image" href="{{ first_frame_url }}" fetchpriority="high">

<section
  class="lhs"
  data-laurea-hero-scroll
  data-section-id="{{ section.id }}"
  data-frames='{{ frame_urls | strip_newlines | strip }}'
  aria-label="{{ brand | escape }} — {{ eyebrow | escape }} Body Splash"
>
  <h1 class="visually-hidden">{{ heading | escape }}</h1>
  <div class="lhs__track" data-hero-track>
    <div class="lhs__sticky" data-hero-sticky>

      <div class="lhs__glow" aria-hidden="true"></div>
      <div class="lhs__sparkle" aria-hidden="true"></div>

      <img
        class="lhs__lcp"
        data-hero-lcp
        src="{{ first_frame_url }}"
        alt="{{ brand | escape }} Body Splash — linha completa"
        width="540"
        height="960"
        loading="eager"
        fetchpriority="high"
        decoding="async">

      <canvas class="lhs__canvas" data-hero-canvas aria-hidden="true"></canvas>

      <div class="lhs__chrome">
        <div class="lhs__top">
          {%- if section.settings.show_badge -%}
            <span class="lhs__badge">{{ brand | escape }} · {{ eyebrow | escape }}</span>
          {%- else -%}
            <span></span>
          {%- endif -%}

          {%- if section.settings.show_counter -%}
            <span class="lhs__counter" data-hero-counter>01 / {{ frame_count }}</span>
          {%- endif -%}
        </div>

        <div></div>

        <div class="lhs__bottom">
          {%- if section.settings.show_cta -%}
            <a class="lhs__cta" data-hero-cta href="{{ cta_link }}">
              <span>{{ cta_text | escape }}</span>
              <svg class="lhs__cta-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14"></path>
                <path d="m13 5 7 7-7 7"></path>
              </svg>
            </a>
          {%- endif -%}

          {%- if section.settings.show_cue -%}
            <div class="lhs__cue" data-hero-cue aria-hidden="true">
              <span>Role para descobrir</span>
              <span class="lhs__cue-line"></span>
            </div>
          {%- endif -%}
        </div>
      </div>

      {%- if section.settings.show_progress -%}
        <div class="lhs__progress" data-hero-progress aria-hidden="true"><span></span></div>
      {%- endif -%}
    </div>
  </div>
</section>

<noscript>
  <style>.lhs { display: none; }</style>
</noscript>

<script src="{{ 'laurea-hero-scroll.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Hero Scroll — Body Splash",
  "tag": "section",
  "class": "shopify-section--laurea-hero-scroll",
  "settings": [
    {
      "type": "header",
      "content": "Conteúdo"
    },
    {
      "type": "text",
      "id": "brand",
      "label": "Marca",
      "default": "Soul Cosméticos"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título principal (SEO / leitores de tela)",
      "default": "Body Splash Lumina — a nova linha shimmer da Soul Cosméticos"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow (texto curto)",
      "default": "Lançamento"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texto do botão CTA",
      "default": "Comprar Body Splash"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Link do CTA"
    },
    {
      "type": "header",
      "content": "Sequência"
    },
    {
      "type": "range",
      "id": "frame_count",
      "label": "Quantidade de frames",
      "min": 10,
      "max": 50,
      "step": 1,
      "default": 50,
      "info": "Use 50 para máxima fluidez. Reduzir economiza banda mas deixa o scrub menos suave."
    },
    {
      "type": "header",
      "content": "Elementos visíveis"
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Mostrar selo da marca",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Mostrar botão CTA",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_cue",
      "label": "Mostrar indicador de scroll",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_progress",
      "label": "Mostrar barra de progresso",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_counter",
      "label": "Mostrar contador de frames",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Hero Scroll — Body Splash",
      "category": "Hero"
    }
  ]
}
{% endschema %}
