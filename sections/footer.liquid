{%- comment -%}
  Apple-pure footer (Subsistema 1).
  Parchment background, dense-link columns, legal row at the bottom.
{%- endcomment -%}

<footer class="ad-footer" data-section-id="{{ section.id }}" data-section-type="footer" role="contentinfo">

  {%- if section.settings.global_footnote != blank -%}
    <p class="ad-footer__footnote ad-fine-print">{{ section.settings.global_footnote }}</p>
  {%- endif -%}

  <div class="ad-footer__columns">
    {%- if section.blocks.size == 0 -%}
      {%- comment -%} Fallback when customizer is empty (post-migration first paint) {%- endcomment -%}
      <div class="ad-footer__column">
        <h3 class="ad-footer__heading ad-caption-strong">Comprar</h3>
        <ul class="ad-footer__links">
          <li><a class="ad-footer__link ad-dense-link" href="/collections/all">Todos os produtos</a></li>
          <li><a class="ad-footer__link ad-dense-link" href="/collections/tenis">Tênis</a></li>
          <li><a class="ad-footer__link ad-dense-link" href="/collections/camisetas">Camisetas</a></li>
          <li><a class="ad-footer__link ad-dense-link" href="/collections/bermudas">Bermudas</a></li>
        </ul>
      </div>
      <div class="ad-footer__column">
        <h3 class="ad-footer__heading ad-caption-strong">Conta</h3>
        <ul class="ad-footer__links">
          <li><a class="ad-footer__link ad-dense-link" href="{{ routes.account_login_url }}">Entrar</a></li>
          <li><a class="ad-footer__link ad-dense-link" href="{{ routes.account_register_url }}">Criar conta</a></li>
          <li><a class="ad-footer__link ad-dense-link" href="{{ routes.cart_url }}">Carrinho</a></li>
        </ul>
      </div>
      <div class="ad-footer__column">
        <h3 class="ad-footer__heading ad-caption-strong">Royal</h3>
        <ul class="ad-footer__links">
          <li><a class="ad-footer__link ad-dense-link" href="/pages/sobre">Sobre nós</a></li>
          <li><a class="ad-footer__link ad-dense-link" href="/pages/atacado">Atacado</a></li>
          <li><a class="ad-footer__link ad-dense-link" href="/pages/dropshipping">Dropshipping</a></li>
        </ul>
      </div>
      <div class="ad-footer__column">
        <h3 class="ad-footer__heading ad-caption-strong">Suporte</h3>
        <ul class="ad-footer__links">
          <li><a class="ad-footer__link ad-dense-link" href="https://wa.me/5562991902661" target="_blank" rel="noopener">WhatsApp: (62) 99190-2661</a></li>
          <li><a class="ad-footer__link ad-dense-link" href="mailto:Royalcalcadospremium@gmail.com">Royalcalcadospremium@gmail.com</a></li>
          <li><a class="ad-footer__link ad-dense-link" href="/pages/faq">Perguntas frequentes</a></li>
          <li><a class="ad-footer__link ad-dense-link" href="/pages/contato">Contato</a></li>
        </ul>
      </div>
    {%- endif -%}
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'link_list' -%}
          <div class="ad-footer__column">
            {%- if block.settings.title != blank -%}
              <h3 class="ad-footer__heading ad-caption-strong">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- assign menu = linklists[block.settings.menu] -%}
            {%- if menu.links.size > 0 -%}
              <ul class="ad-footer__links">
                {%- for link in menu.links -%}
                  <li><a class="ad-footer__link ad-dense-link" href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- when 'rich_text' -%}
          <div class="ad-footer__column">
            {%- if block.settings.title != blank -%}
              <h3 class="ad-footer__heading ad-caption-strong">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.content != blank -%}
              <div class="ad-footer__rich ad-caption">{{ block.settings.content }}</div>
            {%- endif -%}
          </div>
        {%- when 'contact' -%}
          <div class="ad-footer__column">
            {%- if block.settings.title != blank -%}
              <h3 class="ad-footer__heading ad-caption-strong">{{ block.settings.title }}</h3>
            {%- endif -%}
            <ul class="ad-footer__links">
              {%- if block.settings.phone != blank -%}
                <li><a class="ad-footer__link ad-dense-link" href="tel:{{ block.settings.phone | replace: ' ', '' | replace: '(', '' | replace: ')', '' | replace: '-', '' }}">{{ block.settings.phone }}</a></li>
              {%- endif -%}
              {%- if block.settings.whatsapp != blank -%}
                <li><a class="ad-footer__link ad-dense-link" href="https://wa.me/{{ block.settings.whatsapp | replace: ' ', '' | replace: '(', '' | replace: ')', '' | replace: '-', '' | replace: '+', '' }}" target="_blank" rel="noopener">WhatsApp: {{ block.settings.whatsapp }}</a></li>
              {%- endif -%}
              {%- if block.settings.email != blank -%}
                <li><a class="ad-footer__link ad-dense-link" href="mailto:{{ block.settings.email }}">{{ block.settings.email }}</a></li>
              {%- endif -%}
              {%- if block.settings.address != blank -%}
                <li class="ad-footer__address ad-caption">{{ block.settings.address }}</li>
              {%- endif -%}
            </ul>
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>

  <div class="ad-footer__legal">
    <p class="ad-fine-print">
      &copy; {{ 'now' | date: '%Y' }} {{ shop.name | escape }}.
      {%- if section.settings.cnpj != blank %} CNPJ {{ section.settings.cnpj }}.{%- endif -%}
      {%- if section.settings.legal_text != blank %} {{ section.settings.legal_text }}{%- endif -%}
    </p>
    {%- if section.settings.show_payment_icons -%}
      {%- assign payment_types = shop.enabled_payment_types -%}
      {%- if payment_types.size > 0 -%}
        <ul class="ad-footer__payments" aria-label="Métodos de pagamento aceitos">
          {%- for type in payment_types -%}
            <li class="ad-footer__payment">{{ type | payment_type_svg_tag: class: 'ad-footer__payment-icon' }}</li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    {%- endif -%}
  </div>

</footer>

<style>
  .ad-footer {
    background-color: var(--ad-color-canvas-parchment);
    color: var(--ad-color-ink-muted-80);
    padding: 64px var(--ad-space-lg);
  }
  .ad-footer__footnote {
    max-width: 1440px;
    margin: 0 auto var(--ad-space-xxl);
    color: var(--ad-color-ink-muted-48);
    line-height: 1.5;
  }
  .ad-footer__columns {
    max-width: 1440px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--ad-space-xxl);
  }
  .ad-footer__heading {
    margin: 0 0 var(--ad-space-xs);
    color: var(--ad-color-ink);
  }
  .ad-footer__links {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .ad-footer__link {
    color: var(--ad-color-ink-muted-80);
    text-decoration: none;
    display: inline-block;
  }
  .ad-footer__link:hover,
  .ad-footer__link:focus-visible {
    color: var(--ad-color-ink);
    text-decoration: underline;
  }
  .ad-footer__rich {
    color: var(--ad-color-ink-muted-80);
  }
  .ad-footer__rich p { margin: 0 0 var(--ad-space-xs); }
  .ad-footer__rich a { color: var(--ad-color-primary); }
  .ad-footer__address { color: var(--ad-color-ink-muted-48); }

  .ad-footer__legal {
    max-width: 1440px;
    margin: var(--ad-space-xxl) auto 0;
    padding-top: var(--ad-space-lg);
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    display: flex;
    flex-wrap: wrap;
    gap: var(--ad-space-lg);
    justify-content: space-between;
    align-items: center;
  }
  .ad-footer__legal p {
    margin: 0;
    color: var(--ad-color-ink-muted-48);
    line-height: 1.5;
  }
  .ad-footer__payments {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--ad-space-sm);
    align-items: center;
  }
  .ad-footer__payment-icon {
    height: 22px;
    width: auto;
    display: block;
    opacity: 0.7;
  }

  @media (max-width: 640px) {
    .ad-footer { padding: 48px var(--ad-space-md); }
    .ad-footer__columns { gap: var(--ad-space-xl); }
  }
</style>

{% schema %}
{
  "name": "Rodapé (Apple)",
  "settings": [
    { "type": "textarea", "id": "global_footnote", "label": "Footnote global (disclaimers no topo do rodapé)" },
    { "type": "header", "content": "Linha legal" },
    { "type": "text", "id": "cnpj", "label": "CNPJ" },
    { "type": "richtext", "id": "legal_text", "label": "Texto legal adicional" },
    { "type": "checkbox", "id": "show_payment_icons", "label": "Mostrar métodos de pagamento", "default": true }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Coluna de menu",
      "settings": [
        { "type": "text", "id": "title", "label": "Título da coluna", "default": "Comprar" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    },
    {
      "type": "rich_text",
      "name": "Coluna de texto",
      "settings": [
        { "type": "text", "id": "title", "label": "Título da coluna" },
        { "type": "richtext", "id": "content", "label": "Conteúdo" }
      ]
    },
    {
      "type": "contact",
      "name": "Coluna de contato",
      "settings": [
        { "type": "text", "id": "title", "label": "Título", "default": "Suporte" },
        { "type": "text", "id": "phone", "label": "Telefone" },
        { "type": "text", "id": "whatsapp", "label": "WhatsApp (com DDD)" },
        { "type": "text", "id": "email", "label": "E-mail" },
        { "type": "textarea", "id": "address", "label": "Endereço" }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "Rodapé Apple",
      "blocks": [
        { "type": "link_list", "settings": { "title": "Comprar" } },
        { "type": "link_list", "settings": { "title": "Conta" } },
        { "type": "link_list", "settings": { "title": "Royal" } },
        { "type": "contact", "settings": { "title": "Suporte" } }
      ]
    }
  ]
}
{% endschema %}
