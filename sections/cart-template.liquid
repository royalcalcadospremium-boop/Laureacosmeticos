<script>
(function(){
  var root = document.querySelector('[data-section-id="{{ section.id }}"]');
  if (!root) return;

  var needsVendedor = root.getAttribute('data-needs-vendedor') === 'true';
  var form = root.querySelector('[data-cart-form]');
  var checkoutBtn = root.querySelector('[data-checkout-btn]');
  var backdrop = document.getElementById('cvCartBackdrop');
  var modal = document.getElementById('cvCartModal');
  var closeBtn = document.getElementById('cvCartClose');
  var finalizeBtn = document.getElementById('cvCartFinalize');

  // 1) Debounced auto-update on quantity change
  var inputs = root.querySelectorAll('[data-line-qty]');
  var debounceTimer;
  inputs.forEach(function(input){
    input.addEventListener('change', function(){
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(function(){
        updateCart(input.dataset.lineKey, parseInt(input.value, 10) || 0);
      }, 350);
    });
  });

  function updateCart(key, quantity) {
    fetch('{{ routes.cart_change_url }}.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ id: key, quantity: quantity })
    })
    .then(function(r){ return r.json(); })
    .then(function(cart){
      if (quantity === 0) { window.location.reload(); return; }
      var subtotalEl = root.querySelector('[data-cart-subtotal]');
      if (subtotalEl) subtotalEl.textContent = formatMoney(cart.items_subtotal_price);
      var line = cart.items.find(function(i){ return i.key === key; });
      if (line) {
        var lineEl = root.querySelector('[data-line-key="' + key + '"]');
        var priceEl = lineEl && lineEl.querySelector('[data-line-price]');
        if (priceEl) priceEl.textContent = formatMoney(line.final_line_price);
      }
    })
    .catch(function(){ window.location.reload(); });
  }

  function formatMoney(cents) {
    var n = (cents / 100).toFixed(2).replace('.', ',');
    var parts = n.split(',');
    parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, '.');
    return 'R$ ' + parts.join(',');
  }

  // 2) "Finalizar Compra" SEMPRE abre o modal (independente de needs_vendedor).
  //    O conteúdo do modal já vem renderizado pelo Liquid com a opção certa:
  //    - needs_vendedor=false → modal tem botão verde + vendedoras
  //    - needs_vendedor=true  → modal tem só vendedoras
  if (form && checkoutBtn) {
    form.addEventListener('submit', function(e){
      e.preventDefault();
      e.stopPropagation();
      openModal();
    });
    checkoutBtn.addEventListener('click', function(e){
      e.preventDefault();
      e.stopPropagation();
      openModal();
    });
  }

  // 3) Modal open/close
  function openModal(){
    if (!modal || !backdrop) return;
    modal.classList.add('is-open');
    backdrop.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }
  function closeModal(){
    if (!modal || !backdrop) return;
    modal.classList.remove('is-open');
    backdrop.classList.remove('is-open');
    document.body.style.overflow = '';
  }
  if (backdrop) backdrop.addEventListener('click', closeModal);
  if (closeBtn) closeBtn.addEventListener('click', closeModal);
  document.addEventListener('keydown', function(e){
    if (e.key === 'Escape') closeModal();
  });

  // 3b) Botão "Finalizar compra aqui no site" — só existe no DOM quando
  //     needs_vendedor=false. Chama a API do Yampi DIRETO pra pular a página
  //     intermediária /cart e o checkout nativo Shopify. Mesma estratégia
  //     usada no cart-drawer.liquid.
  if (finalizeBtn) {
    // Backup: salva filhos originais pra restaurar caso falhe (sem innerHTML)
    var finalizeOriginalChildren = Array.from(finalizeBtn.childNodes).map(function(n){ return n.cloneNode(true); });

    function setBtnLoading(){
      finalizeBtn.disabled = true;
      finalizeBtn.style.opacity = '0.7';
      while (finalizeBtn.firstChild) finalizeBtn.removeChild(finalizeBtn.firstChild);
      finalizeBtn.textContent = 'Redirecionando…';
    }
    function restoreBtn(){
      finalizeBtn.disabled = false;
      finalizeBtn.style.opacity = '';
      while (finalizeBtn.firstChild) finalizeBtn.removeChild(finalizeBtn.firstChild);
      finalizeOriginalChildren.forEach(function(n){ finalizeBtn.appendChild(n.cloneNode(true)); });
    }

    finalizeBtn.addEventListener('click', async function(){
      setBtnLoading();
      try {
        var cartPayload = await fetch('/cart.json', {
          headers: { 'Accept': 'application/json' },
          credentials: 'same-origin'
        }).then(function(r){ return r.json(); });

        var body = JSON.stringify({
          shop: window.location.host,
          shopify_internal_domain: {{ shop.permanent_domain | json }},
          cart_payload: cartPayload
        });

        var r = await fetch('https://api.dooki.com.br/v2/public/shopify/cart', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: body
        });
        var resp = await r.json();

        if (resp && resp.checkout_direct_url) {
          try { await fetch('/cart/clear.js', { method: 'POST' }); } catch(e) {}
          var url = (typeof ymp_getUrlWithUtms === 'function')
            ? ymp_getUrlWithUtms(resp.checkout_direct_url)
            : resp.checkout_direct_url;
          window.location.href = url;
          return;
        }
        // Fallback: navega pra /cart e deixa o YampiSnippet completar lá
        window.location.href = '/cart';
      } catch (e) {
        window.location.href = '/cart';
      } finally {
        setTimeout(restoreBtn, 4000);
      }
    });
  }

  // 4) Vendedora WhatsApp dispatch — monta a mensagem com o carrinho inteiro
  if (modal) {
    modal.addEventListener('click', function(e){
      var btn = e.target.closest('.cv-cart-btn');
      if (!btn) return;
      var phone = (btn.getAttribute('data-phone') || '').replace(/\D+/g, '');
      if (!phone) return;

      fetch('/cart.js', { headers: { 'Accept': 'application/json' } })
        .then(function(r){ return r.json(); })
        .then(function(cart){
          var lines = [
            '*{{ shop.name | escape }}* — Pedido para confirmação',
            ''
          ];
          cart.items.forEach(function(it, idx){
            var line = (idx + 1) + '. ' + it.product_title;
            if (it.variant_title && it.variant_title !== 'Default Title') line += ' — ' + it.variant_title;
            line += ' (qtd ' + it.quantity + ') — ' + formatMoney(it.final_line_price);
            lines.push(line);
          });
          lines.push('');
          lines.push('*Total:* ' + formatMoney(cart.items_subtotal_price));
          lines.push('');
          lines.push('Gostaria de confirmar disponibilidade e dar continuidade ao pagamento.');

          var text = encodeURIComponent(lines.join('\n'));
          window.open('https://wa.me/' + phone + '?text=' + text, '_blank');
        })
        .catch(function(){
          window.open('https://wa.me/' + phone, '_blank');
        });
    });
  }
})();
</script>

