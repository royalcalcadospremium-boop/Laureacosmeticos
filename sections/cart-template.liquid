{%- comment -%}
  Apple-pure cart page (Subsistema 5 — v3).
  Sync nudge: 2026-05-18 11:13 — Shopify estava cacheando versão antiga.

  - Sem bordas arredondadas em imagem e input qty (divisória 1px entre itens).
  - "Finalizar Compra" SEMPRE abre o modal.
  - Conteúdo do modal varia conforme needs_vendedor:
    • false (todos items sincronizados Tiny/Olist): título + botão verde
      "Finalizar compra aqui no site" + divider + 3 vendedoras.
    • true (algum item NÃO sincronizado): só título + 3 vendedoras (sem botão verde).
  - needs_vendedor=true se: tag 'synced-olist' AUSENTE E
    inventory_management != 'shopify', OU tag 'consultar-vendedor' presente.
{%- endcomment -%}

{%- comment -%}
  Detecta se algum item precisa de vendedor (= NÃO sincronizado com Tiny/Olist).

  Critério "produto está sincronizado" — basta UM destes sinais:
    A. product.tags contains 'synced-olist'        ← gravado pelo sync-precos.js
                                                     em cada produto que ele atualiza
                                                     (autoridade primária — 100% preciso)
    B. variant.inventory_management == 'shopify'   ← inventário rastreado
                                                     (fallback durante transição,
                                                     antes do sync rodar novamente)

  Critério "este produto exige vendedor" — needs_vendedor=true se QUALQUER:
    1. NÃO está sincronizado (nem A nem B acima)
    2. Tem tag 'consultar-vendedor' (override manual no admin)
{%- endcomment -%}
{%- assign needs_vendedor = false -%}
{%- for item in cart.items -%}
  {%- assign is_synced = false -%}
  {%- if item.product.tags contains 'synced-olist' -%}
    {%- assign is_synced = true -%}
  {%- endif -%}
  {%- if item.variant.inventory_management == 'shopify' -%}
    {%- assign is_synced = true -%}
  {%- endif -%}
  {%- unless is_synced -%}
    {%- assign needs_vendedor = true -%}
    {%- break -%}
  {%- endunless -%}
  {%- if item.product.tags contains 'consultar-vendedor' -%}
    {%- assign needs_vendedor = true -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

<section class="ad-cart" data-section-id="{{ section.id }}" data-section-type="cart-template" data-needs-vendedor="{{ needs_vendedor }}">

  {%- if cart.item_count == 0 -%}
    <div class="ad-cart__empty">
      <h1 class="ad-display-lg">Sua sacola está vazia.</h1>
      <p class="ad-lead">Comece explorando o catálogo.</p>
      {%- render 'apple-button', variant: 'primary', href: '/collections/all', label: 'Ver produtos' -%}
    </div>
  {%- else -%}

    <header class="ad-cart__head">
      <h1 class="ad-cart__title ad-display-lg">Sua sacola</h1>
      <p class="ad-cart__count ad-caption">
        {%- if cart.item_count == 1 -%}1 item{%- else -%}{{ cart.item_count }} itens{%- endif -%}
      </p>
    </header>

    <form action="{{ routes.cart_url }}" method="post" novalidate class="ad-cart__form" data-cart-form>

      <div class="ad-cart__inner">

        <ul class="ad-cart__items" role="list">
          {%- for item in cart.items -%}
            <li class="ad-cart__item" data-cart-item data-line-key="{{ item.key }}">
              <a class="ad-cart__media" href="{{ item.url }}">
                {%- if item.image -%}
                  <img src="{{ item | img_url: '240x' }}" alt="{{ item.product.title | escape }}" width="120" height="120" loading="lazy">
                {%- endif -%}
              </a>
              <div class="ad-cart__text">
                <a class="ad-cart__name ad-body-strong" href="{{ item.url }}">{{ item.product.title }}</a>
                {%- if item.product.has_only_default_variant == false -%}
                  <p class="ad-cart__variant ad-caption">{{ item.variant.title }}</p>
                {%- endif -%}
                {%- if item.product.vendor != blank -%}
                  <p class="ad-cart__vendor ad-caption">{{ item.product.vendor }}</p>
                {%- endif -%}
              </div>
              <div class="ad-cart__qty">
                <label class="ad-caption" for="qty-{{ item.key }}">Qtd</label>
                <input id="qty-{{ item.key }}" type="number" name="updates[{{ item.key }}]" value="{{ item.quantity }}" min="0" class="ad-cart__qty-input" data-line-qty data-line-key="{{ item.key }}">
              </div>
              <div class="ad-cart__price">
                <p class="ad-body" data-line-price>{{ item.final_line_price | money }}</p>
                {%- if item.original_line_price > item.final_line_price -%}
                  <p class="ad-caption ad-cart__price-was"><s>{{ item.original_line_price | money }}</s></p>
                {%- endif -%}
              </div>
              <a class="ad-cart__remove ad-btn ad-btn--text-link" href="{{ routes.cart_change_url }}?line={{ forloop.index }}&amp;quantity=0" aria-label="Remover {{ item.product.title | escape }}">Remover</a>
            </li>
          {%- endfor -%}
        </ul>

        <aside class="ad-cart__summary">
          <div class="ad-cart__summary-inner">
            <h2 class="ad-cart__summary-title ad-tagline">Resumo do pedido</h2>

            <dl class="ad-cart__totals">
              <dt class="ad-body">Subtotal</dt>
              <dd class="ad-display-md" data-cart-subtotal>{{ cart.items_subtotal_price | money }}</dd>
            </dl>

            {%- if cart.cart_level_discount_applications.size > 0 -%}
              {%- for discount in cart.cart_level_discount_applications -%}
                <dl class="ad-cart__discount">
                  <dt class="ad-caption">Desconto: {{ discount.title }}</dt>
                  <dd class="ad-body" style="color: var(--ad-color-primary)">- {{ discount.total_allocated_amount | money }}</dd>
                </dl>
              {%- endfor -%}
            {%- endif -%}

            <p class="ad-fine-print ad-cart__shipping-note">
              Frete e impostos calculados no checkout.
            </p>

            <div class="ad-cart__actions">
              <button type="submit" name="checkout" class="ad-btn ad-btn--primary ad-btn--store-hero ad-cart__checkout" data-checkout-btn>
                Finalizar Compra
              </button>
              <a class="ad-btn ad-btn--text-link ad-cart__continue" href="/collections/all">Continuar Comprando</a>
              {%- if section.settings.whatsapp_url != blank -%}
                {%- render 'apple-button',
                    variant: 'secondary-pill',
                    href: section.settings.whatsapp_url,
                    label: 'Falar no WhatsApp' -%}
              {%- endif -%}
            </div>

            <p class="ad-micro-legal ad-cart__legal">
              {{ section.settings.legal_note | default: 'Pagamento via Mercado Pago. Pix, boleto e cartão de crédito.' }}
            </p>
          </div>
        </aside>

      </div>

      {%- if cart.note != blank -%}
        <textarea name="note" hidden>{{ cart.note }}</textarea>
      {%- endif -%}

    </form>

  {%- endif -%}

</section>

{%- comment -%} ───────── Vendedora Modal — abre SEMPRE no Finalizar Compra ─────────
  Conteúdo do modal varia conforme needs_vendedor:
  - needs_vendedor=false (todos items sincronizados Tiny/Olist):
      título "Como você quer finalizar?" + botão verde "Finalizar aqui no site"
      + divider "ou consulte uma vendedora" + grid vendedoras
  - needs_vendedor=true (pelo menos 1 não sincronizado):
      título "Escolha seu vendedor" + grid vendedoras (sem botão verde, sem divider)
{%- endcomment -%}
<div class="cv-cart-modal-backdrop" id="cvCartBackdrop"></div>
<div class="cv-cart-modal" id="cvCartModal" role="dialog" aria-modal="true" aria-label="Finalizar pedido">
  <div class="cv-cart-card">
    <button class="cv-cart-close" id="cvCartClose" type="button" aria-label="Fechar">&times;</button>

    {%- if needs_vendedor -%}
      <h3 class="cv-cart-title">Escolha seu vendedor para finalizar</h3>
      <p class="cv-cart-sub">Há itens no seu pedido que precisam de confirmação manual de estoque. Selecione uma vendedora abaixo:</p>
    {%- else -%}
      <h3 class="cv-cart-title">Como você quer finalizar?</h3>
      <p class="cv-cart-sub">Você pode pagar agora pelo site ou conversar com uma vendedora para confirmar antes.</p>

      {%- comment -%} Primary CTA — só aparece quando TODOS items são sincronizados {%- endcomment -%}
      <button class="cv-cart-finalize" type="button" id="cvCartFinalize">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
        Finalizar compra aqui no site
      </button>

      <div class="cv-cart-divider">
        <span>ou consulte uma vendedora</span>
      </div>
    {%- endif -%}

    <div class="cv-cart-grid">
      <div class="cv-cart-seller">
        <img src="https://cdn.shopify.com/s/files/1/0795/7970/9731/files/2_f8f1d6dd-6be0-458e-b768-67e11436f89c.png?v=1759774645" alt="Suellen" loading="lazy">
        <div class="cv-cart-seller-name">Vendedora Suellen</div>
        <button class="cv-cart-btn" type="button" data-phone="5562985020940">Enviar pedido</button>
      </div>
      <div class="cv-cart-seller">
        <img src="https://cdn.shopify.com/s/files/1/0795/7970/9731/files/1_ed43e8b6-1de1-411d-b887-03f7e0ffac8f.png?v=1759774644" alt="Bruna" loading="lazy">
        <div class="cv-cart-seller-name">Vendedora Bruna</div>
        <button class="cv-cart-btn" type="button" data-phone="5562996909084">Enviar pedido</button>
      </div>
      <div class="cv-cart-seller">
        <img src="https://cdn.shopify.com/s/files/1/0853/9773/3650/files/SUPORTE.png?v=1760072425" alt="Fellipe" loading="lazy">
        <div class="cv-cart-seller-name">Vendedor Fellipe</div>
        <button class="cv-cart-btn" type="button" data-phone="5562991902661">Enviar pedido</button>
      </div>
    </div>
  </div>
</div>

