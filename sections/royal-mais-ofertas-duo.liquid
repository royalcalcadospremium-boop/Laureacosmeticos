              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    {% endif %}
  </div>

  <!-- MODAL QUICK BUY (collection-style) -->
  <div id="nb-qb-{{ section.id }}" onclick="if(event.target===this){this.classList.remove('nb-open');document.body.style.overflow=''}">
    <div id="nb-qb-content-{{ section.id }}"></div>
  </div>


  <script>
    (function(){
      var root = document.getElementById('royal-tabs-cards-{{ section.id }}');
      if(!root) return;

      /* Move o modal para o body para escapar do isolation:isolate da seção */
      var _qbModalEl = document.getElementById('nb-qb-{{ section.id }}');
      if(_qbModalEl && _qbModalEl.parentNode !== document.body) {
        document.body.appendChild(_qbModalEl);
      }

      /* Tabs + Ver mais (dinâmico) */
      var tabButtons = root.querySelectorAll('.tabbtn[data-tab]');
      var panels = root.querySelectorAll('.panel[data-panel]');
      var viewMore = root.querySelector('[data-view-more]');

      function setViewMoreUrlFromBtn(btn){
        if(!viewMore) return;
        var url = (btn && btn.getAttribute) ? btn.getAttribute('data-coll-url') : '';
        if(url) viewMore.setAttribute('href', url);
      }

      function setActive(id){
        var activeBtn = null;

        for(var i=0;i<tabButtons.length;i++){
          var isOn = tabButtons[i].getAttribute('data-tab') === id;
          tabButtons[i].setAttribute('aria-selected', isOn ? 'true' : 'false');
          if(isOn) activeBtn = tabButtons[i];
        }
        for(var j=0;j<panels.length;j++){
          panels[j].classList.toggle('is-active', panels[j].getAttribute('data-panel') === id);
        }

        setViewMoreUrlFromBtn(activeBtn);
      }

      for(var k=0;k<tabButtons.length;k++){
        (function(btn){
          btn.addEventListener('click', function(){
            setActive(btn.getAttribute('data-tab'));
          });
        })(tabButtons[k]);
      }

      /* Se for fallback (sem data-tab), ainda assim garante href correto */
      if(viewMore && (!tabButtons || tabButtons.length === 0)){
        var fallbackBtn = root.querySelector('.tabbtn[data-coll-url]');
        if(fallbackBtn) setViewMoreUrlFromBtn(fallbackBtn);
      }else if(viewMore && tabButtons && tabButtons.length){
        setViewMoreUrlFromBtn(tabButtons[0]);
      }

      function fire(name, detail){
        try { document.dispatchEvent(new CustomEvent(name, { bubbles:true, detail: detail || {} })); } catch(e){}
        try { window.dispatchEvent(new CustomEvent(name, { bubbles:true, detail: detail || {} })); } catch(e){}
      }

      function tryOpenDrawerByTheme(){
        try { if(window.RoyalCartDrawer && typeof window.RoyalCartDrawer.open === 'function') { window.RoyalCartDrawer.open(); return true; } } catch(e){}
        try { if(window.cartDrawer && typeof window.cartDrawer.open === 'function') { window.cartDrawer.open(); return true; } } catch(e){}
        try { if(window.theme && window.theme.CartDrawer && typeof window.theme.CartDrawer.open === 'function') { window.theme.CartDrawer.open(); return true; } } catch(e){}
        try { if(window.Shopify && window.Shopify.theme && window.Shopify.theme.cartDrawer && typeof window.Shopify.theme.cartDrawer.open === 'function') { window.Shopify.theme.cartDrawer.open(); return true; } } catch(e){}
        return false;
      }

      function tryOpenDrawerByClick(){
        var selectors = [
          '[data-action="open-drawer"][aria-controls*="cart"]',
          '[data-action="open-drawer"][aria-controls*="mini"]',
          '[data-drawer-trigger*="cart"]',
          'button[aria-controls*="cart-drawer"]',
          'a[href="#cart-drawer"]',
          'button[name="open-cart"]',
          '.header__cart, .site-header__cart, .cart-toggle, .header__icon--cart'
        ];
        for(var i=0;i<selectors.length;i++){
          var el = document.querySelector(selectors[i]);
          if(el){
            try { el.click(); return true; } catch(e){}
          }
        }
        return false;
      }

      function openCartDrawer(){
        fire('cart:refresh');
        fire('cart:updated');
        fire('cart:open');
        fire('product:added');
        if(tryOpenDrawerByTheme()) return;
        tryOpenDrawerByClick();
      }

      /* Clique no card → navega */
      var INTERACTIVE = 'button, a, input, select, textarea, label, [data-rc-open-modal], [data-rc-add-single], [data-rcm-close], [data-rcm-add]';

      var _pointerStartX = 0;
      var _pointerStartY = 0;
      var _isDragging = false;

      root.addEventListener('pointerdown', function(e){
        _pointerStartX = e.clientX;
        _pointerStartY = e.clientY;
        _isDragging = false;
      }, { passive: true });

      root.addEventListener('pointermove', function(e){
        var dx = Math.abs(e.clientX - _pointerStartX);
        var dy = Math.abs(e.clientY - _pointerStartY);
        if(dx > 6 || dy > 6) _isDragging = true;
      }, { passive: true });

      /* Setinhas de navegacao (desktop) + drag horizontal manual (mobile) */
      root.querySelectorAll('.viewport').forEach(function(vp){
        var track = vp.querySelector('.track');
        if (!track) return;
        function stepPx(){
          var firstSlide = track.querySelector('.slide');
          if (!firstSlide) return 320;
          var cs = window.getComputedStyle(track);
          var gap = parseFloat(cs.columnGap || cs.gap || '14') || 14;
          return firstSlide.offsetWidth + gap;
        }
        var prevBtn = vp.querySelector('.rc-nav--prev');
        var nextBtn = vp.querySelector('.rc-nav--next');
        if (prevBtn) prevBtn.addEventListener('click', function(e){
          e.stopPropagation();
          track.scrollBy({ left: -stepPx() * 2, behavior: 'smooth' });
        });
        if (nextBtn) nextBtn.addEventListener('click', function(e){
          e.stopPropagation();
          track.scrollBy({ left: stepPx() * 2, behavior: 'smooth' });
        });
        function updateNav(){
          var max = track.scrollWidth - track.clientWidth - 2;
          if (prevBtn) prevBtn.style.opacity = track.scrollLeft <= 2 ? '0.4' : '1';
          if (nextBtn) nextBtn.style.opacity = track.scrollLeft >= max ? '0.4' : '1';
        }
        track.addEventListener('scroll', updateNav, { passive: true });
        updateNav();

        /* Drag horizontal manual (mobile/touch) — detecta direcao no 1o movimento:
           - HORIZONTAL: scrolla o track conforme o dedo (continuo, sem pulo)
           - VERTICAL: nao previne — pagina rola normal, card NAO samba */
        var tStartX = 0, tStartY = 0, tScrollStart = 0, tAxis = null;
        track.addEventListener('touchstart', function(e){
          if (!e.touches || !e.touches.length) return;
          tStartX = e.touches[0].clientX;
          tStartY = e.touches[0].clientY;
          tScrollStart = track.scrollLeft;
          tAxis = null;
        }, { passive: true });
        track.addEventListener('touchmove', function(e){
          if (!e.touches || !e.touches.length) return;
          var dx = e.touches[0].clientX - tStartX;
          var dy = e.touches[0].clientY - tStartY;
          if (tAxis === null) {
            if (Math.abs(dx) > 8 && Math.abs(dx) > Math.abs(dy) * 1.3) {
              tAxis = 'x';
              track.classList.add('rcd-dragging'); // desativa snap durante drag
            } else if (Math.abs(dy) > 8) {
              tAxis = 'y';
            }
          }
          if (tAxis === 'x') {
            track.scrollLeft = tScrollStart - dx;
            if (e.cancelable) e.preventDefault();
          }
          /* tAxis === 'y' ou null: deixa o navegador rolar a pagina normalmente */
        }, { passive: false });
        function endTouch(){
          tAxis = null;
          track.classList.remove('rcd-dragging');
        }
        track.addEventListener('touchend',    endTouch, { passive: true });
        track.addEventListener('touchcancel', endTouch, { passive: true });
      });

      root.addEventListener('click', function(e){
        if(_isDragging) return;

        var card = e.target.closest('.card[data-product-url]');
        if(!card) return;

        if(e.target.closest(INTERACTIVE)) return;

        var url = card.getAttribute('data-product-url');
        if(!url) return;

        window.location.href = url;
      });

      /* ===== MODAL QUICK BUY (collection-style) ===== */
      var qbModal = document.getElementById('nb-qb-{{ section.id }}');
      var qbContent = document.getElementById('nb-qb-content-{{ section.id }}');
      var qbSelectedVid = null;

      function qbClose(){
        if(qbModal) qbModal.classList.remove('nb-open');
        document.body.style.overflow = '';
        qbSelectedVid = null;
      }

      function qbOpen(productId){
        var script = document.getElementById('rcp-{{ section.id }}-' + productId);
        if(!script || !qbContent) return;
        var data;
        try { data = JSON.parse(script.textContent || script.innerText); } catch(e){ return; }
        qbSelectedVid = null;

        var variants = Array.isArray(data.variants) ? data.variants : [];
        var isDefault = variants.length === 1 && (variants[0].title === 'Default Title' || variants[0].title === 'Default');

        if(isDefault){
          /* produto sem variação: adiciona direto */
          var vid = variants[0].id;
          fetch('/cart/add.js', {
            method:'POST',
            headers:{'Content-Type':'application/json'},
            body: JSON.stringify({ items:[{ id: Number(vid), quantity:1 }] })
          }).then(function(r){ if(!r.ok) throw new Error(); return r.json(); })
            .then(function(){ openCartDrawer(); })
            .catch(function(){ alert('Erro ao adicionar. Tente novamente.'); });
          return;
        }

        var variantsHtml = variants.map(function(v){
          var avail = !!v.available;
          return '<button class="nb-sz-btn" data-vid="' + v.id + '"' +
            (!avail ? ' disabled' : '') +
            ' style="padding:12px;border:1px solid #ddd;border-radius:4px;background:' + (avail?'#fff':'#f5f5f5') +
            ';cursor:' + (avail?'pointer':'not-allowed') +
            ';font-weight:700;font-size:13px;opacity:' + (avail?'1':'0.4') + '">' +
            v.title + '</button>';
        }).join('');

        qbContent.innerHTML =
          '<button onclick="(function(m){m.classList.remove(\'nb-open\');document.body.style.overflow=\'\';})(document.getElementById(\'nb-qb-{{ section.id }}\'))" style="position:absolute;top:15px;right:15px;border:none;background:none;font-size:24px;cursor:pointer;">&times;</button>' +
          '<div style="display:flex;gap:15px;align-items:center;margin-bottom:20px;">' +
            (data.image ? '<img src="' + data.image + '" style="width:70px;height:70px;object-fit:cover;border-radius:8px;">' : '') +
            '<div><h4 style="margin:0;font-size:14px;">' + data.title + '</h4>' +
            (data.price ? '<div style="font-weight:800;font-size:16px;">' + data.price + '</div>' : '') +
            '</div></div>' +
          '<div style="font-size:12px;font-weight:800;margin-bottom:10px;">ESCOLHA O TAMANHO:</div>' +
          '<div class="nb-sz-grid" style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:20px;">' + variantsHtml + '</div>' +
          '<button id="nb-add-btn-{{ section.id }}" disabled style="width:100%;padding:16px;background:#111;color:#fff;border:none;border-radius:4px;font-weight:800;cursor:pointer;opacity:0.5;">ADICIONAR À SACOLA</button>';

        /* Selecionar tamanho */
        qbContent.querySelector('.nb-sz-grid').addEventListener('click', function(e){
          var btn = e.target.closest('.nb-sz-btn');
          if(!btn || btn.disabled) return;
          qbContent.querySelectorAll('.nb-sz-btn').forEach(function(b){ b.style.borderColor='#ddd'; });
          btn.style.borderColor = '#111';
          qbSelectedVid = btn.getAttribute('data-vid');
          var addBtn = document.getElementById('nb-add-btn-{{ section.id }}');
          if(addBtn){ addBtn.disabled=false; addBtn.style.opacity='1'; }
        });

        /* Adicionar à sacola */
        var addBtn = document.getElementById('nb-add-btn-{{ section.id }}');
        if(addBtn){
          addBtn.addEventListener('click', function(){
            if(!qbSelectedVid) return;
            addBtn.textContent = 'ADICIONANDO...';
            addBtn.disabled = true;
            fetch('/cart/add.js', {
              method:'POST',
              headers:{'Content-Type':'application/json'},
              body: JSON.stringify({ items:[{ id: Number(qbSelectedVid), quantity:1 }] })
            }).then(function(r){ if(!r.ok) throw new Error(); return r.json(); })
              .then(function(){ qbClose(); openCartDrawer(); })
              .catch(function(){
                addBtn.textContent = 'ADICIONAR À SACOLA';
                addBtn.disabled = false;
                addBtn.style.opacity = '1';
              });
          });
        }

        qbModal.classList.add('nb-open');
        document.body.style.overflow = 'hidden';
      }

      if(qbModal){
        document.addEventListener('keydown', function(e){
          if(e.key==='Escape' && qbModal.classList.contains('nb-open')) qbClose();
        });
      }

      /* Clique na sacola → abre modal */
      root.addEventListener('click', function(e){
        var btn = e.target.closest('[data-rc-open-modal]');
        if(!btn) return;
        e.preventDefault(); e.stopPropagation();
        var pid = btn.getAttribute('data-product-id');
        if(pid) qbOpen(pid);
      }, true);

      /* Produto de 1 variante → abre modal (mesmo comportamento) */
      root.addEventListener('click', function(e){
        var btn = e.target.closest('[data-rc-add-single]');
        if(!btn) return;
        e.preventDefault(); e.stopPropagation();
        /* Busca o card pai para pegar o product-id e abrir o modal */
        var card = btn.closest('.card[data-product-id]');
        if(card) qbOpen(card.getAttribute('data-product-id'));
      }, true);

    })();
  </script>

</section>

