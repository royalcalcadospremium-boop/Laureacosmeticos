                    </div>

                    <div class="content" style="padding: 8px 10px;">
                      <a href="{{ p.url }}" class="title" style="text-decoration:none;display:block;">{{ p.title }}</a>
                      {%- render 'rc-tier-boxes', product: p -%}
                    </div>

                    <script type="application/json" id="rcp-{{ section.id }}-{{ p.id }}">
                    {
                      "id": {{ p.id }},
                      "title": {{ p.title | json }},
                      "url": {{ p.url | json }},
                      "price": {{ price | money | json }},
                      "image": {% if featured %}{{ featured | img_url: '300x' | json }}{% else %}""{% endif %},
                      "variants": [
                        {%- for vv in p.variants -%}
                          {
                            "id": {{ vv.id }},
                            "available": {{ vv.available | json }},
                            "title": {{ vv.title | json }},
                            "opt1": {{ vv.option1 | json }},
                            "opt2": {{ vv.option2 | json }},
                            "opt3": {{ vv.option3 | json }},
                            "inventory_management": {{ vv.inventory_management | json }},
                            "inventory_policy": {{ vv.inventory_policy | json }},
                            "inventory_quantity": {{ vv.inventory_quantity | json }}
                          }{% unless forloop.last %},{% endunless %}
                        {%- endfor -%}
                      ]
                    }
                    </script>

                  </div>
                </div>
              {% endfor %}
            {% else %}
              {% for i in (1..limit_count) %}
                <div class="slide">
                  <div class="card">
                    <div class="toprow">
                      <span class="badge">-28%</span>
                      <div class="imgwrap">{{ 'product-1' | placeholder_svg_tag }}</div>
                    </div>

                    <div class="content">
                      <div class="title">Produto exemplo com nome grande (preview)</div>
                      <div class="prices">
                        <div class="compare">R$ 387,00</div>
                        <div class="now">R$ 279,00</div>
                        <div class="installments">ou até 6× de R$ 46,50</div>
                      </div>
                      <div class="buyform">
                        <button class="buybtn" type="button" disabled>Comprar</button>
                      </div>
                    </div>

                  </div>
                </div>
              {% endfor %}
            {% endif %}
          </div>
        </div>
      </div>
    {% else %}
      {% for b in tabs %}
        {% assign coll = b.settings.collection %}
        <div class="panel {% if forloop.first %}is-active{% endif %}" data-panel="{{ b.id }}">
          <div class="viewport">
            <button class="rc-nav rc-nav--prev" type="button" aria-label="Anterior">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <button class="rc-nav rc-nav--next" type="button" aria-label="Proximo">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
            <div class="track">
              {% if coll and coll.products_count > 0 %}
                {% for product in coll.products limit: limit_count %}
                  {% liquid
                    assign p = product

                    assign has_variants = false
                    if p.variants.size > 1
                      assign has_variants = true
                    endif

                    assign featured = p.featured_image
                    assign img_url = ''
                    if featured
                      assign img_url = featured | img_url: '600x'
                    endif

                    assign compare = p.compare_at_price
                    assign price = p.price

                    assign has_compare = false
                    if compare and compare > price
                      assign has_compare = true
                    endif

                    assign off = 0
                    if has_compare
                      assign off = compare | minus: price | times: 100 | divided_by: compare
                    endif

                    assign first_av = p.selected_or_first_available_variant
                    if first_av == nil
                      assign first_av = p.variants.first
                    endif
                  %}

                  <div class="slide">
                    <div class="card rc-card"
                      data-product-id="{{ p.id }}"
                      data-has-variants="{% if has_variants %}true{% else %}false{% endif %}"
                      data-product-url="{{ p.url }}">
                      <div class="toprow">
                        {% if has_compare and off > 0 %}
                          <span class="badge">-{{ off }}%</span>
                        {% endif %}

                        <a class="imgwrap" href="{{ p.url }}">
                          {% if featured %}
                            {%- render 'rc-product-image', product: p, size: '600x', alt: featured.alt -%}
                          {% else %}
                            {{ 'product-1' | placeholder_svg_tag }}
                          {% endif %}
                        </a>

                        <button class="nb-bag" type="button"
                          {% if has_variants %}data-rc-open-modal data-product-id="{{ p.id }}"{% else %}data-rc-add-single data-variant-id="{{ first_av.id }}"{% endif %}>
                          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="2">
                            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                            <line x1="3" y1="6" x2="21" y2="6"/>
                            <path d="M16 10a4 4 0 0 1-8 0"/>
                          </svg>
                        </button>
                      </div>

                      <div class="content" style="padding: 8px 10px;">
                        <a href="{{ p.url }}" class="title" style="text-decoration:none;display:block;">{{ p.title }}</a>
                        {%- render 'rc-tier-boxes', product: p -%}
                      </div>

                      <script type="application/json" id="rcp-{{ section.id }}-{{ p.id }}">
                      {
                        "id": {{ p.id }},
                        "title": {{ p.title | json }},
                        "url": {{ p.url | json }},
                        "image": {% if featured %}{{ featured | img_url: '300x' | json }}{% else %}""{% endif %},
                        "variants": [
                          {%- for vv in p.variants -%}
                            {
                              "id": {{ vv.id }},
                              "available": {{ vv.available | json }},
                              "title": {{ vv.title | json }},
                              "opt1": {{ vv.option1 | json }},
                              "opt2": {{ vv.option2 | json }},
                              "opt3": {{ vv.option3 | json }},
                              "inventory_management": {{ vv.inventory_management | json }},
                              "inventory_policy": {{ vv.inventory_policy | json }},
                              "inventory_quantity": {{ vv.inventory_quantity | json }}
                            }{% unless forloop.last %},{% endunless %}
                          {%- endfor -%}
                        ]
                      }
                      </script>

                    </div>
                  </div>
                {% endfor %}
              {% else %}
                {% for i in (1..limit_count) %}
                  <div class="slide">
                    <div class="card">
                      <div class="toprow">
                        <span class="badge">-28%</span>
                        <div class="imgwrap">{{ 'product-1' | placeholder_svg_tag }}</div>
                      </div>

                      <div class="content">
                        <div class="title">{{ b.settings.label }} — Produto exemplo (preview)</div>
                        <div class="prices">
                          <div class="compare">R$ 387,00</div>
                          <div class="now">R$ 279,00</div>
                          <div class="installments">ou até 6× de R$ 46,50</div>
                        </div>
                        <div class="buyform">
                          <button class="buybtn" type="button" disabled>Comprar</button>
