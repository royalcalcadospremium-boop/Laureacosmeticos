{% comment %} 
royal-mais-ofertas-duo.liquid
Royal • Tabs Cards (v1.4.9a) — VER MAIS + SEM CORAÇÃO + OPACIDADE SÓ DO FUNDO DO DESCONTO
- ✅ “Ver mais” no canto superior direito (link dinâmico para a coleção da aba ativa)
- ✅ Remove ícone de coração dos cards
- ✅ Opacidade controla SOMENTE o FUNDO do badge (texto/número fica 100%)
- ✅ Mantém: clique no card navega pro produto, modal premium único, add single abre drawer, full-bleed foto
FIX:
- ✅ Schema compatível: products_count agora aceita valores maiores (evita FileSaveError)
IMPORTANTE: peek_mobile é range inteiro (o cálculo usa times: 0.01).
{% endcomment %}

{%- render 'rc-tier-card-assets' -%}

<section id="royal-tabs-cards-{{ section.id }}" class="royal-tabs-cards">

  {% liquid
    assign tabs = section.blocks | where: 'type', 'tab'
    assign fallback_tab = false
    if tabs.size == 0
      assign fallback_tab = true
    endif

    assign initial_view_more_url = ''
    if fallback_tab
      if section.settings.collection_fallback
        assign initial_view_more_url = section.settings.collection_fallback.url
      endif
    else
      assign first_tab = tabs.first
      if first_tab and first_tab.settings.collection
        assign initial_view_more_url = first_tab.settings.collection.url
      endif
    endif
  %}

  <style>
    #royal-tabs-cards-{{ section.id }}{
      --bg: {{ section.settings.bg | default: '#FAD6E6' }};
      --card: {{ section.settings.card_bg | default: '#FFEAF3' }};
      --radius: {{ section.settings.card_radius | default: 34 }}px;
      --gap: {{ section.settings.gap | default: 18 }}px;

      --pill-bg: {{ section.settings.pill_bg | default: '#E7E7E7' }};
      --pill-active: {{ section.settings.pill_active_bg | default: '#F01980' }};
      --pill-text: {{ section.settings.pill_text | default: '#2B2B2B' }};
      --pill-active-text: {{ section.settings.pill_active_text | default: '#FFFFFF' }};

      /* botão verde (card + modal) */
      --btn: {{ section.settings.btn_bg | default: '#B7F25A' }};
      --btn-text: {{ section.settings.btn_text | default: '#16310D' }};

      /* Badge */
      --badge: {{ section.settings.badge_bg | default: '#B7F25A' }};
      --badge-text: {{ section.settings.badge_text | default: '#16310D' }};
      --badge-bg-opacity: {{ section.settings.badge_opacity | default: 100 | times: 0.01 }};

      --title: {{ section.settings.title_color | default: '#1F2A44' }};
      --muted: {{ section.settings.muted_color | default: '#6B7280' }};
      --price: {{ section.settings.price_color | default: '#1F2A44' }};
      --compare: {{ section.settings.compare_color | default: '#F01980' }};

      /* Disponibilidade (círculo) */
      --avail: {{ section.settings.avail_border | default: '#A7F3D0' }};
      --unavail: {{ section.settings.unavail_border | default: '#FECACA' }};

      /* Quantidade por tela */
      --per-d: {{ section.settings.per_view_desktop | default: 4 }};
      --per-m: {{ section.settings.per_view_mobile | default: '2' }};
      --peek-m: {{ section.settings.peek_mobile | default: 20 | times: 0.01 }};

      /* Altura do card separada */
      --card-h-d: {{ section.settings.card_height_desktop | default: 520 }}px;
      --card-h-m: {{ section.settings.card_height_mobile  | default: 520 }}px;

      background: var(--bg);
      position: relative;
      z-index: 3;
      isolation: isolate;
      padding: {{ section.settings.section_padding_y | default: 26 }}px 0;
    }

    /* Container */
    #royal-tabs-cards-{{ section.id }} .container{
      width: 100%;
      max-width: 1480px;
      margin-left: auto;
      margin-right: auto;
      padding-left: var(--mobile-container-gutter, 20px);
      padding-right: var(--mobile-container-gutter, 20px);
    }
    @media (min-width: 641px) and (max-width: 1023px){
      #royal-tabs-cards-{{ section.id }} .container{
        padding-left: var(--tablet-container-gutter, 28px);
        padding-right: var(--tablet-container-gutter, 28px);
      }
    }
    @media (min-width: 1024px){
      #royal-tabs-cards-{{ section.id }} .container{
        padding-left: var(--desktop-container-gutter, 36px);
        padding-right: var(--desktop-container-gutter, 36px);
      }
    }

    /* Header (tabs + ver mais) */
    #royal-tabs-cards-{{ section.id }} .headbar{
      display:flex;
      align-items:center;
      justify-content: space-between;
      gap: 14px;
      padding: 6px 0 10px;
    }
    #royal-tabs-cards-{{ section.id }} .viewmore{
      flex: 0 0 auto;
      display:inline-flex;
      align-items:center;
      gap: 8px;
      text-decoration:none;
      font-weight: 800;
      font-size: 14px;
      line-height: 1;
      color: {{ section.settings.view_more_color | default: '#1F2A44' }};
      padding: 10px 14px;
      border-radius: 999px;
      background: {{ section.settings.view_more_bg | default: '#FFFFFF' }};
      border: 1px solid rgba(31,42,68,.10);
      transition: transform .12s ease, filter .12s ease, opacity .12s ease;
      white-space: nowrap;
    }
    #royal-tabs-cards-{{ section.id }} .viewmore:hover{ filter: brightness(.98); transform: translateY(-1px); }
    #royal-tabs-cards-{{ section.id }} .viewmore:active{ transform: scale(.99); }
    #royal-tabs-cards-{{ section.id }} .viewmore svg{
      width: 16px; height: 16px;
      fill: none;
      stroke: currentColor;
      stroke-width: 2.2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }
    @media (max-width: 640px){
      #royal-tabs-cards-{{ section.id }} .headbar{ gap: 10px; }
      #royal-tabs-cards-{{ section.id }} .viewmore{ padding: 9px 12px; font-size: 13px; }
    }

    /* Tabs (pílulas) */
    #royal-tabs-cards-{{ section.id }} .tabsbar{
      display:flex;
      gap:12px;
      align-items:center;
      justify-content:flex-start;
      overflow:auto;
      -webkit-overflow-scrolling:touch;
      scrollbar-width:none;
      padding: 0;
      flex: 1 1 auto;
      min-width: 0;
    }
    #royal-tabs-cards-{{ section.id }} .tabsbar::-webkit-scrollbar{ display:none; }
    #royal-tabs-cards-{{ section.id }} .tabbtn{
      flex:0 0 auto;
      border:0;
      background: var(--pill-bg);
      color: var(--pill-text);
      border-radius: 999px;
      padding: 10px 16px;
      font-weight: 800;
      font-size: 14px;
      line-height: 1;
      cursor:pointer;
      white-space: nowrap;
      transition: transform .12s ease, background .12s ease, color .12s ease;
    }
    #royal-tabs-cards-{{ section.id }} .tabbtn[aria-selected="true"]{
      background: var(--pill-active);
      color: var(--pill-active-text);
    }
    #royal-tabs-cards-{{ section.id }} .tabbtn:active{ transform: scale(.98); }

    /* Carrossel */
    #royal-tabs-cards-{{ section.id }} .viewport{ position:relative; overflow:hidden; }
    /* Setinhas de navegacao (desktop) */
    #royal-tabs-cards-{{ section.id }} .rc-nav{
      position: absolute; top: 50%; transform: translateY(-50%);
      z-index: 5;
      width: 38px; height: 38px;
      border-radius: 50%;
      background: #fff;
      border: 1px solid #e5e5e5;
      box-shadow: 0 4px 14px rgba(0,0,0,0.10);
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      color: #222;
      transition: background 0.15s ease, transform 0.15s ease;
    }
    #royal-tabs-cards-{{ section.id }} .rc-nav:hover{ background: #f7f7f7; transform: translateY(-50%) scale(1.05); }
    #royal-tabs-cards-{{ section.id }} .rc-nav--prev{ left: 4px; }
    #royal-tabs-cards-{{ section.id }} .rc-nav--next{ right: 4px; }
    /* Mobile: ESCONDE as setinhas (so swipe horizontal touch) */
    @media (max-width: 767px){
      #royal-tabs-cards-{{ section.id }} .rc-nav{ display: none; }
    }
    #royal-tabs-cards-{{ section.id }} .track{
      display:flex; gap:var(--gap);
      overflow-x:auto; overflow-y:hidden;
      scrollbar-width:none; -ms-overflow-style:none;
      padding-bottom: 6px;
      /* pan-y: dedo no card so passa scroll VERTICAL pra pagina (sem sambar).
         JS controla o drag horizontal continuo (sem snap-type que cria "pulo"). */
      touch-action: pan-y;
      overscroll-behavior: contain;
      scroll-behavior: smooth;
      /* scroll-snap-type so quando NAO esta arrastando (controlado via JS) */
      scroll-snap-type: x proximity;
    }
    #royal-tabs-cards-{{ section.id }} .track.rcd-dragging{
      scroll-snap-type: none !important;
      scroll-behavior: auto !important;
    }
    #royal-tabs-cards-{{ section.id }} .track::-webkit-scrollbar{ display:none; }

    #royal-tabs-cards-{{ section.id }} .panel{ display:none; }
    #royal-tabs-cards-{{ section.id }} .panel.is-active{ display:block; }

    #royal-tabs-cards-{{ section.id }} .slide{
      position:relative;
      flex:0 0 calc((100% - (var(--gap) * (var(--per-d) - 1))) / var(--per-d));
      min-width: calc((100% - (var(--gap) * (var(--per-d) - 1))) / var(--per-d));
      scroll-snap-align:start;
    }

    /* Mobile com peek */
    @media (max-width: 989px){
      #royal-tabs-cards-{{ section.id }}{ --gap: 14px; }
      #royal-tabs-cards-{{ section.id }} .slide{
        flex-basis: calc((100% - (var(--gap) * (var(--per-m) - 1))) / (var(--per-m) + var(--peek-m)));
        min-width:  calc((100% - (var(--gap) * (var(--per-m) - 1))) / (var(--per-m) + var(--peek-m)));
      }
    }

    /* CARD */
    #royal-tabs-cards-{{ section.id }} .card{
      position: relative;
      background: var(--card);
      border-radius: var(--radius);
      padding: 0;
      box-shadow: 0 18px 40px rgba(31, 42, 68, .12);
      height: var(--card-h-d);
      display:flex;
      flex-direction:column;
      overflow:hidden;
      isolation:isolate;
      cursor: pointer;
    }
    @media (max-width: 989px){
      #royal-tabs-cards-{{ section.id }} .card{ height: var(--card-h-m); }
    }

    /* Topo QUADRADO */
    #royal-tabs-cards-{{ section.id }} .toprow{
      position:relative;
      width: 100%;
      aspect-ratio: 1 / 1;
      background: transparent;
      overflow:hidden;
      flex: 0 0 auto;
    }

    /* Badge %OFF (opacidade só do FUNDO via ::before) */
    #royal-tabs-cards-{{ section.id }} .badge{
      position:absolute;
      left: 10px;
      top: 10px;
      color: var(--badge-text);
      border-radius: 999px;
      padding: 6px 10px;
      font-weight: 700;
      font-size: 12px;
      line-height: 1;
      z-index: 3;
      display:inline-block;
      isolation:isolate;
    }
    #royal-tabs-cards-{{ section.id }} .badge::before{
      content:'';
      position:absolute;
      inset:0;
      background: var(--badge);
      opacity: var(--badge-bg-opacity);
      border-radius: inherit;
      z-index: -1;
    }

    /* ✅ Imagem FULL-BLEED */
    #royal-tabs-cards-{{ section.id }} .imgwrap{
      position:absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      margin: 0;
      padding: 0;
      display:block;
    }
    #royal-tabs-cards-{{ section.id }} .imgwrap img{
      width: 100%;
      height: 100%;
      display:block;
      object-fit: cover;
      object-position: center;
      transform: none !important;
      will-change: auto;
    }
    #royal-tabs-cards-{{ section.id }} .imgwrap svg{
      width: 100%;
      height: 100%;
      display:block;
      transform: none !important;
    }

    /* Conteúdo */
    #royal-tabs-cards-{{ section.id }} .content{
      padding: 16px;
      display:flex;
      flex-direction:column;
      gap: 10px;
      flex: 1 1 auto;
      min-height: 0;
    }

    #royal-tabs-cards-{{ section.id }} .title{
      font-weight: 400;
      color: var(--title);
      font-size: 16px;
      line-height: 1.2;
      text-align:center;
      padding: 0 6px;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
      overflow: hidden;
      text-overflow: ellipsis;
      min-height: calc(2 * 1.2em);
    }

    #royal-tabs-cards-{{ section.id }} .prices{
      text-align:center;
      display:flex;
      flex-direction:column;
      gap: 4px;
      padding: 0 6px;
      margin: 0;
    }
    #royal-tabs-cards-{{ section.id }} .compare{
      color: var(--compare);
      font-weight: 400;
      font-size: 12px;
      text-decoration: line-through;
      opacity: .95;
      min-height: 16px;
    }
    #royal-tabs-cards-{{ section.id }} .now{
      color: var(--price);
      font-weight: 500;
      font-size: 20px;
      letter-spacing: -0.2px;
    }
    #royal-tabs-cards-{{ section.id }} .installments{
      color: var(--muted);
      font-weight: 400;
      font-size: 12px;
      min-height: 16px;
    }

    /* Botão (card) */
    #royal-tabs-cards-{{ section.id }} .buyform{
      margin-top: auto;
      padding-top: 6px;
    }
    #royal-tabs-cards-{{ section.id }} .buybtn{
      width: 100%;
      border: 0;
      border-radius: 999px;
      background: var(--btn);
      color: var(--btn-text);
      padding: 14px 16px;
      font-weight: 700;
      font-size: 16px;
      display:flex;
      align-items:center;
      justify-content:center;
      gap: 10px;
      cursor:pointer;
      box-shadow: 0 10px 22px rgba(22, 49, 13, .15);
      transition: transform .12s ease, filter .12s ease, opacity .12s ease;
      text-decoration: none;
    }
    #royal-tabs-cards-{{ section.id }} .buybtn:hover{ filter: brightness(.98); transform: translateY(-1px); }
    #royal-tabs-cards-{{ section.id }} .buybtn:active{ transform: scale(.99); }
    #royal-tabs-cards-{{ section.id }} .buybtn svg{
      width: 18px; height: 18px;
      fill: none;
      stroke: var(--btn-text);
      stroke-width: 2.2;
    }
    #royal-tabs-cards-{{ section.id }} .buybtn:disabled{
      opacity:.6;
      cursor:not-allowed;
      transform:none;
      box-shadow:none;
    }

    /* =========================================
       MODAL PREMIUM (ÚNICO) — PADRÃO (rcm-*)
       ========================================= */
    #royal-tabs-cards-{{ section.id }} .rcm-overlay{
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,.48);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 999999;
      padding: 14px;
    }
    #royal-tabs-cards-{{ section.id }} .rcm-overlay.is-open{ display:flex; }

    #royal-tabs-cards-{{ section.id }} .rcm-modal{
      width: min(520px, 100%);
      background: #fff;
      border-radius: 22px;
      box-shadow: 0 20px 70px rgba(0,0,0,.25);
      overflow: hidden;
      border: 1px solid rgba(0,0,0,.08);
    }

    #royal-tabs-cards-{{ section.id }} .rcm-head{
      display:flex;
      align-items:center;
      gap: 12px;
      padding: 12px 12px;
      border-bottom: 1px solid rgba(0,0,0,.08);
    }
    #royal-tabs-cards-{{ section.id }} .rcm-thumb{
      width: 56px;
      height: 56px;
      border-radius: 14px;
      background: rgba(0,0,0,.03);
      overflow: hidden;
      flex: 0 0 auto;
      display:flex;
      align-items:center;
      justify-content:center;
    }
    #royal-tabs-cards-{{ section.id }} .rcm-thumb img{
      width:100%;
      height:100%;
      object-fit: cover;
      display:block;
    }
    #royal-tabs-cards-{{ section.id }} .rcm-titlewrap{ min-width: 0; flex: 1; }
    #royal-tabs-cards-{{ section.id }} .rcm-title{
      font-weight: 720;
      font-size: 15px;
      color: #111827;
      line-height: 1.15;
      margin: 0 0 2px;
      display:-webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow:hidden;
    }
    #royal-tabs-cards-{{ section.id }} .rcm-sub{
      font-weight: 450;
      font-size: 13px;
      color: #6B7280;
      margin: 0;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    #royal-tabs-cards-{{ section.id }} .rcm-close{
      width: 40px;
      height: 40px;
      border-radius: 999px;
      border: 1px solid rgba(0,0,0,.10);
      background: #fff;
      cursor: pointer;
      display:flex;
      align-items:center;
      justify-content:center;
      flex: 0 0 auto;
    }
    #royal-tabs-cards-{{ section.id }} .rcm-close svg{
      width: 18px; height: 18px;
      stroke: #222;
      stroke-width: 2.2;
      fill: none;
    }

    #royal-tabs-cards-{{ section.id }} .rcm-body{
      padding: 10px 12px 12px;
      overflow: hidden;
    }
    #royal-tabs-cards-{{ section.id }} .rcm-hint{
      font-size: 12.5px;
      color: #6B7280;
      font-weight: 450;
      margin: 0 0 10px;
    }

    #royal-tabs-cards-{{ section.id }} .rcm-grid{
      display:grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
    }

    #royal-tabs-cards-{{ section.id }} .rcm-row{
      border: 1px solid rgba(0,0,0,.10);
      border-radius: 14px;
      padding: 8px 8px;
      display:flex;
      align-items:center;
      justify-content: space-between;
      gap: 8px;
      min-height: 44px;
      background: #fff;
    }
    #royal-tabs-cards-{{ section.id }} .rcm-row.is-off{
      opacity: .45;
      pointer-events: none;
    }
    #royal-tabs-cards-{{ section.id }} .rcm-size{
      font-weight: 720;
      color: #111827;
      font-size: 13px;
      min-width: 0;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    #royal-tabs-cards-{{ section.id }} .rcm-stock{
      font-weight: 450;
      font-size: 11px;
      color: #6B7280;
      margin-top: 1px;
    }

    #royal-tabs-cards-{{ section.id }} .rcm-step{
      display:flex;
      align-items:center;
      gap: 6px;
      flex: 0 0 auto;
    }
    #royal-tabs-cards-{{ section.id }} .rcm-step button{
      width: 28px;
      height: 28px;
      border-radius: 10px;
      border: 1px solid rgba(0,0,0,.12);
      background: #fff;
      cursor:pointer;
      font-weight: 720;
      line-height: 1;
    }
    #royal-tabs-cards-{{ section.id }} .rcm-step button:disabled{
      opacity: .35;
      cursor:not-allowed;
    }
    #royal-tabs-cards-{{ section.id }} .rcm-step input{
      width: 34px;
      height: 28px;
      border-radius: 10px;
      border: 1px solid rgba(0,0,0,.12);
      text-align:center;
      font-weight: 720;
      font-size: 13px;
      outline: none;
      padding: 0;
    }

    #royal-tabs-cards-{{ section.id }} .rcm-foot{
      border-top: 1px solid rgba(0,0,0,.08);
      padding: 10px 12px 12px;
      display:flex;
      gap: 10px;
      align-items:center;
      justify-content: space-between;
    }
    #royal-tabs-cards-{{ section.id }} .rcm-total{
      font-size: 13px;
      color: #6B7280;
      font-weight: 450;
      white-space: nowrap;
    }
    #royal-tabs-cards-{{ section.id }} .rcm-add{
      flex: 1;
      background: var(--btn);
      border: 0;
      border-radius: 999px;
      height: 52px;
      display:flex;
      align-items:center;
      justify-content:center;
      gap: 10px;
      font-weight: 800;
      font-size: 17px;
      color: var(--btn-text);
      cursor:pointer;
      transition: transform .12s ease, filter .12s ease, opacity .12s ease;
    }
    #royal-tabs-cards-{{ section.id }} .rcm-add:hover{ filter: brightness(.97); transform: translateY(-1px); }
    #royal-tabs-cards-{{ section.id }} .rcm-add:disabled{ opacity:.55; cursor:not-allowed; transform:none; }

    @media (max-width: 520px){
      #royal-tabs-cards-{{ section.id }} .rcm-modal{ border-radius: 18px; }
      #royal-tabs-cards-{{ section.id }} .rcm-thumb{ width: 52px; height: 52px; border-radius: 13px; }
      #royal-tabs-cards-{{ section.id }} .rcm-title{ font-size: 14px; }
      #royal-tabs-cards-{{ section.id }} .rcm-grid{ gap: 7px; }
      #royal-tabs-cards-{{ section.id }} .rcm-row{ padding: 7px 7px; min-height: 42px; }
      #royal-tabs-cards-{{ section.id }} .rcm-step button{ width: 26px; height: 26px; border-radius: 9px; }
      #royal-tabs-cards-{{ section.id }} .rcm-step input{ width: 32px; height: 26px; border-radius: 9px; }
      #royal-tabs-cards-{{ section.id }} .rcm-add{ height: 50px; font-size: 16px; }
    }

    html.rcm-lock, body.rcm-lock{ overflow:hidden !important; height: 100% !important; }

    /* ===== CARD — IDÊNTICO AO COLLECTION-TEMPLATE ===== */
    #royal-tabs-cards-{{ section.id }} .card {
      background: #ffffff !important;
      border-radius: 6px !important;
      border: 1px solid #f0f0f0 !important;
      box-shadow: none !important;
      height: auto !important;
    }
    #royal-tabs-cards-{{ section.id }} .toprow {
      background: #f9f9f9 !important;
      border-radius: 0 !important;
      overflow: hidden !important;
    }
    #royal-tabs-cards-{{ section.id }} .imgwrap img {
      object-fit: contain !important;
    }
    #royal-tabs-cards-{{ section.id }} .badge {
      background: #1a1a1a !important;
      color: #fff !important;
      border-radius: 2px !important;
      padding: 3px 6px !important;
      font-size: 10px !important;
      font-weight: 700 !important;
      top: 8px !important;
      left: 8px !important;
    }
    #royal-tabs-cards-{{ section.id }} .badge::before { display: none !important; }
    #royal-tabs-cards-{{ section.id }} .nb-bag {
      position: absolute !important;
      bottom: 8px !important;
      right: 8px !important;
      background: #fff !important;
      border: none !important;
      border-radius: 50% !important;
      width: 34px !important;
      height: 34px !important;
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      box-shadow: 0 2px 8px rgba(0,0,0,0.12) !important;
      cursor: pointer !important;
      z-index: 3 !important;
    }
    #royal-tabs-cards-{{ section.id }} .content {
      padding: 12px !important;
      gap: 4px !important;
      flex: 0 0 auto !important;
      text-decoration: none !important;
    }
    #royal-tabs-cards-{{ section.id }} .title {
      font-size: 13px !important;
      font-weight: 600 !important;
      color: #333333 !important;
      text-align: left !important;
      padding: 0 !important;
      height: 34px !important;
      min-height: 0 !important;
      margin: 0 0 4px !important;
    }
    #royal-tabs-cards-{{ section.id }} .now {
      font-size: 15px !important;
      font-weight: 800 !important;
      color: #111111 !important;
    }
    #royal-tabs-cards-{{ section.id }} .compare,
    #royal-tabs-cards-{{ section.id }} .installments,
    #royal-tabs-cards-{{ section.id }} .buyform { display: none !important; }

    /* ===== MODAL QUICK BUY (collection-style) ===== */
    #nb-qb-{{ section.id }} {
      position: fixed; inset: 0; z-index: 999999; display: none;
      align-items: flex-end; justify-content: center;
      background: rgba(0,0,0,0.5);
    }
    #nb-qb-{{ section.id }}.nb-open { display: flex; }
    #nb-qb-content-{{ section.id }} {
      background: #fff; width: 100%; max-width: 500px;
      border-radius: 16px 16px 0 0; padding: 20px; position: relative;
    }
  </style>

  <div class="container">

    {% unless section.settings.hide_tabs %}
      <div class="headbar">
        <div class="tabsbar" role="tablist" aria-label="Categorias">
          {% if fallback_tab %}
            <button class="tabbtn" type="button" aria-selected="true" data-coll-url="{{ section.settings.collection_fallback.url }}">Oferta</button>
          {% else %}
            {% for b in tabs %}
              <button
                class="tabbtn"
                type="button"
                role="tab"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                data-tab="{{ b.id }}"
                data-coll-url="{% if b.settings.collection %}{{ b.settings.collection.url }}{% else %}{{ initial_view_more_url }}{% endif %}">
                {{ b.settings.label }}
              </button>
            {% endfor %}
          {% endif %}
        </div>

        {% if section.settings.show_view_more and initial_view_more_url != blank %}
          <a class="viewmore" href="{{ initial_view_more_url }}" data-view-more>
            {{ section.settings.view_more_label | default: 'Ver mais' }}
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M9 18l6-6-6-6"></path>
            </svg>
          </a>
        {% endif %}
      </div>
    {% else %}
      {% if section.settings.show_view_more and initial_view_more_url != blank %}
        <div class="headbar">
          <div style="flex:1 1 auto;"></div>
          <a class="viewmore" href="{{ initial_view_more_url }}" data-view-more>
            {{ section.settings.view_more_label | default: 'Ver mais' }}
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M9 18l6-6-6-6"></path>
            </svg>
          </a>
        </div>
      {% endif %}
    {% endunless %}

    {% assign limit_count = section.settings.products_count | default: 8 %}

    {% if fallback_tab %}
      {% assign coll = section.settings.collection_fallback %}
      <div class="panel is-active">
        <div class="viewport">
          <button class="rc-nav rc-nav--prev" type="button" aria-label="Anterior">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <button class="rc-nav rc-nav--next" type="button" aria-label="Proximo">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
          <div class="track">
            {% if coll and coll.products_count > 0 %}
              {% for product in coll.products limit: limit_count %}
                {% liquid
                  assign p = product

                  assign has_variants = false
                  if p.variants.size > 1
                    assign has_variants = true
                  endif

                  assign featured = p.featured_image
                  assign img_url = ''
                  if featured
                    assign img_url = featured | img_url: '600x'
                  endif

                  assign compare = p.compare_at_price
                  assign price = p.price

                  assign has_compare = false
                  if compare and compare > price
                    assign has_compare = true
                  endif

                  assign off = 0
                  if has_compare
                    assign off = compare | minus: price | times: 100 | divided_by: compare
                  endif

                  assign first_av = p.selected_or_first_available_variant
                  if first_av == nil
                    assign first_av = p.variants.first
                  endif
                %}

                <div class="slide">
                  <div class="card rc-card"
                    data-product-id="{{ p.id }}"
                    data-has-variants="{% if has_variants %}true{% else %}false{% endif %}"
