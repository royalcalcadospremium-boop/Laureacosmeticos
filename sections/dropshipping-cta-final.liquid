{%- comment -%}
  dropshipping-cta-final.liquid
  Banner full-width escuro com 2 CTAs (cadastro + WhatsApp).
{%- endcomment -%}

{%- liquid
  assign wa_url = section.settings.cta2_url
  if wa_url == blank
    assign wa_url = '#'
  endif
-%}

<section class="lp-cta-final" aria-labelledby="dropshipping-cta-final-{{ section.id }}">
  <div class="lp-section__inner lp-section__inner--narrow">
    {%- if section.settings.eyebrow != blank -%}
      <p class="lp-section__eyebrow lp-reveal" style="color: var(--ad-color-primary-on-dark)">
        {{ section.settings.eyebrow }}
      </p>
    {%- endif -%}

    <h2 id="dropshipping-cta-final-{{ section.id }}" class="lp-cta-final__title lp-reveal">
      {{ section.settings.title }}
    </h2>

    {%- if section.settings.lead != blank -%}
      <p class="lp-cta-final__lead lp-reveal">{{ section.settings.lead }}</p>
    {%- endif -%}

    <div class="lp-hero__ctas lp-reveal">
      {%- if section.settings.cta1_label != blank -%}
        <a class="lp-cta lp-cta--primary lp-cta--large" href="{{ section.settings.cta1_url | default: '#' }}">
          {{ section.settings.cta1_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.cta2_label != blank -%}
        <a class="lp-cta lp-cta--whatsapp lp-cta--large" href="{{ wa_url }}" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          {{ section.settings.cta2_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Dropshipping · CTA Final",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Bora começar?" },
    { "type": "text", "id": "title", "label": "Título (H2)", "default": "Comece a vender hoje, sem investir em estoque" },
    { "type": "textarea", "id": "lead", "label": "Lead", "default": "Cadastro grátis em 1 minuto. Sem mensalidade, sem fidelidade. Você só paga quando vende." },
    { "type": "header", "content": "CTAs" },
    { "type": "text", "id": "cta1_label", "label": "CTA primário · texto", "default": "Começar Agora" },
    { "type": "text", "id": "cta1_url", "label": "CTA primário · link", "default": "/account/register" },
    { "type": "text", "id": "cta2_label", "label": "CTA WhatsApp · texto", "default": "Falar no WhatsApp" },
    { "type": "text", "id": "cta2_url", "label": "CTA WhatsApp · link", "info": "Ex: https://wa.me/55XXXXXXXXXXX" }
  ],
  "presets": [
    { "name": "Dropshipping · CTA Final" }
  ]
}
{% endschema %}
