{%- comment -%}
  Apple-pure product page template (Subsistema 4).
  Two-column layout: gallery left, configurator+CTA right.
  Below: description tile, then floating sticky bar with price + Add to Bag.
{%- endcomment -%}

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign featured_media = current_variant.featured_media | default: product.featured_media -%}

<section class="ad-product" data-section-id="{{ section.id }}" data-section-type="product-template" itemscope itemtype="https://schema.org/Product">
  <meta itemprop="name" content="{{ product.title | escape }}">
  <meta itemprop="brand" content="{{ product.vendor | escape }}">
  <link itemprop="url" href="{{ shop.url }}{{ product.url }}">

  <div class="ad-product__inner">

    <div class="ad-product__gallery">
      {%- if product.media.size > 0 -%}
        <div class="ad-product__media-main" data-media-main>
          <img id="ad-product-hero" src="{{ featured_media | img_url: '1200x' }}" alt="{{ product.title | escape }}" loading="eager" width="1200" height="1200">
        </div>
        {%- if product.media.size > 1 -%}
          <div class="ad-product__thumbs" role="list">
            {%- for media in product.media -%}
              <button type="button" class="ad-product__thumb {% if forloop.first %}is-selected{% endif %}" data-media-src="{{ media | img_url: '1200x' }}" data-thumb-index="{{ forloop.index0 }}" aria-label="Imagem {{ forloop.index }} de {{ product.media.size }}">
                <img src="{{ media | img_url: '160x' }}" alt="" loading="lazy" width="80" height="80">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- else -%}
        <div class="ad-product__media-main ad-product__media-placeholder">
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}
    </div>

    <div class="ad-product__info">
      {%- if product.vendor != blank -%}
        <p class="ad-product__vendor ad-caption-strong">{{ product.vendor }}</p>
      {%- endif -%}

      <h1 class="ad-product__title ad-display-md" itemprop="name">{{ product.title }}</h1>

      <div class="ad-product__pricing" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
        <meta itemprop="priceCurrency" content="{{ shop.currency }}">
        <link itemprop="availability" href="https://schema.org/{% if current_variant.available %}InStock{% else %}OutOfStock{% endif %}">
        <p class="ad-product__price ad-lead" data-price>
          <span data-price-now>{{ current_variant.price | money }}</span>
          <span class="ad-product__price-was ad-caption" data-price-was {% if current_variant.compare_at_price <= current_variant.price %}hidden{% endif %}>
            <s data-price-was-text>{% if current_variant.compare_at_price > current_variant.price %}{{ current_variant.compare_at_price | money }}{% endif %}</s>
          </span>
        </p>
        <meta itemprop="price" content="{{ current_variant.price | divided_by: 100.0 }}">
      </div>

      <form action="{{ routes.cart_add_url }}" method="post" enctype="multipart/form-data" class="ad-product__form" data-product-form>

        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <div class="ad-product__option" data-option-index="{{ forloop.index0 }}">
              <p class="ad-product__option-label ad-caption-strong">{{ option.name }}</p>
              <div class="ad-product__chips">
                {%- for value in option.values -%}
                  {%- assign chip_id = section.id | append: '-' | append: option.name | append: '-' | append: forloop.index -%}
                  <input type="radio" id="{{ chip_id }}" name="options[{{ option.name | escape }}]" value="{{ value | escape }}" {% if option.selected_value == value %}checked{% endif %} class="ad-product__chip-input" data-chip-option="{{ forloop.parentloop.index0 }}">
                  <label for="{{ chip_id }}" class="ad-product__chip">{{ value }}</label>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        {%- endunless -%}

        <select name="id" data-variant-select hidden>
          {%- for variant in product.variants -%}
            <option value="{{ variant.id }}" {% if variant == current_variant %}selected{% endif %} data-price="{{ variant.price | money }}" data-was="{% if variant.compare_at_price > variant.price %}{{ variant.compare_at_price | money }}{% endif %}" {% unless variant.available %}disabled{% endunless %}>
              {{ variant.title }}
            </option>
          {%- endfor -%}
        </select>

        <div class="ad-product__qty">
          <label class="ad-caption-strong" for="ad-qty-{{ section.id }}">Quantidade</label>
          <input id="ad-qty-{{ section.id }}" type="number" name="quantity" value="1" min="1" class="ad-product__qty-input">
        </div>

        <div class="ad-product__ctas">
          <button type="submit" class="ad-btn ad-btn--primary ad-product__add" data-add-btn {% unless current_variant.available %}disabled{% endunless %}>
            {% if current_variant.available %}Adicionar à sacola{% else %}Esgotado{% endif %}
          </button>
          {%- if section.settings.whatsapp_url != blank -%}
            {%- render 'apple-button',
                variant: 'secondary-pill',
                href: section.settings.whatsapp_url,
                label: 'Falar no WhatsApp' -%}
          {%- endif -%}
        </div>
      </form>

      {%- if product.description != blank -%}
        <div class="ad-product__desc">
          <h2 class="ad-product__desc-heading ad-tagline">Descrição</h2>
          <div class="ad-product__desc-body ad-body" itemprop="description">{{ product.description }}</div>
        </div>
      {%- endif -%}

    </div>

  </div>

  {%- if section.settings.show_sticky_bar -%}
    <div class="ad-product__sticky ad-frosted" data-sticky-bar hidden>
      <div class="ad-product__sticky-inner">
        <div class="ad-product__sticky-info">
          <p class="ad-product__sticky-title ad-body-strong">{{ product.title }}</p>
          <p class="ad-product__sticky-price ad-body" data-sticky-price>{{ current_variant.price | money }}</p>
        </div>
        <button type="button" class="ad-btn ad-btn--primary" onclick="document.querySelector('[data-add-btn]').click()">
          Adicionar à sacola
        </button>
      </div>
    </div>
  {%- endif -%}
</section>

<style>
  .ad-product { padding: var(--ad-space-xxl) 0 var(--ad-space-section); background: var(--ad-color-canvas); }
  .ad-product__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 var(--ad-space-lg);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--ad-space-xxl);
    align-items: start;
  }

  .ad-product__gallery { position: sticky; top: 120px; display: flex; flex-direction: column; gap: var(--ad-space-md); }
  .ad-product__media-main {
    background: var(--ad-color-canvas-parchment);
    border-radius: var(--ad-radius-lg);
    overflow: hidden;
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ad-product__media-main img { width: 100%; height: 100%; object-fit: contain; box-shadow: var(--ad-shadow-product); }
  .ad-product__thumbs {
    display: flex;
    gap: var(--ad-space-xs);
    overflow-x: auto;
    scrollbar-width: thin;
  }
  .ad-product__thumb {
    flex: 0 0 80px;
    background: var(--ad-color-canvas);
    border: 1px solid var(--ad-color-hairline);
    border-radius: var(--ad-radius-sm);
    padding: 4px;
    cursor: pointer;
    transition: border-color 120ms ease-out;
  }
  .ad-product__thumb img { display: block; width: 100%; height: 72px; object-fit: contain; }
  .ad-product__thumb.is-selected { border-color: var(--ad-color-primary-focus); border-width: 2px; padding: 3px; }

  .ad-product__info { display: flex; flex-direction: column; gap: var(--ad-space-lg); }
  .ad-product__vendor { margin: 0; color: var(--ad-color-ink-muted-48); text-transform: uppercase; letter-spacing: 0.5px; }
  .ad-product__title { margin: 0; }
  .ad-product__pricing { display: flex; flex-direction: column; gap: var(--ad-space-xs); }
  .ad-product__price { margin: 0; display: flex; align-items: baseline; gap: var(--ad-space-md); }
  .ad-product__price-was { color: var(--ad-color-ink-muted-48); }
  .ad-product__price-was[hidden] { display: none; }

  .ad-product__option { display: flex; flex-direction: column; gap: var(--ad-space-xs); }
  .ad-product__option-label { margin: 0; }
  .ad-product__chips { display: flex; flex-wrap: wrap; gap: var(--ad-space-xs); }
  .ad-product__chip-input { position: absolute; opacity: 0; pointer-events: none; }
  .ad-product__chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 56px;
    padding: 12px 16px;
    background: var(--ad-color-canvas);
    border: 1px solid var(--ad-color-hairline);
    border-radius: var(--ad-radius-pill);
    cursor: pointer;
    font-size: var(--ad-type-caption-size);
    color: var(--ad-color-ink);
    transition: border-color 120ms ease-out, background-color 120ms ease-out;
  }
  .ad-product__chip:hover { border-color: var(--ad-color-ink-muted-48); }
  .ad-product__chip-input:checked + .ad-product__chip {
    border-color: var(--ad-color-primary-focus);
    border-width: 2px;
    padding: 11px 15px;
  }
  .ad-product__chip-input:focus-visible + .ad-product__chip {
    outline: 2px solid var(--ad-color-primary-focus);
    outline-offset: 2px;
  }

  .ad-product__qty { display: flex; align-items: center; gap: var(--ad-space-sm); }
  .ad-product__qty-input {
    width: 72px;
    padding: 8px 12px;
    border: 1px solid var(--ad-color-hairline);
    border-radius: var(--ad-radius-sm);
    font-size: var(--ad-type-body-size);
    text-align: center;
  }

  .ad-product__ctas { display: flex; gap: var(--ad-space-md); flex-wrap: wrap; }
  .ad-product__add { flex: 1; min-width: 200px; }
  .ad-product__add[disabled] { opacity: 0.6; cursor: not-allowed; }

  .ad-product__desc { padding-top: var(--ad-space-lg); border-top: 1px solid var(--ad-color-divider-soft); }
  .ad-product__desc-heading { margin: 0 0 var(--ad-space-sm); }
  .ad-product__desc-body { color: var(--ad-color-ink-muted-80); }
  .ad-product__desc-body p { margin: 0 0 var(--ad-space-sm); }

  .ad-product__sticky {
    position: fixed;
    left: 0; right: 0; bottom: 0;
    z-index: 50;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }
  .ad-product__sticky[hidden] { display: none; }
  .ad-product__sticky-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 12px var(--ad-space-lg);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--ad-space-md);
    min-height: 64px;
  }
  .ad-product__sticky-info { display: flex; flex-direction: column; gap: 2px; }
  .ad-product__sticky-title, .ad-product__sticky-price { margin: 0; }

  @media (max-width: 833px) {
    .ad-product__inner { grid-template-columns: 1fr; gap: var(--ad-space-xl); }
    .ad-product__gallery { position: static; }
  }
</style>

<script>
(function(){
  var root = document.querySelector('[data-section-id="{{ section.id }}"]');
  if (!root) return;

  var select = root.querySelector('[data-variant-select]');
  var chipsByOption = {};
  root.querySelectorAll('.ad-product__chip-input').forEach(function(input){
    var idx = input.dataset.chipOption;
    chipsByOption[idx] = chipsByOption[idx] || [];
    chipsByOption[idx].push(input);
    input.addEventListener('change', updateSelection);
  });

  function getSelected() {
    var picked = [];
    Object.keys(chipsByOption).forEach(function(idx){
      var checked = chipsByOption[idx].find(function(i){ return i.checked; });
      if (checked) picked.push(checked.value);
    });
    return picked;
  }

  function updateSelection() {
    var picked = getSelected();
    var match = Array.from(select.options).find(function(o){
      var v = o.text.trim().split(' / ').map(function(s){ return s.trim(); });
      return v.length === picked.length && v.every(function(val, i){ return val === picked[i]; });
    });
    if (match) {
      select.value = match.value;
      var priceEl = root.querySelector('[data-price-now]');
      var wasWrap = root.querySelector('[data-price-was]');
      var wasText = root.querySelector('[data-price-was-text]');
      var stickyPriceEl = root.querySelector('[data-sticky-price]');
      var addBtn = root.querySelector('[data-add-btn]');
      if (priceEl) priceEl.textContent = match.dataset.price;
      if (stickyPriceEl) stickyPriceEl.textContent = match.dataset.price;
      if (wasWrap && wasText) {
        var w = match.dataset.was || '';
        wasText.textContent = w;
        wasWrap.hidden = !w;
      }
      if (addBtn) {
        addBtn.disabled = match.disabled;
        addBtn.textContent = match.disabled ? 'Esgotado' : 'Adicionar à sacola';
      }
    }
  }

  var hero = root.querySelector('#ad-product-hero');
  root.querySelectorAll('.ad-product__thumb').forEach(function(t){
    t.addEventListener('click', function(){
      root.querySelectorAll('.ad-product__thumb').forEach(function(x){ x.classList.remove('is-selected'); });
      t.classList.add('is-selected');
      if (hero) hero.src = t.dataset.mediaSrc;
    });
  });

  var stickyBar = root.querySelector('[data-sticky-bar]');
  var ctas = root.querySelector('.ad-product__ctas');
  if (stickyBar && ctas) {
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){ stickyBar.hidden = e.isIntersecting; });
    }, { threshold: 0 });
    io.observe(ctas);
  }
})();
</script>

{% schema %}
{
  "name": "Produto (Apple)",
  "settings": [
    { "type": "url", "id": "whatsapp_url", "label": "URL WhatsApp (CTA secundário)", "default": "https://wa.me/5562991902661" },
    { "type": "checkbox", "id": "show_sticky_bar", "label": "Floating sticky bar com preço + Add", "default": true }
  ]
}
{% endschema %}
