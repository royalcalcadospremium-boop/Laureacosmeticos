{%- liquid
  assign variant = section.settings.variant | default: 'light'
  assign bg = '#ffffff'
  if variant == 'parchment'
    assign bg = 'var(--ad-canvas-parchment, #f5f5f7)'
  endif
-%}

<section
  class="ad-faq ad-faq--{{ variant }}"
  id="section-{{ section.id }}"
  style="background:{{ bg }};"
>
  <div class="ad-faq__inner">
    <header class="ad-faq__header">
      <h1 class="ad-display-lg ad-faq__title">{{ page.title }}</h1>
      {%- if page.content != blank -%}
        <div class="ad-lead-airy ad-faq__intro">{{ page.content }}</div>
      {%- endif -%}
    </header>

    {%- if section.settings.show_search -%}
      <div class="ad-faq__search">
        <input
          type="search"
          class="ad-faq__search-input"
          id="ad-faq-search-{{ section.id }}"
          placeholder="Buscar perguntas..."
          autocomplete="off"
        >
      </div>
    {%- endif -%}

    {%- if section.blocks.size == 0 -%}
      <div class="ad-faq__empty">
        <p class="ad-display-md">Em breve, perguntas frequentes.</p>
      </div>
    {%- else -%}
      <div class="ad-faq__body" id="ad-faq-body-{{ section.id }}">
        {%- assign open_group = false -%}
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'category' -%}
              {%- if open_group -%}
                </div>
              {%- endif -%}
              <div class="ad-faq__category" {{ block.shopify_attributes }}>
                <h2 class="ad-display-md ad-faq__category-title">{{ block.settings.title | escape }}</h2>
                <div class="ad-faq__items">
              {%- assign open_group = true -%}
            {%- when 'item' -%}
              {%- unless open_group -%}
                <div class="ad-faq__category">
                  <div class="ad-faq__items">
                {%- assign open_group = true -%}
              {%- endunless -%}
              <details class="ad-faq__item" {{ block.shopify_attributes }}>
                <summary class="ad-faq__question ad-body-strong">
                  <span class="ad-faq__question-text">{{ block.settings.question | escape }}</span>
                  <svg class="ad-faq__chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                    <path d="M3 5L7 9L11 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </summary>
                <div class="ad-faq__answer ad-body">{{ block.settings.answer }}</div>
              </details>
          {%- endcase -%}
        {%- endfor -%}
        {%- if open_group -%}
          </div></div>
        {%- endif -%}
      </div>

      <p class="ad-faq__no-results ad-body" id="ad-faq-empty-{{ section.id }}" style="display:none;">
        Nenhum resultado encontrado.
      </p>
    {%- endif -%}
  </div>
</section>

<style>
  #section-{{ section.id }}.ad-faq {
    padding: var(--ad-space-xxl, 96px) var(--ad-space-lg, 24px);
  }

  #section-{{ section.id }} .ad-faq__inner {
    max-width: 880px;
    margin: 0 auto;
  }

  #section-{{ section.id }} .ad-faq__header {
    text-align: center;
    margin-bottom: var(--ad-space-xl, 64px);
  }

  #section-{{ section.id }} .ad-faq__title {
    color: var(--ad-ink, #1d1d1f);
    margin: 0 0 var(--ad-space-md, 16px);
  }

  #section-{{ section.id }} .ad-faq__intro {
    color: var(--ad-ink-muted-80, rgba(29,29,31,0.8));
    max-width: 640px;
    margin: 0 auto;
  }

  #section-{{ section.id }} .ad-faq__search {
    margin: 0 auto var(--ad-space-xl, 64px);
    max-width: 480px;
  }

  #section-{{ section.id }} .ad-faq__search-input {
    width: 100%;
    padding: 14px 20px;
    border: 1px solid var(--ad-hairline, rgba(0,0,0,0.12));
    border-radius: 999px;
    background: #fff;
    font: inherit;
    font-size: 15px;
    color: var(--ad-ink, #1d1d1f);
    transition: border-color 160ms ease, box-shadow 160ms ease;
    outline: none;
  }

  #section-{{ section.id }} .ad-faq__search-input::placeholder {
    color: var(--ad-ink-muted-48, rgba(29,29,31,0.48));
  }

  #section-{{ section.id }} .ad-faq__search-input:focus {
    border-color: var(--ad-primary, #0066cc);
    box-shadow: 0 0 0 4px rgba(0,102,204,0.12);
  }

  #section-{{ section.id }} .ad-faq__category {
    margin-bottom: var(--ad-space-xl, 64px);
  }

  #section-{{ section.id }} .ad-faq__category:last-child {
    margin-bottom: 0;
  }

  #section-{{ section.id }} .ad-faq__category-title {
    color: var(--ad-ink, #1d1d1f);
    margin: 0 0 var(--ad-space-md, 16px);
  }

  #section-{{ section.id }} .ad-faq__items {
    border-top: 1px solid var(--ad-divider-soft, rgba(0,0,0,0.08));
  }

  #section-{{ section.id }} .ad-faq__item {
    border-bottom: 1px solid var(--ad-divider-soft, rgba(0,0,0,0.08));
    padding: 24px 0;
  }

  #section-{{ section.id }} .ad-faq__question {
    color: var(--ad-ink, #1d1d1f);
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    list-style: none;
    user-select: none;
  }

  #section-{{ section.id }} .ad-faq__question::-webkit-details-marker {
    display: none;
  }

  #section-{{ section.id }} .ad-faq__question-text {
    flex: 1;
  }

  #section-{{ section.id }} .ad-faq__chevron {
    flex-shrink: 0;
    color: var(--ad-ink-muted-80, rgba(29,29,31,0.8));
    transition: transform 200ms ease;
  }

  #section-{{ section.id }} .ad-faq__item[open] .ad-faq__chevron {
    transform: rotate(180deg);
  }

  #section-{{ section.id }} .ad-faq__answer {
    color: var(--ad-ink-muted-80, rgba(29,29,31,0.8));
    padding-top: 12px;
  }

  #section-{{ section.id }} .ad-faq__answer p:first-child {
    margin-top: 0;
  }

  #section-{{ section.id }} .ad-faq__answer p:last-child {
    margin-bottom: 0;
  }

  #section-{{ section.id }} .ad-faq__answer a {
    color: var(--ad-primary, #0066cc);
    text-decoration: none;
  }

  #section-{{ section.id }} .ad-faq__answer a:hover {
    text-decoration: underline;
  }

  #section-{{ section.id }} .ad-faq__empty {
    text-align: center;
    padding: var(--ad-space-xxl, 96px) 0;
    color: var(--ad-ink-muted-48, rgba(29,29,31,0.48));
  }

  #section-{{ section.id }} .ad-faq__no-results {
    text-align: center;
    color: var(--ad-ink-muted-48, rgba(29,29,31,0.48));
    padding: var(--ad-space-xl, 64px) 0;
  }

  @media (max-width: 640px) {
    #section-{{ section.id }}.ad-faq {
      padding: var(--ad-space-xl, 64px) var(--ad-space-md, 16px);
    }
    #section-{{ section.id }} .ad-faq__header {
      margin-bottom: var(--ad-space-lg, 32px);
    }
  }
</style>

{%- if section.settings.show_search -%}
  <script>
    (function() {
      var input = document.getElementById('ad-faq-search-{{ section.id }}');
      var body = document.getElementById('ad-faq-body-{{ section.id }}');
      var emptyMsg = document.getElementById('ad-faq-empty-{{ section.id }}');
      if (!input || !body) return;

      input.addEventListener('input', function() {
        var query = input.value.toLowerCase().trim();
        var items = body.querySelectorAll('.ad-faq__item');
        var categories = body.querySelectorAll('.ad-faq__category');
        var visibleCount = 0;

        items.forEach(function(item) {
          var text = item.textContent.toLowerCase();
          var match = query === '' || text.indexOf(query) !== -1;
          item.style.display = match ? '' : 'none';
          if (match) visibleCount++;
        });

        categories.forEach(function(cat) {
          var visibleItems = cat.querySelectorAll('.ad-faq__item');
          var hasVisible = false;
          visibleItems.forEach(function(i) {
            if (i.style.display !== 'none') hasVisible = true;
          });
          cat.style.display = hasVisible ? '' : 'none';
        });

        if (emptyMsg) {
          emptyMsg.style.display = (visibleCount === 0 && query !== '') ? '' : 'none';
        }
      });
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "FAQ",
  "settings": [
    {
      "type": "select",
      "id": "variant",
      "label": "Background variant",
      "options": [
        { "value": "light", "label": "Light" },
        { "value": "parchment", "label": "Parchment" }
      ],
      "default": "light"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search bar",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Category title",
          "default": "Category"
        }
      ]
    },
    {
      "type": "item",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "category",
        "settings": { "title": "Pedidos e envio" }
      },
      {
        "type": "item",
        "settings": {
          "question": "Vocês fazem entregas para todo o Brasil?",
          "answer": "<p>Sim, entregamos em todo o território nacional. O frete e prazo são calculados no checkout.</p>"
        }
      },
      {
        "type": "item",
        "settings": {
          "question": "Qual o prazo de envio do meu pedido?",
          "answer": "<p>Pedidos são processados em até 2 dias úteis. O prazo de entrega depende da sua região.</p>"
        }
      },
      {
        "type": "category",
        "settings": { "title": "Produtos" }
      },
      {
        "type": "item",
        "settings": {
          "question": "Posso trocar um produto?",
          "answer": "<p>Sim. Entre em contato com nosso atendimento e iremos te ajudar com a troca.</p>"
        }
      },
      {
        "type": "category",
        "settings": { "title": "Outros" }
      },
      {
        "type": "item",
        "settings": {
          "question": "Tem mais alguma dúvida?",
          "answer": "<p>Fale com a gente pela página de contato. Estamos prontos para ajudar.</p>"
        }
      }
    ]
  }
}
{% endschema %}
