<section data-section-id="{{ section.id }}" data-section-type="password" class="ad-password">
  <div class="ad-password__stack">
    {%- assign logo_image = section.settings.logo | default: shop.logo -%}
    {%- if logo_image != blank -%}
      <div class="ad-password__logo">
        <img
          src="{{ logo_image | img_url: '240x80' }}"
          alt="{{ shop.name | escape }}"
          loading="eager"
          width="240"
          height="40">
      </div>
    {%- endif -%}

    <h1 class="ad-hero-display ad-password__title">
      {{ section.settings.heading | default: 'Em breve.' | escape }}
    </h1>

    {%- assign subline = section.settings.subline | default: 'Estamos preparando uma experiência excepcional. Volte logo.' -%}
    <p class="ad-lead ad-password__subline">{{ subline | escape }}</p>

    <div class="ad-password__signup">
      {%- form 'customer', id: 'ad-password-newsletter', class: 'ad-password__form' -%}
        {%- if form.posted_successfully? -%}
          <p class="ad-body ad-password__success">Obrigado. Te avisamos quando abrirmos.</p>
        {%- else -%}
          <input type="hidden" name="contact[tags]" value="newsletter,password-page">
          <input type="hidden" name="contact[context]" value="password-page">

          <div class="ad-password__row">
            <label class="visually-hidden" for="ad-password-email">E-mail</label>
            <input
              type="email"
              id="ad-password-email"
              name="contact[email]"
              class="ad-password__input"
              placeholder="seu@email.com"
              autocomplete="email"
              required>
            {% render 'apple-button', variant: 'primary', label: 'Avise-me', type: 'submit', class: 'ad-password__submit' %}
          </div>

          {%- if form.errors -%}
            <p class="ad-caption ad-password__error">
              {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
            </p>
          {%- endif -%}
        {%- endif -%}
      {%- endform -%}
    </div>

    {%- assign has_social = false -%}
    {%- if section.settings.instagram_url != blank or section.settings.whatsapp_url != blank or section.settings.facebook_url != blank -%}
      {%- assign has_social = true -%}
    {%- endif -%}

    {%- if has_social -%}
      <ul class="ad-password__social" role="list">
        {%- if section.settings.instagram_url != blank -%}
          <li>
            <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
            </a>
          </li>
        {%- endif -%}
        {%- if section.settings.whatsapp_url != blank -%}
          <li>
            <a href="{{ section.settings.whatsapp_url }}" target="_blank" rel="noopener" aria-label="WhatsApp">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.5 12a8.5 8.5 0 0 1-12.7 7.4L3.5 20.5l1.2-4.2A8.5 8.5 0 1 1 20.5 12z"/><path d="M8.6 9.2c.2-.5.5-.5.8-.5h.5c.2 0 .4 0 .6.5l.8 1.9c.1.2 0 .4-.1.6l-.4.5c-.1.1-.2.3-.1.5.2.4.7 1.2 1.4 1.8.9.8 1.7 1.1 2 1.2.2.1.4 0 .5-.1l.5-.6c.2-.2.4-.2.6-.1l1.8.9c.2.1.4.2.4.4 0 .2-.1 1-.5 1.4-.4.4-1.1.8-1.8.8-.5 0-1 0-3-.8s-3.3-2.8-3.4-3c-.1-.2-.9-1.2-.9-2.3 0-1 .5-1.6.7-1.8z" fill="currentColor" stroke="none"/></svg>
            </a>
          </li>
        {%- endif -%}
        {%- if section.settings.facebook_url != blank -%}
          <li>
            <a href="{{ section.settings.facebook_url }}" target="_blank" rel="noopener" aria-label="Facebook">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13.5 21v-7.5h2.5l.4-3h-2.9V8.6c0-.9.3-1.5 1.6-1.5H16.6V4.4c-.3 0-1.2-.1-2.3-.1-2.3 0-3.8 1.4-3.8 3.9v2.2H8v3h2.5V21h3z"/></svg>
            </a>
          </li>
        {%- endif -%}
      </ul>
    {%- endif -%}

    <div class="ad-password__login">
      {%- form 'storefront_password', class: 'ad-password__login-form' -%}
        {%- if form.errors -%}
          <p class="ad-caption ad-password__error">{{ form.errors.messages.form }}</p>
        {%- endif -%}
        <details class="ad-password__login-details">
          <summary class="ad-password__login-toggle">Entrar com senha</summary>
          <div class="ad-password__login-row">
            <label class="visually-hidden" for="ad-password-pw">Senha</label>
            <input
              type="password"
              id="ad-password-pw"
              name="password"
              class="ad-password__input ad-password__input--pw"
              placeholder="Senha"
              autocomplete="current-password">
            {% render 'apple-button', variant: 'primary', label: 'Entrar', type: 'submit', class: 'ad-password__submit' %}
          </div>
        </details>
      {%- endform -%}
    </div>
  </div>
</section>

<style>
  .ad-password {
    background: var(--ad-color-surface-tile-1, #272729);
    color: var(--ad-color-on-dark, #ffffff);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px 24px;
    width: 100%;
  }
  .ad-password__stack {
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }
  .ad-password__logo img {
    max-height: 40px;
    width: auto;
    filter: brightness(0) invert(1);
  }
  .ad-password__title {
    color: var(--ad-color-on-dark, #ffffff);
    margin: 0;
  }
  .ad-password__subline {
    color: var(--ad-color-body-muted, #cccccc);
    margin: 0;
    max-width: 520px;
  }
  .ad-password__signup { width: 100%; margin-top: 8px; }
  .ad-password__form { margin: 0; }
  .ad-password__row {
    display: flex;
    flex-direction: row;
    gap: 12px;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
  }
  .ad-password__input {
    width: 320px;
    max-width: 100%;
    padding: 12px 20px;
    background: #ffffff;
    color: var(--ad-color-ink, #1d1d1f);
    border: 1px solid var(--ad-color-hairline, #e0e0e0);
    border-radius: var(--ad-radius-pill, 9999px);
    font: 400 17px/1.47 'SF Pro Text', system-ui, -apple-system, sans-serif;
    letter-spacing: -0.374px;
    outline: none;
  }
  .ad-password__input:focus { border-color: var(--ad-color-primary-focus, #0071e3); box-shadow: 0 0 0 3px rgba(0,113,227,0.2); }
  .ad-password__input::placeholder { color: var(--ad-color-ink-muted-48, #7a7a7a); }
  .ad-password__success { color: var(--ad-color-body-muted, #cccccc); margin: 0; }
  .ad-password__error { color: var(--ad-color-primary-on-dark, #2997ff); margin: 8px 0 0; }
  .ad-password__social {
    list-style: none;
    padding: 0;
    margin: 8px 0 0;
    display: flex;
    gap: 24px;
    justify-content: center;
  }
  .ad-password__social a {
    color: #ffffff;
    opacity: 0.6;
    transition: opacity 0.2s ease;
    display: inline-flex;
  }
  .ad-password__social a:hover,
  .ad-password__social a:focus { opacity: 1; }
  .ad-password__login { margin-top: 24px; width: 100%; }
  .ad-password__login-form { margin: 0; }
  .ad-password__login-details { text-align: center; }
  .ad-password__login-toggle {
    color: var(--ad-color-primary-on-dark, #2997ff);
    font: 400 17px/1.47 'SF Pro Text', system-ui, -apple-system, sans-serif;
    letter-spacing: -0.374px;
    cursor: pointer;
    list-style: none;
    display: inline-block;
  }
  .ad-password__login-toggle::-webkit-details-marker { display: none; }
  .ad-password__login-row {
    display: flex;
    flex-direction: row;
    gap: 12px;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    margin-top: 16px;
  }
  .visually-hidden {
    position: absolute !important;
    width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }
  @media (max-width: 640px) {
    .ad-password { min-height: 600px; padding: 64px 20px; }
    .ad-password__row,
    .ad-password__login-row { flex-direction: column; }
    .ad-password__input { width: 100%; }
    .ad-password__submit { width: 100%; }
  }
</style>

{% schema %}
{
  "name": "Password page",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo (versão branca recomendada)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Em breve."
    },
    {
      "type": "textarea",
      "id": "subline",
      "label": "Subtítulo",
      "default": "Estamos preparando uma experiência excepcional. Volte logo."
    },
    {
      "type": "header",
      "content": "Redes sociais"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "whatsapp_url",
      "label": "WhatsApp URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    }
  ]
}
{% endschema %}
