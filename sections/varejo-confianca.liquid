{%- comment -%}
  varejo-confianca.liquid
  Faixa de 5 selos de confiança (originais, frete, parcelamento, troca, WhatsApp).
  Cada selo é hardcoded em ordem fixa — sem blocks. Settings só pra eyebrow/título.
  Grid 5 colunas desktop, 2 colunas mobile (último item ocupa full width).
{%- endcomment -%}

{{ 'lp-shared.css' | asset_url | stylesheet_tag }}
<script src="{{ 'lp-shared.js' | asset_url }}" defer></script>

<section class="lp-section lp-section--parchment" aria-labelledby="varejo-confianca-title-{{ section.id }}">
  <div class="lp-section__inner">
    {%- if section.settings.title != blank or section.settings.eyebrow != blank -%}
      <header class="lp-section__head">
        {%- if section.settings.eyebrow != blank -%}
          <p class="lp-section__eyebrow lp-reveal">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 id="varejo-confianca-title-{{ section.id }}" class="lp-section__title lp-reveal">{{ section.settings.title }}</h2>
        {%- endif -%}
        {%- if section.settings.lead != blank -%}
          <p class="lp-section__lead lp-reveal">{{ section.settings.lead }}</p>
        {%- endif -%}
      </header>
    {%- endif -%}

    <div class="varejo-trust-grid">
      <div class="lp-card lp-card--centered lp-reveal">
        <div class="lp-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L3 6v6c0 5 3.8 9.5 9 10 5.2-.5 9-5 9-10V6l-9-4z"/>
            <polyline points="9 12 11 14 15 10"/>
          </svg>
        </div>
        <h3 class="lp-card__title">100% Originais</h3>
        <p class="lp-card__text">Nota fiscal e selo de garantia direto das marcas.</p>
      </div>

      <div class="lp-card lp-card--centered lp-reveal">
        <div class="lp-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="1" y="6" width="13" height="11" rx="1"/>
            <path d="M14 9h4l3 4v4h-7"/>
            <circle cx="6" cy="19" r="2"/>
            <circle cx="17" cy="19" r="2"/>
          </svg>
        </div>
        <h3 class="lp-card__title">Frete Grátis R$150+</h3>
        <p class="lp-card__text">Entrega gratuita pro Brasil todo em compras acima de R$150.</p>
      </div>

      <div class="lp-card lp-card--centered lp-reveal">
        <div class="lp-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="5" width="20" height="14" rx="2"/>
            <line x1="2" y1="10" x2="22" y2="10"/>
            <line x1="6" y1="15" x2="10" y2="15"/>
          </svg>
        </div>
        <h3 class="lp-card__title">12x sem juros</h3>
        <p class="lp-card__text">Parcele em até 12 vezes no cartão sem custo adicional.</p>
      </div>

      <div class="lp-card lp-card--centered lp-reveal">
        <div class="lp-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="17 1 21 5 17 9"/>
            <path d="M3 11V9a4 4 0 0 1 4-4h14"/>
            <polyline points="7 23 3 19 7 15"/>
            <path d="M21 13v2a4 4 0 0 1-4 4H3"/>
          </svg>
        </div>
        <h3 class="lp-card__title">Troca em 7 dias</h3>
        <p class="lp-card__text">Trocou e não serviu? Devolução fácil em até 7 dias úteis.</p>
      </div>

      <div class="lp-card lp-card--centered lp-reveal">
        <div class="lp-card__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
          </svg>
        </div>
        <h3 class="lp-card__title">WhatsApp humano</h3>
        <p class="lp-card__text">Atendimento de gente de verdade — sem bot, sem espera longa.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .varejo-trust-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--ad-space-lg);
  }
  .lp-card--centered {
    text-align: center;
    align-items: center;
  }
  .lp-card--centered .lp-card__icon { margin-left: auto; margin-right: auto; }
  @media (max-width: 1023px) {
    .varejo-trust-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--ad-space-md);
    }
    .varejo-trust-grid > :last-child {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 480px) {
    .varejo-trust-grid {
      grid-template-columns: 1fr;
    }
    .varejo-trust-grid > :last-child {
      grid-column: auto;
    }
  }
</style>

{% schema %}
{
  "name": "Varejo · Confiança",
  "tag": "section",
  "class": "lp-section-wrap lp-section-wrap--trust",
  "enabled_on": { "templates": ["page"] },
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Por que comprar com a gente" },
    { "type": "text", "id": "title", "label": "Título", "default": "Confiança que cabe na palma da mão" },
    { "type": "textarea", "id": "lead", "label": "Subtítulo", "default": "Cinco garantias pra você comprar tranquilo." }
  ],
  "presets": [
    { "name": "Varejo · Confiança" }
  ]
}
{% endschema %}
