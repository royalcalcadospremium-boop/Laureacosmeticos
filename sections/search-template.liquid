{% comment %}
Royal • Search Gummy Style (v1.0.0)
- Espelha collection-template.liquid: mesma rc-grid, mesmo rc-product-card,
  mesmo seletor de tier, mesmo Quick Buy modal.
- Sem filtros de marca/modelo/tamanho (resultados de busca são heterogêneos).
- Sem botão "Baixar fotos" (download é por coleção, não por busca).
- Resultados não-produto (pages, articles) aparecem em lista compacta no fim.
{% endcomment %}

{%- assign items_per_page = section.settings.products_per_page | default: 24 -%}
{%- render 'rc-tier-card-assets' -%}

<section id="royal-search-gummy-{{ section.id }}" class="royal-section-fix" data-section-id="{{ section.id }}" data-section-type="search">

  <style>
    #royal-search-gummy-{{ section.id }}, #royal-search-gummy-{{ section.id }} * { box-sizing: border-box; }

    #royal-search-gummy-{{ section.id }}{
      --bg: {{ section.settings.bg | default: '#FFFFFF' }};
      --card: {{ section.settings.card_bg | default: '#ffffff' }};
      --primary: {{ section.settings.primary | default: '#111111' }};
      --green: {{ section.settings.green | default: '#B6E35C' }};
      --text: {{ section.settings.text | default: '#333333' }};
      --radius: {{ section.settings.card_radius | default: 6 }}px;
      --badge-bg: {{ section.settings.badge_bg | default: '#1a1a1a' }};
      --badge-opacity: {{ section.settings.badge_opacity | default: 100 | times: 0.01 }};
      background: var(--bg);
      padding: 18px 0 34px;
      overflow-x: hidden;
    }

    #royal-search-gummy-{{ section.id }} .rc-container{ max-width: 1320px; margin: 0 auto; padding: 0 16px; width: 100%; }
    #royal-search-gummy-{{ section.id }} .rc-title{ color: var(--primary); font-weight: 700; font-size: clamp(22px, 3vw, 36px); margin: 10px 0; }
    #royal-search-gummy-{{ section.id }} .rc-subtitle{ color: #666; font-size: 14px; margin: 0 0 16px; }

    /* SEARCH FORM */
    #royal-search-gummy-{{ section.id }} .rc-search-form{
      display: flex; gap: 8px; max-width: 560px; margin: 0 0 24px;
    }
    #royal-search-gummy-{{ section.id }} .rc-search-input{
      flex: 1; height: 44px; padding: 10px 18px;
      border: 1px solid #e0e0e0; border-radius: 9999px;
      font-size: 15px; font-family: inherit; color: var(--text); background: #fff;
    }
    #royal-search-gummy-{{ section.id }} .rc-search-input:focus{
      outline: 2px solid #0066cc; outline-offset: 1px; border-color: #0066cc;
    }
    #royal-search-gummy-{{ section.id }} .rc-search-btn{
      height: 44px; padding: 0 24px; background: #111; color: #fff;
      border: 0; border-radius: 9999px; font-weight: 700; cursor: pointer;
      font-size: 14px;
    }
    #royal-search-gummy-{{ section.id }} .rc-search-btn:hover{ opacity: 0.9; }

    /* GRID CORE (idêntico à collection) */
    #royal-search-gummy-{{ section.id }} .rc-grid{
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
      width: 100%;
    }
    @media (max-width: 1100px){ #royal-search-gummy-{{ section.id }} .rc-grid{ grid-template-columns: repeat(3, 1fr); } }
    @media (max-width: 767px){
      #royal-search-gummy-{{ section.id }} .rc-grid{ grid-template-columns: repeat(2, 1fr); gap: 10px; }
      #royal-search-gummy-{{ section.id }} .rc-container{ padding: 0 10px; }
    }

    /* CARDS (idêntico à collection) */
    #royal-search-gummy-{{ section.id }} .rc-card{
      background: var(--card);
      border-radius: var(--radius);
      position: relative;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      border: 1px solid #f0f0f0;
      transition: transform 0.2s ease;
    }
    #royal-search-gummy-{{ section.id }} .rc-media{
      display: block; width: 100%; aspect-ratio: 1/1; position: relative; background: #f9f9f9;
    }
    #royal-search-gummy-{{ section.id }} .rc-media img{
      position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center;
    }
    #royal-search-gummy-{{ section.id }} .rc-name{
      font-size: 13px; font-weight: 600; color: var(--text); text-decoration: none;
      display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
      height: 34px; margin: 8px 0 4px; line-height: 1.3;
    }
    #royal-search-gummy-{{ section.id }} .rc-price-value{ font-size: 15px; font-weight: 800; color: #111; }

    #royal-search-gummy-{{ section.id }} .rc-badge{
      position: absolute; top: 8px; left: 8px; background: var(--badge-bg); opacity: var(--badge-opacity); color: #fff;
      border-radius: 2px; font-size: 10px; font-weight: 700; padding: 3px 6px; z-index: 2;
    }
    .nb-bag {
      position: absolute; bottom: 8px; right: 8px; background: #fff; border: none;
      border-radius: 50%; width: 34px; height: 34px; display: flex; align-items: center; justify-content: center;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1); cursor: pointer; z-index: 3;
    }

    /* OUTROS RESULTADOS (pages, articles) */
    #royal-search-gummy-{{ section.id }} .rc-other-results{
      margin-top: 40px; padding-top: 20px; border-top: 1px solid #eee;
    }
    #royal-search-gummy-{{ section.id }} .rc-other-results h2{
      font-size: 18px; font-weight: 700; margin: 0 0 16px; color: var(--primary);
    }
    #royal-search-gummy-{{ section.id }} .rc-other-list{
      list-style: none; margin: 0; padding: 0;
    }
    #royal-search-gummy-{{ section.id }} .rc-other-list li{
      padding: 12px 0; border-bottom: 1px solid #f5f5f5;
    }
    #royal-search-gummy-{{ section.id }} .rc-other-list a{
      color: #0066cc; text-decoration: none; font-size: 15px; font-weight: 600;
    }
    #royal-search-gummy-{{ section.id }} .rc-other-list a:hover{ text-decoration: underline; }
    #royal-search-gummy-{{ section.id }} .rc-other-list .rc-other-snippet{
      color: #666; font-size: 13px; margin-top: 4px; line-height: 1.4;
    }

    /* PAGINAÇÃO (idêntico à collection) */
    #royal-search-gummy-{{ section.id }} .rc-pagination-wrapper { margin-top: 40px; text-align: center; border-top: 1px solid #eee; padding-top: 20px; }
    #royal-search-gummy-{{ section.id }} .rc-pagination { display: flex; justify-content: center; gap: 8px; margin-bottom: 20px; flex-wrap: wrap; }
    #royal-search-gummy-{{ section.id }} .rc-page {
      min-width: 38px; height: 38px; display: flex; align-items: center; justify-content: center;
      border: 1px solid #ddd; border-radius: 4px; text-decoration: none; color: #111; font-weight: 600; font-size: 13px;
    }
    #royal-search-gummy-{{ section.id }} .rc-page[aria-current="page"] { background: #111; color: #fff; border-color: #111; }

    /* EMPTY / INITIAL STATES */
    #royal-search-gummy-{{ section.id }} .rc-empty{
      text-align: center; padding: 60px 20px; background: #fafafa; border-radius: 12px; margin-top: 24px;
    }
    #royal-search-gummy-{{ section.id }} .rc-empty h2{ font-size: 22px; font-weight: 700; margin: 0 0 8px; color: var(--primary); }
    #royal-search-gummy-{{ section.id }} .rc-empty p{ color: #666; margin: 0 0 20px; }
    #royal-search-gummy-{{ section.id }} .rc-empty-cta{
      display: inline-block; padding: 12px 24px; background: #111; color: #fff;
      text-decoration: none; border-radius: 9999px; font-weight: 700; font-size: 14px;
    }

    /* MODAL QUICK BUY (idêntico à collection) */
    .nb-qb-wrap { position: fixed; inset: 0; z-index: 999999; display: none; align-items: flex-end; justify-content: center; background: rgba(0,0,0,0.5); }
    .nb-qb-wrap.nb-open { display: flex; }
    .nb-qb-modal { background: #fff; width: 100%; max-width: 500px; border-radius: 16px 16px 0 0; padding: 20px; position: relative; }
    .qb-close { position: absolute; top: 15px; right: 15px; border: none; background: none; font-size: 24px; cursor: pointer; line-height: 1; }
    .qb-header { display: flex; gap: 15px; align-items: center; margin-bottom: 20px; }
    .qb-thumb { width: 70px; height: 70px; object-fit: cover; border-radius: 8px; }
    .qb-title { margin: 0; font-size: 14px; }
    .qb-price { font-weight: 800; font-size: 16px; }
    .qb-label { font-size: 12px; font-weight: 800; margin-bottom: 10px; }
    .qb-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-bottom: 20px; }
    .sz-btn { padding: 12px; border: 1px solid #ddd; border-radius: 4px; background: #fff; cursor: pointer; font-weight: 700; transition: border-color 0.15s ease; }
    .sz-btn.is-selected { border-color: #111; }
    .sz-btn.is-unavailable, .sz-btn[disabled] { background: #f5f5f5; opacity: 0.4; cursor: not-allowed; }
    .qb-add { width: 100%; padding: 16px; background: #111; color: #fff; border: none; border-radius: 4px; font-weight: 800; cursor: pointer; opacity: 0.5; transition: opacity 0.15s ease; }
    .qb-add.is-ready, .qb-add:not([disabled]) { opacity: 1; }
  </style>

  <div class="rc-container">
    {%- if search.performed -%}
      {%- assign product_count = 0 -%}
      {%- assign other_count = 0 -%}
      {%- for r in search.results -%}
        {%- if r.object_type == 'product' -%}{%- assign product_count = product_count | plus: 1 -%}
        {%- else -%}{%- assign other_count = other_count | plus: 1 -%}{%- endif -%}
      {%- endfor -%}

      <h1 class="rc-title">{{ search.terms | escape }}</h1>
      <p class="rc-subtitle">{{ search.results_count }} {% if search.results_count == 1 %}resultado{% else %}resultados{% endif %}</p>

      <form class="rc-search-form" action="{{ routes.search_url }}" method="get" role="search">
        <input type="hidden" name="type" value="product">
        <input type="search" name="q" class="rc-search-input" value="{{ search.terms | escape }}" placeholder="Buscar produtos…" autocomplete="off" aria-label="Buscar">
        <button type="submit" class="rc-search-btn">Buscar</button>
      </form>

      {%- if search.results_count == 0 -%}
        <div class="rc-empty">
          <h2>Nenhum resultado para "{{ search.terms | escape }}"</h2>
          <p>Tente outros termos ou navegue por todas as marcas.</p>
          <a href="{{ routes.all_products_collection_url }}" class="rc-empty-cta">Ver todos os produtos</a>
        </div>
      {%- else -%}

        {%- paginate search.results by items_per_page -%}

          {%- if product_count > 0 -%}
            <div class="rc-grid">
              {%- for r in search.results -%}
                {%- if r.object_type == 'product' -%}
                  {%- unless r.available -%}{%- continue -%}{%- endunless -%}
                  {%- assign product = r -%}
                  {%- render 'rc-product-card', product: product, product_index: forloop.index -%}
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- if other_count > 0 -%}
            <section class="rc-other-results">
              <h2>Outras páginas ({{ other_count }})</h2>
              <ul class="rc-other-list">
                {%- for r in search.results -%}
                  {%- if r.object_type != 'product' -%}
                    <li>
                      <a href="{{ r.url }}">{{ r.title | escape }}</a>
                      {%- if r.content != blank -%}
                        <div class="rc-other-snippet">{{ r.content | strip_html | truncate: 160 }}</div>
                      {%- endif -%}
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            </section>
          {%- endif -%}

          {%- if paginate.pages > 1 -%}
            <div class="rc-pagination-wrapper">
              <nav class="rc-pagination" aria-label="Paginação">
                {%- for part in paginate.parts -%}
                  {%- if part.is_link -%}<a href="{{ part.url }}" class="rc-page">{{ part.title }}</a>
                  {%- else -%}<span class="rc-page" {% if part.title == paginate.current_page %}aria-current="page"{% endif %}>{{ part.title }}</span>
                  {%- endif -%}
                {%- endfor -%}
              </nav>
            </div>
          {%- endif -%}

        {%- endpaginate -%}

      {%- endif -%}

    {%- else -%}
      {%- comment -%} INITIAL STATE — busca não foi feita ainda {%- endcomment -%}
      <h1 class="rc-title">Buscar</h1>
      <p class="rc-subtitle">Encontre produtos por marca, modelo ou referência.</p>

      <form class="rc-search-form" action="{{ routes.search_url }}" method="get" role="search">
        <input type="hidden" name="type" value="product">
        <input type="search" name="q" class="rc-search-input" placeholder="Buscar produtos…" autocomplete="off" autofocus aria-label="Buscar">
        <button type="submit" class="rc-search-btn">Buscar</button>
      </form>

      <div class="rc-empty">
        <h2>Digite o que você procura acima</h2>
        <p>Você pode buscar por marca (Nike, Adidas, Puma), modelo (Air Max, Mizuno) ou referência.</p>
        <a href="{{ routes.all_products_collection_url }}" class="rc-empty-cta">Ver todos os produtos</a>
      </div>
    {%- endif -%}
  </div>

  {% comment %} Modal Quick Buy {% endcomment %}
  <div class="nb-qb-wrap" id="modal-quick-buy" onclick="if(event.target==this) closeQuickBuy()">
    <div class="nb-qb-modal" id="modal-content"></div>
  </div>

  <script>
    (function() {
      // Quick Buy só é definido se ainda não existir (evita conflito com collection-template)
      if (window.openQuickBuy) return;

      window.openQuickBuy = function(id) {
        const dataEl = document.getElementById('data-' + id);
        if (!dataEl) return;
        const data = JSON.parse(dataEl.textContent);
        const modal = document.getElementById('modal-quick-buy');
        const content = document.getElementById('modal-content');
        if (!modal || !content) return;
        content.replaceChildren();

        const closeBtn = document.createElement('button');
        closeBtn.type = 'button';
        closeBtn.className = 'qb-close';
        closeBtn.setAttribute('aria-label', 'Fechar');
        closeBtn.textContent = '×';
        closeBtn.addEventListener('click', window.closeQuickBuy);

        const header = document.createElement('div');
        header.className = 'qb-header';
        const img = document.createElement('img');
        img.src = data.image;
        img.alt = data.title || '';
        img.className = 'qb-thumb';
        img.width = 70;
        img.height = 70;
        const headerText = document.createElement('div');
        const title = document.createElement('h4');
        title.className = 'qb-title';
        title.textContent = data.title;
        const price = document.createElement('div');
        price.className = 'qb-price';
        price.textContent = data.price;
        headerText.append(title, price);
        header.append(img, headerText);

        const label = document.createElement('div');
        label.className = 'qb-label';
        label.textContent = 'ESCOLHA O TAMANHO:';

        const grid = document.createElement('div');
        grid.className = 'qb-grid';
        data.variants.forEach(v => {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'sz-btn';
          btn.textContent = v.title;
          btn.dataset.variantId = String(v.id);
          if (!v.available) {
            btn.disabled = true;
            btn.classList.add('is-unavailable');
          }
          btn.addEventListener('click', () => window.selectVariant(btn, v.id));
          grid.appendChild(btn);
        });

        const addBtn = document.createElement('button');
        addBtn.type = 'button';
        addBtn.id = 'btn-add-final';
        addBtn.className = 'qb-add';
        addBtn.disabled = true;
        addBtn.textContent = 'ADICIONAR À SACOLA';
        addBtn.addEventListener('click', () => window.finalizeAdd(addBtn));

        content.append(closeBtn, header, label, grid, addBtn);
        modal.classList.add('nb-open');
      };

      window.selectedId = null;
      window.selectVariant = function(btn, id) {
        const prev = btn.parentElement && btn.parentElement.querySelector('.sz-btn.is-selected');
        if (prev) prev.classList.remove('is-selected');
        btn.classList.add('is-selected');
        window.selectedId = id;
        const finalBtn = document.getElementById('btn-add-final');
        if (finalBtn) {
          finalBtn.disabled = false;
          finalBtn.classList.add('is-ready');
        }
      };

      window.finalizeAdd = function(btn) {
        btn.innerText = "ADICIONANDO...";
        fetch('/cart/add.js', {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({ items: [{ id: window.selectedId, quantity: 1 }] })
        }).then(() => {
          btn.innerText = "ADICIONAR À SACOLA";
          document.getElementById('modal-quick-buy').classList.remove('nb-open');
          setTimeout(() => {
            const cartDrawer = document.querySelector('[id*="CartDrawer"], [class*="cart-drawer"], [class*="Cart-drawer"]');
            if (cartDrawer) {
              cartDrawer.classList.add('is-open');
              return;
            }
            const cartBtn = document.querySelector('[data-cart-drawer], [class*="cart-toggle"], button[aria-label*="Cart"]');
            if (cartBtn) { cartBtn.click(); return; }
            document.dispatchEvent(new CustomEvent('cart:open'));
            window.dispatchEvent(new CustomEvent('cart:open'));
            alert("✅ Produto adicionado à sacola com sucesso!");
          }, 300);
        }).catch((err) => {
          btn.innerText = "ADICIONAR À SACOLA";
          console.error(err);
          alert("❌ Erro ao adicionar. Tente novamente.");
        });
      };

      window.closeQuickBuy = function() {
        document.getElementById('modal-quick-buy').classList.remove('nb-open');
      };
    })();
  </script>

</section>

{% schema %}
{
  "name": "Search Royal Gummy",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Produtos por página",
      "min": 12,
      "max": 60,
      "step": 4,
      "default": 24
    },
    { "type": "header", "content": "Cores (espelha collection-template)" },
    { "type": "color", "id": "bg",         "label": "Fundo da seção",       "default": "#FFFFFF" },
    { "type": "color", "id": "card_bg",    "label": "Fundo do card",        "default": "#ffffff" },
    { "type": "color", "id": "primary",    "label": "Texto principal",      "default": "#111111" },
    { "type": "color", "id": "text",       "label": "Texto secundário",     "default": "#333333" },
    { "type": "color", "id": "green",      "label": "Verde (preço atacado)","default": "#B6E35C" },
    { "type": "color", "id": "badge_bg",   "label": "Fundo do badge",       "default": "#1a1a1a" },
    {
      "type": "range",
      "id": "badge_opacity",
      "label": "Opacidade do badge",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 100
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Raio dos cards (px)",
      "min": 0,
      "max": 20,
      "step": 1,
      "default": 6
    }
  ]
}
{% endschema %}
